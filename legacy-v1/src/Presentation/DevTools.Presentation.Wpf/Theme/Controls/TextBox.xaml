<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Modern TextBox Style -->
    <Style x:Key="ModernTextBoxStyle" TargetType="{x:Type TextBox}">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DevToolsBrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>

        <!-- conforto + padrão -->
        <Setter Property="FontSize" Value="{DynamicResource DevToolsFontSize.Input}"/>
        <Setter Property="MinHeight" Value="38"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="CaretBrush" Value="White"/>

        <!-- se tiver scroll, já usa o estilo bonito -->
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      VerticalAlignment="Center"
                                      Margin="{TemplateBinding Padding}"
                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.65"/>
            </Trigger>
            <Trigger Property="IsReadOnly" Value="True">
                <Setter Property="Opacity" Value="0.9"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="InputStyle" TargetType="TextBox" BasedOn="{StaticResource ModernTextBoxStyle}"/>

    <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBoxStyle}"/>

    <Style x:Key="DevToolsTextInput" TargetType="TextBox" BasedOn="{StaticResource ModernTextBoxStyle}">
        <Setter Property="Background" Value="{DynamicResource DevToolsWindowBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DevToolsBrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontSize" Value="{DynamicResource DevToolsFontSize.Input}"/>
        <Setter Property="MinHeight" Value="38"/>
    </Style>
</ResourceDictionary>
