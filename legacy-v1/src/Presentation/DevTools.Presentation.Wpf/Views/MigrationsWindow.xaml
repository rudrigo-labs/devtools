<Window x:Class="DevTools.Presentation.Wpf.Views.MigrationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        mc:Ignorable="d"
        Title="EF Core Migrations"
        Height="670"
        Width="1080"
        MinWidth="980"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Style="{StaticResource ModernWindowStyle}">

    <c:DevToolsToolFrame x:Name="MainFrame"
                         Title="EF Core Migrations"
                         HelpText="Cria ou aplica migrations para contextos EF Core."
                         PrimaryButtonContent="Executar"
                         SecondaryButtonContent="Fechar"
                         PrimaryButtonClick="Execute_Click"
                         SecondaryButtonClick="Close_Click"
                         CloseButtonClick="Close_Click">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,12,0,0">
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <c:PathSelector x:Name="ProjectSelector"
                                    Grid.Column="0"
                                    Title="Pasta Raiz do Projeto"
                                    IsFolderPicker="True"/>

                    <c:PathSelector x:Name="StartupSelector"
                                    Grid.Column="2"
                                    Title="Arquivo do Startup Project (.csproj)"
                                    IsFolderPicker="False"/>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Acao" Style="{StaticResource DevToolsInputLabel}"/>
                        <ComboBox x:Name="ActionCombo"
                                  SelectionChanged="ActionCombo_SelectionChanged"
                                  SelectedIndex="0"
                                  Style="{StaticResource DevToolsSelectInput}">
                            <ComboBoxItem Content="Add Migration" Tag="Add"/>
                            <ComboBoxItem Content="Update Database" Tag="Update"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Provider" Style="{StaticResource DevToolsInputLabel}"/>
                        <ComboBox x:Name="ProviderCombo"
                                  SelectedIndex="0"
                                  Style="{StaticResource DevToolsSelectInput}">
                            <ComboBoxItem Content="SQL Server" Tag="SqlServer"/>
                            <ComboBoxItem Content="SQLite" Tag="Sqlite"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="MigrationNamePanel" Grid.Column="0">
                        <TextBlock Text="Nome da Migration" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="MigrationNameInput" Style="{StaticResource DevToolsTextInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="DbContext Full Name" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="DbContextInput"
                                 ToolTip="Ex: MyProject.Data.AppDbContext"
                                 Style="{StaticResource DevToolsTextInput}"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox x:Name="DryRunCheck"
                              Grid.Column="0"
                              Content="Dry Run (gerar comando sem executar)"
                              Style="{StaticResource DevToolsCheckBox}"
                              VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Argumentos Adicionais (opcional)" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="AdditionalArgsInput"
                                 Style="{StaticResource DevToolsTextInput}"/>
                        <TextBlock Text="Atalhos comuns (clique para adicionar):"
                                   Style="{StaticResource DevToolsInputLabel}"
                                   Margin="0,10,0,6"/>
                        <WrapPanel>
                            <Button Content="--verbose"
                                    Style="{StaticResource DevToolsBrowseButton}"
                                    MinWidth="0"
                                    MinHeight="30"
                                    Width="Auto"
                                    Padding="10,6"
                                    Margin="0,0,8,8"
                                    Click="AdditionalArgChip_Click"/>
                            <Button Content="--no-build"
                                    Style="{StaticResource DevToolsBrowseButton}"
                                    MinWidth="0"
                                    MinHeight="30"
                                    Width="Auto"
                                    Padding="10,6"
                                    Margin="0,0,8,8"
                                    Click="AdditionalArgChip_Click"/>
                            <Button Content="--no-color"
                                    Style="{StaticResource DevToolsBrowseButton}"
                                    MinWidth="0"
                                    MinHeight="30"
                                    Width="Auto"
                                    Padding="10,6"
                                    Margin="0,0,8,8"
                                    Click="AdditionalArgChip_Click"/>
                            <Button Content="--prefix-output"
                                    Style="{StaticResource DevToolsBrowseButton}"
                                    MinWidth="0"
                                    MinHeight="30"
                                    Width="Auto"
                                    Padding="10,6"
                                    Margin="0,0,8,8"
                                    Click="AdditionalArgChip_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <Expander IsExpanded="True">
                    <Expander.Header>
                        <TextBlock Text="Log de Saida" Style="{StaticResource DevToolsCardTitle}"/>
                    </Expander.Header>
                    <TextBox x:Name="OutputText"
                             Height="120"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource DevToolsTextInput}"/>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </c:DevToolsToolFrame>
</Window>

