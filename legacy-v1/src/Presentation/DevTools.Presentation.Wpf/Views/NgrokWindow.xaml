<Window x:Class="DevTools.Presentation.Wpf.Views.NgrokWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        mc:Ignorable="d"
        Title="Ngrok Local Tunnel"
        Height="670"
        Width="1080"
        MinWidth="980"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Style="{StaticResource ModernWindowStyle}">

    <Window.Resources>
        <sys:Double x:Key="DevToolsContentMaxWidth">1280</sys:Double>
    </Window.Resources>

    <c:DevToolsToolFrame x:Name="MainFrame"
                         Title="Expor Porta com Ngrok"
                         HelpText="Configure o token e inicie tuneis HTTP para sua porta local."
                         StatusText="Ngrok nao configurado."
                         PrimaryButtonContent="Iniciar Tunel"
                         SecondaryButtonContent="Parar Tunel"
                         PrimaryButtonClick="StartButton_Click"
                         SecondaryButtonClick="StopButton_Click"
                         CloseButtonClick="CloseButton_Click">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,12,0,0">
                <Border x:Name="OnboardingPanel"
                            Background="{DynamicResource DevToolsSurface}"
                            BorderBrush="{DynamicResource DevToolsBrushBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16"
                            Margin="0,0,0,12"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Ngrok nao esta configurado."
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource DevToolsTextPrimary}"/>

                            <TextBlock Text="Para usar esta funcionalidade e necessario informar seu Authtoken."
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource DevToolsTextSecondary}"/>

                            <TextBlock Text="Se voce ainda nao tem conta, crie gratuitamente e siga o guia."
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource DevToolsTextSecondary}"/>

                            <Grid Margin="0,12,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="Criar conta"
                                        Click="CreateNgrokAccount_Click"
                                        Style="{StaticResource DevToolsSecondaryButton}"/>

                                <Button Grid.Column="2"
                                        Content="Ver guia"
                                        Click="OpenOnboardingHelp_Click"
                                        Style="{StaticResource DevToolsSecondaryButton}"/>
                            </Grid>

                            <TextBlock Text="Authtoken do ngrok" Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="AuthTokenInput"
                                     Margin="0,0,0,12"
                                     Style="{StaticResource DevToolsTextInput}"/>

                            <Button Content="Salvar configuracao"
                                    HorizontalAlignment="Right"
                                    Click="SaveNgrokToken_Click"
                                    Style="{StaticResource DevToolsPrimaryButton}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="TunnelConfigPanel"
                            Background="{DynamicResource DevToolsSurface}"
                            BorderBrush="{DynamicResource DevToolsBrushBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Tunel HTTP Local"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource DevToolsTextPrimary}"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Porta local" Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="PortInput"
                                     Text="5000"
                                     Width="200"
                                     PreviewTextInput="NumberValidationTextBox"
                                     Style="{StaticResource DevToolsTextInput}"/>

                            <TextBlock Text="Exemplo: 5000 para expor http://localhost:5000"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource DevToolsTextSecondary}"
                                       FontSize="{DynamicResource DevToolsFontSize.Status}"/>
                        </StackPanel>
                    </Border>

                    <Button Content="Matar Processos Ngrok"
                            Margin="0,12,0,0"
                            Click="KillAll_Click"
                            Style="{StaticResource DangerButtonStyle}"/>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Tuneis Ativos"
                               FontSize="{DynamicResource DevToolsFontSize.SectionTitle}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="Atualizar"
                            Click="RefreshButton_Click"
                            HorizontalAlignment="Right"
                            Style="{StaticResource DevToolsSecondaryButton}"/>
                </Grid>

                <Border Grid.Row="1"
                        Background="{DynamicResource DevToolsSurface}"
                        BorderBrush="{DynamicResource DevToolsBrushBorder}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <Grid>
                        <ListBox x:Name="TunnelsList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource DevToolsWindowBackground}"
                                            BorderBrush="{DynamicResource DevToolsBrushBorder}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Margin="0,0,0,8"
                                            Padding="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding PublicUrl}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           FontSize="14"/>
                                                <TextBlock Text="{Binding Proto, StringFormat=Protocolo: {0}}"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Margin="0,4,0,0"/>
                                                <TextBlock Text="{Binding Addr, StringFormat=Destino local: {0}}"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                    Content="Copiar URL"
                                                    Click="CopyUrl_Click"
                                                    Tag="{Binding PublicUrl}"
                                                    Style="{StaticResource DevToolsSecondaryButton}"
                                                    Margin="12,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock x:Name="EmptyStateText"
                                   Text="Nenhum tunel ativo."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </c:DevToolsToolFrame>
</Window>
