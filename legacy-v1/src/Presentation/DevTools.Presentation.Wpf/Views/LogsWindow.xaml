<Window x:Class="DevTools.Presentation.Wpf.Views.LogsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        mc:Ignorable="d"
        Title="Logs do Sistema"
        Height="640"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Style="{StaticResource ModernWindowStyle}">

    <c:DevToolsToolFrame x:Name="MainFrame"
                         Title="Logs do Sistema"
                         HelpText="Consulta e manutencao de logs locais."
                         PrimaryButtonContent="Atualizar"
                         SecondaryButtonContent="Fechar"
                         PrimaryButtonClick="Refresh_Click"
                         SecondaryButtonClick="CloseButton_Click"
                         CloseButtonClick="CloseButton_Click">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,0,0,12">
                <Button Content="Abrir Pasta"
                        Click="OpenFolder_Click"
                        Margin="0,0,12,0"
                        Style="{StaticResource DevToolsSecondaryButton}"/>
                <Button Content="Limpar"
                        Click="Clear_Click"
                        Style="{StaticResource DevToolsSecondaryButton}"/>
            </StackPanel>

            <TextBox x:Name="LogTextBox"
                     Grid.Row="1"
                     Style="{StaticResource DevToolsTextInput}"
                     FontFamily="Consolas"
                     FontSize="12"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"/>
        </Grid>
    </c:DevToolsToolFrame>
</Window>
