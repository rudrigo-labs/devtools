<UserControl x:Class="DevTools.Presentation.Wpf.Components.ActionBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             x:Name="Root">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,0,0,10">

        <Button Style="{StaticResource ActionBarButton}"
                Click="ActionNew_Click"
                IsEnabled="{Binding CanNew, ElementName=Root}"
                Visibility="{Binding ShowNew, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,6,0"/>
                <TextBlock Text="New"/>
            </StackPanel>
        </Button>

        <Button Style="{StaticResource ActionBarButton}"
                Click="ActionSave_Click"
                IsEnabled="{Binding CanSave, ElementName=Root}"
                Visibility="{Binding ShowSave, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16" Margin="0,0,6,0"/>
                <TextBlock Text="Save"/>
            </StackPanel>
        </Button>

        <Button Style="{StaticResource ActionBarButton}"
                Click="ActionDelete_Click"
                IsEnabled="{Binding CanDelete, ElementName=Root}"
                Visibility="{Binding ShowDelete, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" Margin="0,0,6,0"/>
                <TextBlock Text="Delete"/>
            </StackPanel>
        </Button>

        <Button Style="{StaticResource ActionBarButton}"
                Click="ActionCancel_Click"
                IsEnabled="{Binding CanCancel, ElementName=Root}"
                Visibility="{Binding ShowCancel, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Close" Width="16" Height="16" Margin="0,0,6,0"/>
                <TextBlock Text="Cancel"/>
            </StackPanel>
        </Button>

    </StackPanel>
</UserControl>
