<Window x:Class="DevTools.Presentation.Wpf.Views.LogsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DevTools - Logs"
        Height="600" Width="900"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="{StaticResource DevToolsWindowBackground}"
        BorderBrush="{StaticResource DevToolsBorder}"
        BorderThickness="1">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="Transparent" 
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <DockPanel Margin="10,0">
                <Button Content="X" 
                        Width="28"
                        Height="24"
                        DockPanel.Dock="Right"
                        Margin="8,8,0,8"
                        Click="Close_Click"
                        Style="{StaticResource DevToolsSecondaryButton}"/>
                
                <TextBlock Text="Application Logs" 
                           VerticalAlignment="Center" 
                           FontSize="{StaticResource DevToolsFontSize.SectionTitle}"
                           Foreground="{StaticResource DevToolsTextPrimary}"
                           FontWeight="SemiBold"/>
            </DockPanel>
        </Border>

        <!-- Log Content -->
        <TextBox Grid.Row="1" x:Name="LogBox" 
                 Margin="16"
                 IsReadOnly="True" 
                 TextWrapping="Wrap" 
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="12"
                 Background="{StaticResource DevToolsInputBackground}"
                 Foreground="{StaticResource DevToolsTextPrimary}"
                 BorderThickness="0"
                 Padding="8"/>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="{StaticResource DevToolsSurface}" Padding="16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Atualizar" Click="Refresh_Click" Style="{StaticResource DevToolsSecondaryButton}" Margin="0,0,8,0"/>
                <Button Content="Abrir Pasta" Click="OpenFolder_Click" Style="{StaticResource DevToolsSecondaryButton}" Margin="0,0,8,0"/>
                <Button Content="Limpar Logs" Click="Clear_Click" Style="{StaticResource DevToolsDangerButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
