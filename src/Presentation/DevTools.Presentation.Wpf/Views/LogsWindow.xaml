<Window x:Class="DevTools.Presentation.Wpf.Views.LogsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Logs do Sistema" Height="640" Width="900" WindowStartupLocation="CenterScreen"
        Style="{StaticResource ModernWindowStyle}">

    <c:DevToolsToolFrame x:Name="MainFrame"
                         Title="Logs do Sistema"
                         PrimaryButtonContent="Atualizar"
                         SecondaryButtonContent="Fechar"
                         PrimaryButtonClick="Refresh_Click"
                         SecondaryButtonClick="CloseButton_Click"
                         CloseButtonClick="CloseButton_Click">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                <Button Content="Abrir Pasta" Click="OpenFolder_Click" Margin="0,0,10,0" Style="{StaticResource SecondaryButtonStyle}" Padding="10,5" FontSize="12"/>
                <Button Content="Limpar" Click="Clear_Click" Style="{StaticResource SecondaryButtonStyle}" Padding="10,5" FontSize="12"/>
            </StackPanel>

            <!-- Log Content -->
            <TextBox x:Name="LogTextBox" Grid.Row="1"
                     Style="{StaticResource ModernTextBoxStyle}"
                     FontFamily="Consolas" FontSize="12"
                     IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"/>
        </Grid>
    </c:DevToolsToolFrame>
</Window>
