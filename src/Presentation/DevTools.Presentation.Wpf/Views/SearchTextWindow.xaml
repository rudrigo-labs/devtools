<Window x:Class="DevTools.Presentation.Wpf.Views.SearchTextWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        mc:Ignorable="d"
        Title="Buscar Texto em Arquivos"
        Height="670"
        Width="1080"
        MinWidth="980"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Style="{StaticResource ModernWindowStyle}">

    <c:DevToolsToolFrame x:Name="MainFrame"
                         Title="Buscar Texto em Arquivos"
                         HelpText="Busca rapida com regex opcional e filtros."
                         PrimaryButtonContent="Executar"
                         SecondaryButtonContent="Fechar"
                         PrimaryButtonClick="Execute_Click"
                         SecondaryButtonClick="Close_Click"
                         CloseButtonClick="Close_Click">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,12,0,0">
                <c:PathSelector x:Name="PathSelector"
                                Title="Diretorio de Busca"
                                IsFolderPicker="True"
                                Margin="0,0,0,16"/>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Texto para Pesquisar" Style="{StaticResource DevToolsInputLabel}"/>
                    <TextBox x:Name="SearchTextInput" Style="{StaticResource DevToolsTextInput}"/>
                </StackPanel>

                <WrapPanel Margin="0,0,0,16">
                    <CheckBox x:Name="UseRegexCheck"
                              Content="Usar Regex"
                              Style="{StaticResource DevToolsCheckBox}"
                              Margin="0,0,20,8"/>
                    <CheckBox x:Name="CaseSensitiveCheck"
                              Content="Case Sensitive"
                              Style="{StaticResource DevToolsCheckBox}"
                              Margin="0,0,20,8"/>
                </WrapPanel>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Incluir (glob patterns)" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="IncludePatternInput"
                                 ToolTip="Ex: *.cs, *.ts"
                                 Style="{StaticResource DevToolsTextInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Excluir (glob patterns)" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="ExcludePatternInput"
                                 ToolTip="Ex: bin, obj, node_modules"
                                 Style="{StaticResource DevToolsTextInput}"/>
                    </StackPanel>
                </Grid>

                <Expander IsExpanded="True" Margin="0,6,0,0">
                    <Expander.Header>
                        <TextBlock Text="Resultados" Style="{StaticResource DevToolsCardTitle}" Margin="0,0,0,0"/>
                    </Expander.Header>
                    <TextBox x:Name="OutputText"
                             Height="120"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource DevToolsTextInput}"/>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </c:DevToolsToolFrame>
</Window>
