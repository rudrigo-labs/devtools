<Window x:Class="DevTools.Presentation.Wpf.Views.SearchTextWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        Title="DevTools - Search Text"
        Width="800"
        Height="500"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource DevToolsWindowBackground}">
    <Border BorderBrush="{StaticResource DevToolsBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource DevToolsWindowBackground}">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="Header"
                    Grid.Row="0"
                    Background="{StaticResource DevToolsSurface}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel Margin="10,0">
                    <TextBlock Text="Search Text"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource DevToolsFontSize.SectionTitle}"
                               Foreground="{StaticResource DevToolsTextPrimary}"/>
                    <Button Content="X"
                            Width="28"
                            Height="24"
                            DockPanel.Dock="Right"
                            Margin="8,8,0,8"
                            Click="Close_Click"
                            Style="{StaticResource DevToolsSecondaryButton}"/>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="0,12,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <c:ProfileSelector x:Name="ProfileSelector"
                                       ToolName="searchtext"
                                       Margin="0,0,0,12"/>

                    <c:PathSelector x:Name="PathSelector"
                                    Title="Diretório raiz"
                                    Margin="0,0,0,8"/>

                    <TextBox x:Name="SearchTextInput"
                             Style="{StaticResource DevToolsTextInput}"
                             Margin="0,4,0,0"/>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <CheckBox x:Name="UseRegexCheck"
                                  Content="Regex"
                                  Margin="0,0,16,0"
                                  Foreground="{StaticResource DevToolsTextSecondary}"/>
                        <CheckBox x:Name="CaseSensitiveCheck"
                                  Content="Case sensitive"
                                  Foreground="{StaticResource DevToolsTextSecondary}"/>
                    </StackPanel>

                    <TextBlock Text="Include (globs, separado por vírgula ou ponto-e-vírgula)"
                               Margin="0,8,0,4"
                               Foreground="{StaticResource DevToolsTextSecondary}"/>
                    <TextBox x:Name="IncludePatternInput"
                             Style="{StaticResource DevToolsTextInput}"/>

                    <TextBlock Text="Exclude (globs, separado por vírgula ou ponto-e-vírgula)"
                               Margin="0,8,0,4"
                               Foreground="{StaticResource DevToolsTextSecondary}"/>
                    <TextBox x:Name="ExcludePatternInput"
                             Style="{StaticResource DevToolsTextInput}"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,8,0,0"
                        Background="{StaticResource DevToolsSurface}"
                        BorderBrush="{StaticResource DevToolsBorder}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="OutputText"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Hidden"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource DevToolsTextPrimary}"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Executar Busca"
                        Width="140"
                        Click="Execute_Click"
                        Style="{StaticResource DevToolsPrimaryButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
