<Window x:Class="DevTools.Presentation.Wpf.Views.SearchTextWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:components="clr-namespace:DevTools.Presentation.Wpf.Components"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        mc:Ignorable="d"
        Title="Buscar Texto em Arquivos" Height="640" Width="900" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Style="{StaticResource ModernWindowStyle}">

    <c:DevToolsToolFrame x:Name="MainFrame"
                         Title="Buscar Texto em Arquivos"
                         HelpText="Busca rápida com regex opcional e filtros."
                         PrimaryButtonContent="Executar"
                         SecondaryButtonContent="Cancelar"
                         PrimaryButtonClick="Execute_Click"
                         SecondaryButtonClick="Close_Click"
                         CloseButtonClick="Close_Click">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                
                <!-- Caminho -->
                <components:PathSelector x:Name="PathSelector" 
                                     Title="Diretório de Busca"
                                     IsFolderPicker="True"
                                     Margin="0,0,0,15"/>

                <!-- Termo de Busca -->
                <StackPanel Margin="0,10,0,0">
                    <Label Content="Texto para Pesquisar:"/>
                    <TextBox x:Name="SearchTextInput" Style="{StaticResource ModernTextBoxStyle}" />
                </StackPanel>

                <!-- Opções -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <CheckBox x:Name="UseRegexCheck" Content="Usar Regex" Margin="0,0,20,0"/>
                    <CheckBox x:Name="CaseSensitiveCheck" Content="Case Sensitive"/>
                </StackPanel>

                <!-- Filtros -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <Label Content="Incluir (glob patterns)"/>
                        <TextBox x:Name="IncludePatternInput" ToolTip="Ex: *.cs, *.ts" Style="{StaticResource ModernTextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <Label Content="Excluir (glob patterns)"/>
                        <TextBox x:Name="ExcludePatternInput" ToolTip="Ex: bin, obj, node_modules" Style="{StaticResource ModernTextBoxStyle}"/>
                    </StackPanel>
                </Grid>

                <!-- Output Area -->
                <Expander Header="Resultados" IsExpanded="True" BorderBrush="{StaticResource BorderBrush}">
                    <TextBox x:Name="OutputText" 
                             Height="120" 
                             TextWrapping="Wrap" 
                             IsReadOnly="True" 
                             FontFamily="Consolas"
                             FontSize="12"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource ModernTextBoxStyle}"
                             Foreground="{DynamicResource DevToolsTextPrimary}"/>
                </Expander>

            </StackPanel>
        </ScrollViewer>
    </c:DevToolsToolFrame>
</Window>
