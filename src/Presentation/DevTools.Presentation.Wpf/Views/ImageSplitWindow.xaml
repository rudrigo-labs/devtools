<Window x:Class="DevTools.Presentation.Wpf.Views.ImageSplitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        Title="DevTools - Image Split"
        Width="720"
        Height="460"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource DevToolsWindowBackground}">
    <Border BorderBrush="{StaticResource DevToolsBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource DevToolsWindowBackground}">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="Header"
                    Grid.Row="0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel Margin="10,0">
                    <Button Content="X"
                            Width="28"
                            Height="24"
                            DockPanel.Dock="Right"
                            Margin="8,8,0,8"
                            Click="CloseButton_Click"
                            Style="{StaticResource DevToolsSecondaryButton}"/>
                    <TextBlock Text="Image Split"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource DevToolsFontSize.SectionTitle}"
                               Foreground="{StaticResource DevToolsTextPrimary}"/>
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="0,12,0,12">
                <c:PathSelector x:Name="InputPathSelector"
                                Title="Imagem de entrada"
                                IsFolderPicker="False"
                                Margin="0,0,0,12"/>

                <c:PathSelector x:Name="OutputPathSelector"
                                Title="Pasta de saída (opcional)"
                                IsFolderPicker="True"
                                Margin="0,0,0,12"/>

                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Alpha (0-255)" Foreground="{StaticResource DevToolsTextSecondary}"/>
                        <TextBox x:Name="AlphaBox"
                                 Style="{StaticResource DevToolsTextInput}"
                                 PreviewTextInput="NumberValidationTextBox"
                                 Text="10"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Min Tamanho" Foreground="{StaticResource DevToolsTextSecondary}"/>
                        <TextBox x:Name="MinSizeBox"
                                 Style="{StaticResource DevToolsTextInput}"
                                 PreviewTextInput="NumberValidationTextBox"
                                 Text="3"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Bottom">
                        <CheckBox x:Name="OverwriteCheck"
                                  Content="Sobrescrever existentes"
                                  Foreground="{StaticResource DevToolsTextSecondary}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Processar"
                        Width="120"
                        Click="ProcessButton_Click"
                        Style="{StaticResource DevToolsPrimaryButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

