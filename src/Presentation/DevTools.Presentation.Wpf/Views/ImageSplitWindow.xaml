<Window x:Class="DevTools.Presentation.Wpf.Views.ImageSplitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        mc:Ignorable="d"
        Title="Dividir Imagens"
        Height="780"
        Width="1120"
        MinWidth="1020"
        MinHeight="700"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource ModernWindowStyle}"
        ShowInTaskbar="False"
        Topmost="True">

    <c:DevToolsToolFrame x:Name="MainFrame"
                         Title="Dividir Imagens"
                         HelpText="Divide imagens em grade configuravel."
                         PrimaryButtonContent="Processar"
                         SecondaryButtonContent="Fechar"
                         PrimaryButtonClick="ProcessButton_Click"
                         SecondaryButtonClick="CloseButton_Click"
                         CloseButtonClick="CloseButton_Click">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Configuracao"
                           FontSize="{DynamicResource DevToolsFontSize.SectionTitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           Margin="0,0,0,16"/>

                <c:PathSelector x:Name="InputPathSelector"
                                Title="Imagem de Entrada"
                                IsFolderPicker="False"
                                Margin="0,0,0,16"/>

                <c:PathSelector x:Name="OutputPathSelector"
                                Title="Pasta de Saida (Opcional - padrao: mesma da entrada)"
                                IsFolderPicker="True"
                                Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Limiar Alpha (0-255)" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="AlphaBox"
                                 Text="10"
                                 PreviewTextInput="NumberValidationTextBox"
                                 Style="{StaticResource DevToolsTextInput}"/>
                        <TextBlock Text="Transparencia minima para considerar fundo."
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="{DynamicResource DevToolsFontSize.Status}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Tamanho Minimo (px)" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="MinSizeBox"
                                 Text="3"
                                 PreviewTextInput="NumberValidationTextBox"
                                 Style="{StaticResource DevToolsTextInput}"/>
                        <TextBlock Text="Largura e altura minimas para recorte."
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="{DynamicResource DevToolsFontSize.Status}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="OverwriteCheck"
                          Content="Sobrescrever arquivos existentes"
                          Style="{StaticResource DevToolsCheckBox}"/>
            </StackPanel>
        </ScrollViewer>
    </c:DevToolsToolFrame>
</Window>

