<Window x:Class="DevTools.Presentation.Wpf.Views.RenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        Title="Renomear Projeto .NET" Height="640" Width="900" WindowStartupLocation="CenterScreen"
        Style="{StaticResource ModernWindowStyle}"
        ShowInTaskbar="True"
        Topmost="True">

    <Window.Resources>
        <!-- Styles removed to use global theme -->
    </Window.Resources>

    <c:DevToolsToolFrame Title="Renomear Projeto .NET"
                         HelpText="Renomeia projeto/solution e namespaces C# com opções de backup."
                         PrimaryButtonContent="Renomear"
                         SecondaryButtonContent="Cancelar"
                         PrimaryButtonClick="ProcessButton_Click"
                         SecondaryButtonClick="CloseButton_Click">
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
        <StackPanel Margin="0,10,0,0">
            
                <c:PathSelector x:Name="RootPathSelector" Title="Pasta Raiz" IsFolderPicker="True" />

                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <Label Content="Texto Antigo:"/>
                        <TextBox x:Name="OldTextBox" Style="{StaticResource ModernTextBoxStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <Label Content="Texto Novo:"/>
                        <TextBox x:Name="NewTextBox" Style="{StaticResource ModernTextBoxStyle}"/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,15,0,0">
                    <Label Content="Modo de Renomeação:"/>
                    <ComboBox x:Name="ModeCombo" SelectedIndex="0" Style="{StaticResource ModernComboBoxStyle}">
                        <ComboBoxItem Content="Geral (Texto Simples)"/>
                        <ComboBoxItem Content="Namespace C# (Inteligente)"/>
                    </ComboBox>
                </StackPanel>
                
                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <Label Content="Include (Glob):"/>
                        <TextBox x:Name="IncludeBox" Style="{StaticResource ModernTextBoxStyle}" ToolTip="Ex: *.cs, **/*.txt"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <Label Content="Exclude (Glob):"/>
                        <TextBox x:Name="ExcludeBox" Style="{StaticResource ModernTextBoxStyle}" ToolTip="Ex: obj/*, bin/*"/>
                    </StackPanel>
                </Grid>
                
                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <CheckBox x:Name="BackupCheck" Content="Criar Backup" IsChecked="True" Margin="0,0,15,0"/>
                    <CheckBox x:Name="UndoLogCheck" Content="Log de Reversão" IsChecked="True"/>
                    <CheckBox x:Name="DryRunCheck" Content="Dry Run (Teste)" IsChecked="False" Margin="15,0,0,0"/>
                    <CheckBox x:Name="RememberSettingsCheck" Content="Lembrar" IsChecked="False" Margin="15,0,0,0"/>
                </StackPanel>
                
                <c:RunSummaryControl x:Name="RunSummary" Margin="0,15,0,0"/>
        </StackPanel>
        </ScrollViewer>
    </c:DevToolsToolFrame>
</Window>