<Window x:Class="DevTools.Presentation.Wpf.Views.RenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        Title="Renomear Projeto .NET"
        Height="780"
        Width="1120"
        MinWidth="1020"
        MinHeight="700"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource ModernWindowStyle}"
        ShowInTaskbar="False"
        Topmost="True">

    <c:DevToolsToolFrame x:Name="MainFrame"
                         Title="Renomear Projeto .NET"
                         HelpText="Renomeia projeto e namespaces com opcoes de seguranca."
                         PrimaryButtonContent="Renomear"
                         SecondaryButtonContent="Fechar"
                         PrimaryButtonClick="ProcessButton_Click"
                         SecondaryButtonClick="CloseButton_Click">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Configuracao"
                           FontSize="{DynamicResource DevToolsFontSize.SectionTitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           Margin="0,0,0,16"/>

                <c:PathSelector x:Name="RootPathSelector"
                                Title="Pasta Raiz"
                                IsFolderPicker="True"
                                Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Texto Antigo" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="OldTextBox" Style="{StaticResource DevToolsTextInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Texto Novo" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="NewTextBox" Style="{StaticResource DevToolsTextInput}"/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Modo de Renomeacao" Style="{StaticResource DevToolsInputLabel}"/>
                    <ComboBox x:Name="ModeCombo" SelectedIndex="0" Style="{StaticResource DevToolsSelectInput}">
                        <ComboBoxItem Content="Geral (Texto Simples)"/>
                        <ComboBoxItem Content="Namespace C# (Inteligente)"/>
                    </ComboBox>
                </StackPanel>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Include (Glob)" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="IncludeBox"
                                 Style="{StaticResource DevToolsTextInput}"
                                 ToolTip="Ex: *.cs, **/*.txt"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Exclude (Glob)" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="ExcludeBox"
                                 Style="{StaticResource DevToolsTextInput}"
                                 ToolTip="Ex: obj/*, bin/*"/>
                    </StackPanel>
                </Grid>

                <WrapPanel Margin="0,0,0,16">
                    <CheckBox x:Name="BackupCheck"
                              Content="Criar Backup"
                              IsChecked="True"
                              Style="{StaticResource DevToolsCheckBox}"
                              Margin="0,0,16,8"/>
                    <CheckBox x:Name="UndoLogCheck"
                              Content="Log de Reversao"
                              IsChecked="True"
                              Style="{StaticResource DevToolsCheckBox}"
                              Margin="0,0,16,8"/>
                    <CheckBox x:Name="DryRunCheck"
                              Content="Dry Run (Teste)"
                              IsChecked="False"
                              Style="{StaticResource DevToolsCheckBox}"
                              Margin="0,0,16,8"/>
                    <CheckBox x:Name="RememberSettingsCheck"
                              Content="Lembrar"
                              IsChecked="False"
                              Style="{StaticResource DevToolsCheckBox}"
                              Margin="0,0,16,8"/>
                </WrapPanel>

                <c:RunSummaryControl x:Name="RunSummary"/>
            </StackPanel>
        </ScrollViewer>
    </c:DevToolsToolFrame>
</Window>

