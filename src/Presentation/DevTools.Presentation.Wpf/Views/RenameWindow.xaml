<Window x:Class="DevTools.Presentation.Wpf.Views.RenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        Title="DevTools - Rename"
        Width="720"
        Height="460"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource DevToolsWindowBackground}">
    <Border BorderBrush="{StaticResource DevToolsBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource DevToolsWindowBackground}">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="Header"
                    Grid.Row="0"
                    Background="{StaticResource DevToolsSurface}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel Margin="10,0">
                    <TextBlock Text="Rename"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource DevToolsFontSize.SectionTitle}"
                               Foreground="{StaticResource DevToolsTextPrimary}"/>
                    <Button Content="X"
                            Width="28"
                            Height="24"
                            DockPanel.Dock="Right"
                            Margin="8,8,0,8"
                            Click="CloseButton_Click"
                            Style="{StaticResource DevToolsSecondaryButton}"/>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="0,12,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <c:ProfileSelector x:Name="ProfileSelector"
                                       ToolName="rename"
                                       Margin="0,0,0,12"/>

                    <c:PathSelector x:Name="RootPathSelector"
                                       Title="Pasta raiz"
                                       Margin="0,0,0,12"/>

                    <TextBlock Text="Texto antigo"
                               Margin="0,12,0,4"
                               Foreground="{StaticResource DevToolsTextSecondary}"/>
                    <TextBox x:Name="OldTextBox"
                             Style="{StaticResource DevToolsTextInput}"/>

                    <TextBlock Text="Texto novo"
                               Margin="0,12,0,4"
                               Foreground="{StaticResource DevToolsTextSecondary}"/>
                    <TextBox x:Name="NewTextBox"
                             Style="{StaticResource DevToolsTextInput}"/>

                    <TextBlock Text="Modo"
                               Margin="0,12,0,4"
                               Foreground="{StaticResource DevToolsTextSecondary}"/>
                    <ComboBox x:Name="ModeCombo"
                              Style="{StaticResource DevToolsSelectInput}">
                        <ComboBoxItem Content="Geral"/>
                        <ComboBoxItem Content="Namespace/C#"/>
                    </ComboBox>

                    <TextBlock Text="Include (globs, separado por vírgula)"
                               Margin="0,12,0,4"
                               Foreground="{StaticResource DevToolsTextSecondary}"/>
                    <TextBox x:Name="IncludeBox"
                             Style="{StaticResource DevToolsTextInput}"/>

                    <TextBlock Text="Exclude (globs, separado por vírgula)"
                               Margin="0,12,0,4"
                               Foreground="{StaticResource DevToolsTextSecondary}"/>
                    <TextBox x:Name="ExcludeBox"
                             Style="{StaticResource DevToolsTextInput}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <CheckBox x:Name="DryRunCheck"
                                  Content="Dry-run"
                                  Margin="0,0,16,0"
                                  Foreground="{StaticResource DevToolsTextSecondary}"/>
                        <CheckBox x:Name="BackupCheck"
                                  Content="Criar backup"
                                  Margin="0,0,16,0"
                                  Foreground="{StaticResource DevToolsTextSecondary}"/>
                        <CheckBox x:Name="UndoLogCheck"
                                  Content="Gerar undo log"
                                  Foreground="{StaticResource DevToolsTextSecondary}"/>
                    </StackPanel>

                    <CheckBox x:Name="RememberSettingsCheck"
                              Content="Lembrar parâmetros desta execução"
                              Margin="0,8,0,0"
                              Foreground="{StaticResource DevToolsTextSecondary}"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{StaticResource DevToolsSurface}"
                        BorderBrush="{StaticResource DevToolsBorder}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10">
                    <c:RunSummaryControl x:Name="RunSummary"/>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Executar Rename"
                        Width="160"
                        Click="ProcessButton_Click"
                        Style="{StaticResource DevToolsPrimaryButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

