<Window x:Class="DevTools.Presentation.Wpf.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DevTools Dashboard"
        Width="1100"
        Height="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style TargetType="TabControl">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel x:Name="HeaderPanel" Grid.Row="0" Panel.ZIndex="1" Margin="0,0,4,-1" IsItemsHost="True" Background="Transparent"/>
                            <Border x:Name="Border" Grid.Row="1" BorderThickness="0" Background="{TemplateBinding Background}" KeyboardNavigation.TabNavigation="Local" KeyboardNavigation.DirectionalNavigation="Contained">
                                <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent" Margin="{TemplateBinding Padding}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border x:Name="Border" Margin="0,0,4,0" Background="Transparent" BorderBrush="{StaticResource DevToolsBorder}" BorderThickness="0,0,0,3" Padding="12,8">
                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" RecognizesAccessKey="True"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource DevToolsAccent}"/>
                                <Setter Property="Foreground" Value="{StaticResource DevToolsAccent}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="Border" Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource DevToolsTextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource DevToolsTextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="{StaticResource DevToolsWindowBackground}" CornerRadius="8" BorderBrush="{StaticResource DevToolsBorder}" BorderThickness="1">
        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left navigation -->
        <Border Grid.Column="0"
                Background="{StaticResource DevToolsSurface}"
                BorderBrush="{StaticResource DevToolsBorder}"
                BorderThickness="0,0,1,0"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <DockPanel LastChildFill="True" Margin="0,20,0,20">
                <StackPanel DockPanel.Dock="Top" Margin="20,0,20,40">
                    <TextBlock FontSize="{StaticResource DevToolsFontSize.WindowTitle}">
                        <Run Text="DevTools"
                             Foreground="{StaticResource DevToolsTextPrimary}"
                             FontWeight="SemiBold"/><Run Text=" "/>
                        <Run Text="Dashboard"
                             Foreground="{StaticResource DevToolsTextSecondary}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="20,0,20,0">
                    <Button Content="Ferramentas"
                            Tag="Tools"
                            Click="NavButton_Click"
                            Style="{StaticResource DevToolsSecondaryButton}"
                            Margin="0,0,0,10"/>
                    <Button Content="Jobs"
                            Tag="Jobs"
                            Click="NavButton_Click"
                            Style="{StaticResource DevToolsSecondaryButton}"
                            Margin="0,0,0,10"/>
                    <Button Content="Configurações"
                            Tag="Settings"
                            Click="NavButton_Click"
                            Style="{StaticResource DevToolsSecondaryButton}"
                            Margin="0,0,0,10"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="20,0,20,0">
                    <Button Content="Fechar"
                            Click="CloseButton_Click"
                            Style="{StaticResource DevToolsSecondaryButton}"
                            Margin="0,0,0,10"/>
                    <Button Content="Encerrar"
                            Click="Shutdown_Click"
                            Style="{StaticResource DangerButtonStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1"
              Background="{StaticResource DevToolsWindowBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource DevToolsSurface}"
                    BorderBrush="{StaticResource DevToolsBorder}"
                    BorderThickness="0,0,0,1"
                    Padding="20,14"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel LastChildFill="False">
                    <TextBlock Text="Painel principal"
                               FontSize="{StaticResource DevToolsFontSize.SectionTitle}"
                               Foreground="{StaticResource DevToolsTextPrimary}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               DockPanel.Dock="Left"/>
                    
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                        <Button ToolTip="Minimizar para bandeja"
                                Click="CloseButton_Click"
                                Style="{StaticResource IconButtonStyle}"
                                Margin="0,0,8,0">
                            <Path Data="{StaticResource Icon.WindowMinimize}" Fill="{StaticResource SecondaryTextBrush}" Stretch="Uniform" Width="10" Height="10"/>
                        </Button>
                        <Button ToolTip="Encerrar aplicação"
                                Click="Shutdown_Click"
                                Style="{StaticResource IconButtonStyle}">
                            <Path Data="{StaticResource Icon.WindowClose}" Fill="{StaticResource SecondaryTextBrush}" Stretch="Uniform" Width="10" Height="10"/>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <TabControl x:Name="MainTabControl"
                        Grid.Row="1"
                        Background="{StaticResource DevToolsWindowBackground}">
                <!-- Tools tab -->
                <TabItem x:Name="TabTools" Header="Ferramentas">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="20">
                        <UniformGrid Columns="3" Margin="0,10,0,0">
                            <Button Margin="10"
                                    Tag="Notes"
                                    Click="OpenTool_Click"
                                    Style="{StaticResource DevToolsSecondaryButton}"
                                    HorizontalContentAlignment="Stretch">
                                <DockPanel Margin="4">
                                    <Border Width="4" Background="{StaticResource DevToolsAccent}" CornerRadius="2" Margin="0,2,8,2" DockPanel.Dock="Left"/>
                                    <Path Style="{StaticResource IconPathStyle}" Data="{StaticResource Icon.Notes}" DockPanel.Dock="Left"/>
                                    <StackPanel>
                                        <TextBlock Text="Notes"
                                                   FontSize="{StaticResource DevToolsFontSize.Label}"
                                                   Foreground="{StaticResource DevToolsTextPrimary}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Notas locais rápidas em Markdown."
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource DevToolsTextSecondary}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                            <Button Margin="10"
                                    Tag="Harvest"
                                    Click="OpenTool_Click"
                                    Style="{StaticResource DevToolsSecondaryButton}"
                                    HorizontalContentAlignment="Stretch">
                                <DockPanel Margin="4">
                                    <Border Width="4" Background="{StaticResource DevToolsAccent}" CornerRadius="2" Margin="0,2,8,2" DockPanel.Dock="Left"/>
                                    <Path Style="{StaticResource IconPathStyle}" Data="{StaticResource Icon.Harvest}" DockPanel.Dock="Left"/>
                                    <StackPanel>
                                        <TextBlock Text="Harvest"
                                                   FontSize="{StaticResource DevToolsFontSize.Label}"
                                                   Foreground="{StaticResource DevToolsTextPrimary}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Colhe arquivos de código para análise e backup."
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource DevToolsTextSecondary}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                            <Button Margin="10"
                                    Tag="Organizer"
                                    Click="OpenTool_Click"
                                    Style="{StaticResource DevToolsSecondaryButton}"
                                    HorizontalContentAlignment="Stretch">
                                <DockPanel Margin="4">
                                    <Border Width="4" Background="{StaticResource DevToolsAccent}" CornerRadius="2" Margin="0,2,8,2" DockPanel.Dock="Left"/>
                                    <Path Style="{StaticResource IconPathStyle}" Data="{StaticResource Icon.Organizer}" DockPanel.Dock="Left"/>
                                    <StackPanel>
                                        <TextBlock Text="Organizer"
                                                   FontSize="{StaticResource DevToolsFontSize.Label}"
                                                   Foreground="{StaticResource DevToolsTextPrimary}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Organiza arquivos da Inbox em pastas por regras."
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource DevToolsTextSecondary}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                            <Button Margin="10"
                                    Tag="Rename"
                                    Click="OpenTool_Click"
                                    Style="{StaticResource DevToolsSecondaryButton}"
                                    HorizontalContentAlignment="Stretch">
                                <DockPanel Margin="4">
                                    <Border Width="4" Background="{StaticResource DevToolsAccent}" CornerRadius="2" Margin="0,2,8,2" DockPanel.Dock="Left"/>
                                    <Path Style="{StaticResource IconPathStyle}" Data="{StaticResource Icon.Rename}" DockPanel.Dock="Left"/>
                                    <StackPanel>
                                        <TextBlock Text="Rename"
                                                   FontSize="{StaticResource DevToolsFontSize.Label}"
                                                   Foreground="{StaticResource DevToolsTextPrimary}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Renomeação em massa com padrões simples ou Regex."
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource DevToolsTextSecondary}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                            <Button Margin="10"
                                    Tag="SearchText"
                                    Click="OpenTool_Click"
                                    Style="{StaticResource DevToolsSecondaryButton}">
                                <DockPanel Margin="4">
                                    <Border Width="4" Background="{StaticResource DevToolsAccent}" CornerRadius="2" Margin="0,2,8,2" DockPanel.Dock="Left"/>
                                    <StackPanel>
                                        <TextBlock Text="Search Text"
                                                   FontSize="{StaticResource DevToolsFontSize.Label}"
                                                   Foreground="{StaticResource DevToolsTextPrimary}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Busca textual em arquivos, com suporte a Regex."
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource DevToolsTextSecondary}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                            <Button Margin="10"
                                    Tag="Snapshot"
                                    Click="OpenTool_Click"
                                    Style="{StaticResource DevToolsSecondaryButton}"
                                    HorizontalContentAlignment="Stretch">
                                <DockPanel Margin="4">
                                    <Border Width="4" Background="{StaticResource DevToolsAccent}" CornerRadius="2" Margin="0,2,8,2" DockPanel.Dock="Left"/>
                                    <Path Style="{StaticResource IconPathStyle}" Data="{StaticResource Icon.Snapshot}" DockPanel.Dock="Left"/>
                                    <StackPanel>
                                        <TextBlock Text="Snapshot"
                                                   FontSize="{StaticResource DevToolsFontSize.Label}"
                                                   Foreground="{StaticResource DevToolsTextPrimary}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Gera snapshot da estrutura de diretórios."
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource DevToolsTextSecondary}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                            <Button Margin="10"
                                    Tag="Utf8Convert"
                                    Click="OpenTool_Click"
                                    Style="{StaticResource DevToolsSecondaryButton}"
                                    HorizontalContentAlignment="Stretch">
                                <DockPanel Margin="4">
                                    <Border Width="4" Background="{StaticResource DevToolsAccent}" CornerRadius="2" Margin="0,2,8,2" DockPanel.Dock="Left"/>
                                    <Path Style="{StaticResource IconPathStyle}" Data="{StaticResource Icon.Utf8Convert}" DockPanel.Dock="Left"/>
                                    <StackPanel>
                                        <TextBlock Text="UTF-8 Convert"
                                                   FontSize="{StaticResource DevToolsFontSize.Label}"
                                                   Foreground="{StaticResource DevToolsTextPrimary}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Converte arquivos de texto para encoding UTF-8."
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource DevToolsTextSecondary}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                            <Button Margin="10"
                                    Tag="ImageSplitter"
                                    Click="OpenTool_Click"
                                    Style="{StaticResource DevToolsSecondaryButton}"
                                    HorizontalContentAlignment="Stretch">
                                <DockPanel Margin="4">
                                    <Border Width="4" Background="{StaticResource DevToolsAccent}" CornerRadius="2" Margin="0,2,8,2" DockPanel.Dock="Left"/>
                                    <Path Style="{StaticResource IconPathStyle}" Data="{StaticResource Icon.ImageSplitter}" DockPanel.Dock="Left"/>
                                    <StackPanel>
                                        <TextBlock Text="Image Splitter"
                                                   FontSize="{StaticResource DevToolsFontSize.Label}"
                                                   Foreground="{StaticResource DevToolsTextPrimary}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Divide imagens grandes em partes menores."
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource DevToolsTextSecondary}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                            <Button Margin="10"
                                    Tag="SSHTunnel"
                                    Click="OpenTool_Click"
                                    Style="{StaticResource DevToolsSecondaryButton}"
                                    HorizontalContentAlignment="Stretch">
                                <DockPanel Margin="4">
                                    <Border Width="4" Background="{StaticResource DevToolsAccent}" CornerRadius="2" Margin="0,2,8,2" DockPanel.Dock="Left"/>
                                    <Path Style="{StaticResource IconPathStyle}" Data="{StaticResource Icon.SSHTunnel}" DockPanel.Dock="Left"/>
                                    <StackPanel>
                                        <TextBlock Text="SSH Tunnel"
                                                   FontSize="{StaticResource DevToolsFontSize.Label}"
                                                   Foreground="{StaticResource DevToolsTextPrimary}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Gerencia túneis SSH para bancos e serviços internos."
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource DevToolsTextSecondary}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                            <Button Margin="10"
                                    Tag="Ngrok"
                                    Click="OpenTool_Click"
                                    Style="{StaticResource DevToolsSecondaryButton}">
                                <DockPanel Margin="4">
                                    <Border Width="4" Background="{StaticResource DevToolsAccent}" CornerRadius="2" Margin="0,2,8,2" DockPanel.Dock="Left"/>
                                    <StackPanel>
                                        <TextBlock Text="Ngrok"
                                                   FontSize="{StaticResource DevToolsFontSize.Label}"
                                                   Foreground="{StaticResource DevToolsTextPrimary}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Abre túneis Ngrok para portas locais."
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource DevToolsTextSecondary}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                            <Button Margin="10"
                                    Tag="Migrations"
                                    Click="OpenTool_Click"
                                    Style="{StaticResource DevToolsSecondaryButton}"
                                    HorizontalContentAlignment="Stretch">
                                <DockPanel Margin="4">
                                    <Border Width="4" Background="{StaticResource DevToolsAccent}" CornerRadius="2" Margin="0,2,8,2" DockPanel.Dock="Left"/>
                                    <Path Style="{StaticResource IconPathStyle}" Data="{StaticResource Icon.Migrations}" DockPanel.Dock="Left"/>
                                    <StackPanel>
                                        <TextBlock Text="Migrations"
                                                   FontSize="{StaticResource DevToolsFontSize.Label}"
                                                   Foreground="{StaticResource DevToolsTextPrimary}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Auxilia na execução de comandos EF Core migrations."
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource DevToolsTextSecondary}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                            <Button Margin="10"
                                    Tag="Jobs"
                                    Click="OpenTool_Click"
                                    Style="{StaticResource DevToolsSecondaryButton}"
                                    HorizontalContentAlignment="Stretch">
                                <DockPanel Margin="4">
                                    <Border Width="4" Background="{StaticResource DevToolsAccent}" CornerRadius="2" Margin="0,2,8,2" DockPanel.Dock="Left"/>
                                    <Path Style="{StaticResource IconPathStyle}" Data="{StaticResource Icon.Jobs}" DockPanel.Dock="Left"/>
                                    <StackPanel>
                                        <TextBlock Text="Jobs Center"
                                                   FontSize="{StaticResource DevToolsFontSize.Label}"
                                                   Foreground="{StaticResource DevToolsTextPrimary}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Atalho para o centro de jobs e histórico."
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource DevToolsTextSecondary}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                            <Button Margin="10"
                                    Tag="Logs"
                                    Click="OpenTool_Click"
                                    Style="{StaticResource DevToolsSecondaryButton}"
                                    HorizontalContentAlignment="Stretch">
                                <DockPanel Margin="4">
                                    <Border Width="4" Background="{StaticResource DevToolsAccent}" CornerRadius="2" Margin="0,2,8,2" DockPanel.Dock="Left"/>
                                    <Path Style="{StaticResource IconPathStyle}" Data="{StaticResource Icon.Logs}" DockPanel.Dock="Left"/>
                                    <StackPanel>
                                        <TextBlock Text="Logs"
                                                   FontSize="{StaticResource DevToolsFontSize.Label}"
                                                   Foreground="{StaticResource DevToolsTextPrimary}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Visualização rápida de logs do DevTools."
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource DevToolsTextSecondary}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Button>
                        </UniformGrid>
                    </ScrollViewer>
                </TabItem>

                <!-- Jobs tab -->
                <TabItem x:Name="TabJobs" Header="Jobs">
                    <Grid Background="{StaticResource DevToolsWindowBackground}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="Jobs em execução / históricos"
                                   FontSize="{StaticResource DevToolsFontSize.SectionTitle}"
                                   Foreground="{StaticResource DevToolsTextPrimary}"
                                   Margin="20,20,20,10"/>
                        <DataGrid x:Name="JobsDataGrid"
                                  Grid.Row="1"
                                  Margin="20"
                                  AutoGenerateColumns="True"
                                  IsReadOnly="True"
                                  Background="{StaticResource DevToolsSurface}"
                                  Foreground="{StaticResource DevToolsTextPrimary}"/>
                    </Grid>
                </TabItem>

                <!-- Settings tab -->
                <TabItem x:Name="TabSettings" Header="Configurações">
                    <Grid Background="{StaticResource DevToolsWindowBackground}">
                        <TextBlock Text="Configurações globais serão reimplementadas nesta tela."
                                   FontSize="{StaticResource DevToolsFontSize.Label}"
                                   Foreground="{StaticResource DevToolsTextSecondary}"
                                   Margin="20"/>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
    </Border>
</Window>
