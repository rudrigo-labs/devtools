<Window x:Class="DevTools.Presentation.Wpf.Views.OrganizerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        mc:Ignorable="d"
        Title="Organizador de Arquivos"
        Height="670"
        Width="1080"
        MinWidth="980"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Style="{StaticResource ModernWindowStyle}">

    <c:DevToolsToolFrame x:Name="MainFrame"
                         Title="Organizador de Arquivos"
                         HelpText="Move e organiza arquivos por regras de categoria."
                         PrimaryButtonContent="Organizar"
                         SecondaryButtonContent="Fechar"
                         PrimaryButtonClick="RunButton_Click"
                         SecondaryButtonClick="CloseButton_Click"
                         CloseButtonClick="CloseButton_Click">
        <StackPanel Margin="0,12,0,0">
                <c:PathSelector x:Name="InputPathSelector"
                            Title="Pasta de Entrada"
                            IsFolderPicker="True"
                            Margin="0,0,0,16"/>

            <c:PathSelector x:Name="OutputPathSelector"
                            Title="Pasta de Saida (Opcional)"
                            IsFolderPicker="True"
                            Margin="0,0,0,16"/>

            <CheckBox x:Name="SimulateCheck"
                      Content="Simular (nao move arquivos)"
                      IsChecked="False"
                      Style="{StaticResource DevToolsCheckBox}"
                      Margin="0,0,0,16"/>

            <TextBlock Text="Se a pasta de saida estiver vazia, a ferramenta organiza na mesma pasta de entrada."
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontSize="{DynamicResource DevToolsFontSize.Status}"/>
        </StackPanel>
    </c:DevToolsToolFrame>
</Window>

