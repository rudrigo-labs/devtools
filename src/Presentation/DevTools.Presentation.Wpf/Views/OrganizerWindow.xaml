<Window x:Class="DevTools.Presentation.Wpf.Views.OrganizerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        mc:Ignorable="d"
        Title="Organizador de Arquivos" Height="640" Width="900" WindowStartupLocation="CenterScreen"
        Style="{StaticResource ModernWindowStyle}">
    
    <c:DevToolsToolFrame Title="Organizador de Arquivos"
                         HelpText="Move/organiza por extensão/data conforme categorias"
                         PrimaryButtonContent="Organizar"
                         SecondaryButtonContent="Cancelar"
                         PrimaryButtonClick="RunButton_Click"
                         SecondaryButtonClick="CloseButton_Click"
                         CloseButtonClick="CloseButton_Click">
        <StackPanel Margin="0,20,0,0">
            <TextBlock Text="Configuração" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,15"/>
            
            <c:PathSelector x:Name="InputPathSelector" Title="Pasta de Entrada (Arquivos Bagunçados)" 
                            IsFolderPicker="True" Margin="0,0,0,20"/>
            
            <c:PathSelector x:Name="OutputPathSelector" Title="Pasta de Saída (Opcional - Padrão: Mesma da Entrada)" 
            IsFolderPicker="True" Margin="0,0,0,20"/>

            <CheckBox x:Name="SimulateCheck" Content="Simular (Apenas Teste - Não move arquivos)" 
                      Foreground="{StaticResource PrimaryTextBrush}"
                      FontSize="14"
                      IsChecked="False"
                      VerticalContentAlignment="Center"
                      Margin="0,5,0,0"/>
        </StackPanel>
    </c:DevToolsToolFrame>
</Window>
