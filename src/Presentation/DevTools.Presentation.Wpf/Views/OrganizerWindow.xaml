<Window x:Class="DevTools.Presentation.Wpf.Views.OrganizerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        Title="DevTools - Organizer"
        Width="640"
        SizeToContent="Height"
        MinHeight="400"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource DevToolsWindowBackground}">
    <Border BorderBrush="{StaticResource DevToolsBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource DevToolsWindowBackground}">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="Header"
                    Grid.Row="0"
                    Background="{StaticResource DevToolsSurface}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel Margin="10,0">
                    <TextBlock Text="Organizer"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource DevToolsFontSize.SectionTitle}"
                               Foreground="{StaticResource DevToolsTextPrimary}"/>
                    <Button Content="X"
                            Width="28"
                            Height="24"
                            DockPanel.Dock="Right"
                            Margin="8,8,0,8"
                            Click="CloseButton_Click"
                            Style="{StaticResource DevToolsSecondaryButton}"/>
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="1"
                        Margin="0,12,0,12">
                <!-- ProfileSelector Removed -->

                <c:PathSelector x:Name="InputPathSelector"
                                Title="Inbox (pasta de entrada)"
                                Margin="0,0,0,8"/>

                <c:PathSelector x:Name="OutputPathSelector"
                                Title="Pasta de saída (opcional)"
                                Margin="0,8,0,0"/>

                <CheckBox x:Name="SimulateCheck"
                          Content="Simular apenas (não mover arquivos)"
                          Margin="0,12,0,0"
                          Foreground="{StaticResource DevToolsTextSecondary}"/>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancelar"
                        Width="100"
                        Margin="0,0,10,0"
                        Click="CloseButton_Click"
                        Style="{StaticResource DevToolsSecondaryButton}"/>
                <Button Content="Organizar"
                        Width="140"
                        Click="RunButton_Click"
                        Style="{StaticResource DevToolsPrimaryButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>