<Window x:Class="DevTools.Presentation.Wpf.Views.Utf8ConvertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        Title="Converter para UTF-8"
        Height="670"
        Width="1080"
        MinWidth="980"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource ModernWindowStyle}"
        ShowInTaskbar="False"
        Topmost="True">

    <c:DevToolsToolFrame x:Name="MainFrame"
                         Title="Converter para UTF-8"
                         HelpText="Converte arquivos para UTF-8 preservando conteudo."
                         PrimaryButtonContent="Converter"
                         SecondaryButtonContent="Fechar"
                         PrimaryButtonClick="ProcessButton_Click"
                         SecondaryButtonClick="CloseButton_Click"
                         CloseButtonClick="CloseButton_Click">
        <StackPanel Margin="0,12,0,0">
                <c:PathSelector x:Name="RootPathSelector"
                            Title="Pasta Raiz"
                            IsFolderPicker="True"
                            Margin="0,0,0,16"/>

            <WrapPanel>
                <CheckBox x:Name="RecursiveCheck"
                          Content="Recursivo"
                          IsChecked="True"
                          Style="{StaticResource DevToolsCheckBox}"
                          Margin="0,0,16,8"/>
                <CheckBox x:Name="DryRunCheck"
                          Content="Dry Run (somente análise)"
                          IsChecked="False"
                          Style="{StaticResource DevToolsCheckBox}"
                          Margin="0,0,16,8"/>
                <CheckBox x:Name="BackupCheck"
                          Content="Criar backup"
                          IsChecked="True"
                          Style="{StaticResource DevToolsCheckBox}"
                          Margin="0,0,16,8"/>
                <CheckBox x:Name="BomCheck"
                          Content="Adicionar BOM"
                          IsChecked="True"
                          Style="{StaticResource DevToolsCheckBox}"
                          Margin="0,0,16,8"/>
            </WrapPanel>

            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Include (Glob) (Opcional)" Style="{StaticResource DevToolsInputLabel}"/>
                    <TextBox x:Name="IncludeGlobsInput"
                             Style="{StaticResource DevToolsTextInput}"
                             ToolTip="Ex: **/*.cs, **/*.json"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Exclude (Glob) (Opcional)" Style="{StaticResource DevToolsInputLabel}"/>
                    <TextBox x:Name="ExcludeGlobsInput"
                             Style="{StaticResource DevToolsTextInput}"
                             ToolTip="Ex: **/bin/**, **/obj/**"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </c:DevToolsToolFrame>
</Window>

