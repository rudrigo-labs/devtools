<Window x:Class="DevTools.Presentation.Wpf.Views.Utf8ConvertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        Title="Converter para UTF‑8" Height="640" Width="900" WindowStartupLocation="CenterScreen"
        Style="{StaticResource ModernWindowStyle}"
        ShowInTaskbar="True"
        Topmost="True">

    <c:DevToolsToolFrame Title="Converter para UTF‑8"
                         HelpText="Converte arquivos para UTF‑8 preservando conteúdo."
                         PrimaryButtonContent="Converter"
                         SecondaryButtonContent="Cancelar"
                         PrimaryButtonClick="ProcessButton_Click"
                         SecondaryButtonClick="CloseButton_Click">
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
        <StackPanel Margin="0,10,0,0">
            
            <Label Content="Pasta Raiz:"/>
                <c:PathSelector x:Name="RootPathSelector" Title="Pasta Raiz" IsFolderPicker="True" />

                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <CheckBox x:Name="RecursiveCheck" Content="Recursivo" IsChecked="True" Margin="0,0,15,0"/>
                    <CheckBox x:Name="BackupCheck" Content="Criar Backup" IsChecked="True" Margin="0,0,15,0"/>
                    <CheckBox x:Name="BomCheck" Content="Adicionar BOM" IsChecked="True"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </c:DevToolsToolFrame>
</Window>