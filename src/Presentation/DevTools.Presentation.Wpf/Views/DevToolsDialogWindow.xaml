<Window x:Class="DevTools.Presentation.Wpf.Views.DevToolsDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="DevTools Dialog"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MinWidth="420"
        MaxWidth="560"
        MinHeight="190"
        MaxHeight="420"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">

    <Border Background="{DynamicResource DevToolsWindowBackground}"
            BorderBrush="{Binding ElementName=TypeAccentBar, Path=Background}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="TypeAccentBar"
                    Grid.Row="0"
                    Background="{DynamicResource DevToolsAccent}"
                    CornerRadius="8,8,0,0"/>

            <Grid Grid.Row="1" Margin="18,14,18,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <materialDesign:PackIcon x:Name="TypeIcon"
                                         Kind="InformationOutline"
                                         Width="20"
                                         Height="20"
                                         Foreground="{Binding ElementName=TypeAccentBar, Path=Background}"
                                         VerticalAlignment="Top"
                                         Margin="0,1,10,0"/>

                <TextBlock x:Name="DialogTitleText"
                           Grid.Column="1"
                           Text="Informacao"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DevToolsTextPrimary}"
                           TextWrapping="Wrap"/>
            </Grid>

            <TextBlock x:Name="DialogMessageText"
                       Grid.Row="2"
                       Margin="18,0,18,16"
                       Foreground="{DynamicResource DevToolsTextSecondary}"
                       FontSize="14"
                       TextWrapping="Wrap"/>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="18,0,18,14">
                <Button x:Name="SecondaryButton"
                        Content="Não"
                        Width="120"
                        Margin="0,0,10,0"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Click="SecondaryButton_Click"/>
                <Button x:Name="PrimaryButton"
                        Content="OK"
                        Width="120"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Click="PrimaryButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
