<Window x:Class="DevTools.Presentation.Wpf.Views.DevToolsDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DevTools"
        Height="200" Width="400"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="{StaticResource DevToolsWindowBackground}"
        BorderBrush="{StaticResource DevToolsBorder}"
        BorderThickness="1"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="0" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource DevToolsSurface}" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <TextBlock x:Name="TitleText" 
                       Text="Title" 
                       VerticalAlignment="Center" 
                       Margin="12,0"
                       FontSize="{StaticResource DevToolsFontSize.Label}"
                       Foreground="{StaticResource DevToolsTextPrimary}"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Icon placeholder (could be an image or path) -->
            <Path x:Name="IconPath" 
                  Grid.Column="0" 
                  Width="32" Height="32" 
                  Margin="0,0,16,0"
                  VerticalAlignment="Top"
                  Fill="{StaticResource DevToolsPrimary}"
                  Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>

            <TextBlock x:Name="MessageText" 
                       Grid.Column="1"
                       Text="Message goes here..." 
                       TextWrapping="Wrap" 
                       FontSize="{StaticResource DevToolsFontSize.Body}"
                       Foreground="{StaticResource DevToolsTextPrimary}"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="{StaticResource DevToolsSurface}" Padding="16">
            <StackPanel x:Name="ButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Buttons will be added dynamically or controlled by visibility -->
                <Button x:Name="YesButton" Content="Sim" Click="Yes_Click" Style="{StaticResource DevToolsPrimaryButton}" Margin="0,0,8,0" Visibility="Collapsed"/>
                <Button x:Name="NoButton" Content="Não" Click="No_Click" Style="{StaticResource DevToolsSecondaryButton}" Margin="0,0,8,0" Visibility="Collapsed"/>
                <Button x:Name="OkButton" Content="OK" Click="Ok_Click" Style="{StaticResource DevToolsPrimaryButton}" Margin="0,0,8,0" Visibility="Collapsed"/>
                <Button x:Name="CancelButton" Content="Cancelar" Click="Cancel_Click" Style="{StaticResource DevToolsSecondaryButton}" Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
