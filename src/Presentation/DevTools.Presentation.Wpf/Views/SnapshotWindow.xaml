<Window x:Class="DevTools.Presentation.Wpf.Views.SnapshotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        mc:Ignorable="d"
        Title="DevTools - Snapshot"
        Height="600" Width="900"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="{StaticResource DevToolsWindowBackground}"
        BorderBrush="{StaticResource DevToolsBorder}"
        BorderThickness="1">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource DevToolsSurface}" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid Margin="12,0">
                <TextBlock Text="Codebase Snapshot" 
                           VerticalAlignment="Center" 
                           FontSize="{StaticResource DevToolsFontSize.SectionTitle}"
                           Foreground="{StaticResource DevToolsTextPrimary}"
                           FontWeight="SemiBold"/>
                
                <Button Content="✕" 
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Style="{StaticResource DevToolsWindowButtonStyle}"
                        Click="Cancel_Click"/>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Parameters -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,16,0">
                <StackPanel>
                    <c:ProfileSelector x:Name="ProfileSelector" ToolName="snapshot" Margin="0,0,0,16"/>

                    <c:PathSelector x:Name="RootPathSelector" Title="Diretório Raiz (Source)" IsFolderPicker="True" Margin="0,0,0,16"/>
                    
                    <c:PathSelector x:Name="OutputPathSelector" Title="Diretório de Saída (Output)" IsFolderPicker="True" Margin="0,0,0,16"/>

                    <StackPanel>
                        <TextBlock Text="Filtros e Limites" FontSize="{StaticResource DevToolsFontSize.SectionTitle}" Foreground="{StaticResource DevToolsAccent}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <StackPanel Margin="0,0,0,16">
                            <Label Content="Pastas Ignoradas (uma por linha)" Foreground="{StaticResource DevToolsTextSecondary}"/>
                            <TextBox x:Name="IgnoredBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" 
                                     Style="{StaticResource DevToolsTextInput}" Margin="0,0,0,8"/>
                            
                            <Label Content="Tamanho Máximo por Arquivo (KB)" Foreground="{StaticResource DevToolsTextSecondary}"/>
                            <TextBox x:Name="MaxKbBox" Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,16,0,0">
                        <TextBlock Text="Formatos de Saída" FontSize="{StaticResource DevToolsFontSize.SectionTitle}" Foreground="{StaticResource DevToolsAccent}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <StackPanel Margin="0,0,0,16">
                            <CheckBox x:Name="TextCheck" Content="Texto Plano (Concatenado)" IsChecked="True" Margin="0,0,0,8" Style="{StaticResource DevToolsCheckBox}"/>
                            <CheckBox x:Name="JsonNestedCheck" Content="JSON Aninhado (Nested)" Margin="0,0,0,8" Style="{StaticResource DevToolsCheckBox}"/>
                            <CheckBox x:Name="JsonRecursiveCheck" Content="JSON Recursivo (Recursive)" Margin="0,0,0,8" Style="{StaticResource DevToolsCheckBox}"/>
                            <CheckBox x:Name="HtmlCheck" Content="HTML Preview (Navegável)" Margin="0,0,0,8" Style="{StaticResource DevToolsCheckBox}"/>
                            
                            <CheckBox x:Name="RememberSettingsCheck" Content="Lembrar configurações" IsChecked="True" Margin="0,16,0,0" Style="{StaticResource DevToolsCheckBox}"/>
                        </StackPanel>
                    </StackPanel>

                    <Button x:Name="RunButton" Content="Gerar Snapshot" Click="Run_Click" 
                            Margin="0,24,0,0" Height="40" 
                            Style="{StaticResource DevToolsPrimaryButton}"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Results -->
            <Border Grid.Column="1" Background="{StaticResource DevToolsSurface}" CornerRadius="8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Resultado" FontWeight="Bold" Margin="0,0,0,12" Foreground="{StaticResource DevToolsTextPrimary}"/>
                    
                    <c:RunSummaryControl x:Name="RunSummary" Grid.Row="1"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
