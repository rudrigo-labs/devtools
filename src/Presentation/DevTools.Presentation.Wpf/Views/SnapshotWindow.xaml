<Window x:Class="DevTools.Presentation.Wpf.Views.SnapshotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        Title="Snapshot de Projeto" Height="640" Width="900" WindowStartupLocation="CenterScreen"
        Style="{StaticResource ModernWindowStyle}"
        ShowInTaskbar="True"
        Topmost="True">

    <c:DevToolsToolFrame Title="Snapshot de Projeto"
                         PrimaryButtonContent="Gerar Snapshot"
                         SecondaryButtonContent="Cancelar"
                         PrimaryButtonClick="ProcessButton_Click"
                         SecondaryButtonClick="CloseButton_Click"
                         CloseButtonClick="CloseButton_Click">
        <StackPanel Margin="0,20,0,0">
            
            <Label Content="Pasta do Projeto:"/>
            <c:PathSelector x:Name="RootPathSelector" IsFolderPicker="True" />

            <Label Content="Formatos de Saída:" Margin="0,15,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <CheckBox x:Name="TextCheck" Content="Texto Unificado (.txt)" IsChecked="True" Margin="0,5"/>
                    <CheckBox x:Name="HtmlCheck" Content="Preview HTML (.html)" IsChecked="False" Margin="0,5"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <CheckBox x:Name="JsonNestedCheck" Content="JSON Aninhado (.json)" IsChecked="False" Margin="0,5"/>
                    <CheckBox x:Name="JsonRecursiveCheck" Content="JSON Recursivo (.json)" IsChecked="False" Margin="0,5"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </c:DevToolsToolFrame>
</Window>
