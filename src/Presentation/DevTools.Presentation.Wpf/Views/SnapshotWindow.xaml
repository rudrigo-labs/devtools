<Window x:Class="DevTools.Presentation.Wpf.Views.SnapshotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        Title="Snapshot do Projeto"
        Height="640"
        Width="900"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource ModernWindowStyle}"
        ShowInTaskbar="False"
        Topmost="True">

    <c:DevToolsToolFrame x:Name="MainFrame"
                         Title="Snapshot de Projeto"
                         HelpText="Gera saidas de snapshot em multiplos formatos."
                         PrimaryButtonContent="Gerar Snapshot"
                         SecondaryButtonContent="Cancelar"
                         PrimaryButtonClick="ProcessButton_Click"
                         SecondaryButtonClick="CloseButton_Click"
                         CloseButtonClick="CloseButton_Click">
        <StackPanel>
            <TextBlock Text="Configuracao"
                       FontSize="{DynamicResource DevToolsFontSize.SectionTitle}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentBrush}"
                       Margin="0,0,0,16"/>

            <c:PathSelector x:Name="RootPathSelector"
                            Title="Pasta do Projeto"
                            IsFolderPicker="True"
                            Margin="0,0,0,16"/>

            <TextBlock Text="Formatos de Saida"
                       Style="{StaticResource DevToolsInputLabel}"/>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <CheckBox x:Name="TextCheck"
                              Content="Texto Unificado (.txt)"
                              IsChecked="True"
                              Style="{StaticResource DevToolsCheckBox}"
                              Margin="0,0,0,8"/>
                    <CheckBox x:Name="HtmlCheck"
                              Content="Preview HTML (.html)"
                              IsChecked="False"
                              Style="{StaticResource DevToolsCheckBox}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <CheckBox x:Name="JsonNestedCheck"
                              Content="JSON Aninhado (.json)"
                              IsChecked="False"
                              Style="{StaticResource DevToolsCheckBox}"
                              Margin="0,0,0,8"/>
                    <CheckBox x:Name="JsonRecursiveCheck"
                              Content="JSON Recursivo (.json)"
                              IsChecked="False"
                              Style="{StaticResource DevToolsCheckBox}"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </c:DevToolsToolFrame>
</Window>
