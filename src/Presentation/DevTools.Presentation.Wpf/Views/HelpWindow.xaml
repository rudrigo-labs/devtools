<Window x:Class="DevTools.Presentation.Wpf.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Guia de Ajuda"
        Height="700" Width="800"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource ModernWindowStyle}">

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="20,0">
                <materialDesign:PackIcon Kind="HelpCircle" Foreground="{DynamicResource AccentColor}" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Guia de Ajuda: Configuração de Backup" Foreground="White" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <FlowDocumentScrollViewer x:Name="HelpContentScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30,20">
            <!-- O conteúdo será injetado via code-behind -->
        </FlowDocumentScrollViewer>

        <Border Grid.Row="2" Background="#2D2D30" Padding="20,15" BorderBrush="#3F3F46" BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <materialDesign:PackIcon Kind="FilePdfBox" Foreground="#E81123" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Deseja levar este guia com você?" Foreground="#CCCCCC" VerticalAlignment="Center" FontSize="13"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="DownloadPdfButton" Content="Baixar PDF" Click="DownloadPdfButton_Click" 
                            Style="{DynamicResource SecondaryButtonStyle}" Width="120" Margin="0,0,10,0"/>
                    <Button x:Name="CloseButton" Content="Fechar" Click="CloseButton_Click" 
                            Style="{DynamicResource PrimaryButtonStyle}" Width="100"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
