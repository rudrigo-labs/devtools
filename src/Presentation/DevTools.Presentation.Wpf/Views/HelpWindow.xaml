<Window x:Class="DevTools.Presentation.Wpf.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Guia de Ajuda"
        Height="700"
        Width="840"
        MinHeight="560"
        MinWidth="680"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Style="{StaticResource ModernWindowStyle}">

    <Border Background="{DynamicResource DevToolsWindowBackground}"
            BorderBrush="{DynamicResource DevToolsBrushBorder}"
            BorderThickness="1"
            CornerRadius="8">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="72"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource DevToolsSurface}"
                    BorderBrush="{DynamicResource DevToolsBrushBorder}"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Margin="16,0">
                    <materialDesign:PackIcon Kind="HelpCircle"
                                             Foreground="{DynamicResource DevToolsAccent}"
                                             Width="20"
                                             Height="20"
                                             VerticalAlignment="Center"
                                             Margin="0,0,10,0"/>
                    <TextBlock Text="Guia de Ajuda: Configuracao de Backup"
                               Foreground="{DynamicResource DevToolsTextPrimary}"
                               FontSize="{DynamicResource DevToolsFontSize.WindowTitle}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <RichTextBox x:Name="HelpContentViewer"
                         Grid.Row="1"
                         Margin="16"
                         Padding="8,2"
                         Background="Transparent"
                         Foreground="{DynamicResource DevToolsTextPrimary}"
                         BorderThickness="0"
                         IsReadOnly="True"
                         IsDocumentEnabled="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"/>

            <Border Grid.Row="2"
                    Background="{DynamicResource DevToolsSurface}"
                    BorderBrush="{DynamicResource DevToolsBrushBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="16,0">
                <DockPanel LastChildFill="False">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <materialDesign:PackIcon Kind="FilePdfBox"
                                                 Foreground="{DynamicResource ErrorBrush}"
                                                 Width="18"
                                                 Height="18"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,8,0"/>
                        <TextBlock Text="Deseja levar este guia com voce?"
                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                   VerticalAlignment="Center"
                                   FontSize="{DynamicResource DevToolsFontSize.Status}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button x:Name="DownloadPdfButton"
                                Content="Baixar PDF"
                                Click="DownloadPdfButton_Click"
                                Style="{DynamicResource DevToolsSecondaryButton}"
                                Width="140"
                                Margin="0,0,10,0"/>
                        <Button x:Name="CloseButton"
                                Content="Fechar"
                                Click="CloseButton_Click"
                                Style="{DynamicResource DevToolsPrimaryButton}"
                                Width="120"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
