<Window x:Class="DevTools.Presentation.Wpf.Views.NgrokWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        mc:Ignorable="d"
        Title="Ngrok Local Tunnel"
        Height="640"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Style="{StaticResource ModernWindowStyle}">

    <c:DevToolsToolFrame x:Name="MainFrame"
                         Title="Expor Porta (Ngrok)"
                         HelpText="Cria tunel http publico para uma porta local."
                         StatusText="Parado"
                         PrimaryButtonContent="Expor Porta"
                         SecondaryButtonContent="Cancelar"
                         PrimaryButtonClick="StartButton_Click"
                         SecondaryButtonClick="CloseButton_Click"
                         CloseButtonClick="CloseButton_Click">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource DevToolsSurface}"
                    BorderBrush="{DynamicResource DevToolsBrushBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Porta Local" Style="{StaticResource DevToolsInputLabel}"/>
                    <TextBox x:Name="PortInput"
                             Text="5000"
                             Width="180"
                             PreviewTextInput="NumberValidationTextBox"
                             Style="{StaticResource DevToolsTextInput}"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Tuneis Ativos"
                               FontSize="{DynamicResource DevToolsFontSize.SectionTitle}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"/>
                    <Button Content="Atualizar"
                            Click="RefreshButton_Click"
                            HorizontalAlignment="Right"
                            Style="{StaticResource DevToolsSecondaryButton}"/>
                </Grid>

                <Grid Grid.Row="1">
                    <ListBox x:Name="TunnelsList"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource DevToolsSurface}"
                                        BorderBrush="{DynamicResource DevToolsBrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,0,0,8"
                                        Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding PublicUrl}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontSize="14"/>
                                            <TextBlock Text="{Binding Config.Addr}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="Copiar"
                                                Click="CopyUrl_Click"
                                                Tag="{Binding PublicUrl}"
                                                Style="{StaticResource DevToolsSecondaryButton}"
                                                Margin="12,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock x:Name="EmptyStateText"
                               Text="Nenhum tunel ativo."
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Visibility="Collapsed"/>
                </Grid>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Margin="0,16,0,0">
                <Button Content="Matar Processos Ngrok"
                        Click="KillAll_Click"
                        Style="{StaticResource DangerButtonStyle}"/>
            </StackPanel>
        </Grid>
    </c:DevToolsToolFrame>
</Window>
