<Window x:Class="DevTools.Presentation.Wpf.Views.NotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Notas" Height="720" Width="420"
        Style="{StaticResource ModernWindowStyle}"
        Topmost="True"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="Button" x:Key="AppBarButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#66FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource DevToolsWindowBackground}"
            BorderBrush="{DynamicResource DevToolsBrushBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="0">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Header (Draggable) -->
            <Border Grid.Row="0"
                    Background="{DynamicResource DevToolsSurface}"
                    BorderBrush="{DynamicResource DevToolsBrushBorder}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="6"
                    Padding="12,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <TextBlock x:Name="HeaderTitle"
                           Text="NOTAS"
                           FontSize="{DynamicResource DevToolsFontSize.WindowTitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DevToolsTextPrimary}"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
            </Border>

            <!-- List View -->
            <Grid x:Name="ListGrid" Grid.Row="1" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox x:Name="NotesList" Grid.Row="0"
                         Background="Transparent" BorderThickness="0" 
                         Foreground="{DynamicResource DevToolsTextPrimary}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         MouseDoubleClick="NotesList_MouseDoubleClick"
                         Margin="0,12,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="0,0,0,1" BorderBrush="#333333" Padding="5,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding UpdatedUtc}" FontSize="12" Opacity="0.6"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}" Padding="2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1FFFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- AppBar List -->
                <Border Grid.Row="1"
                        Background="{DynamicResource DevToolsSurface}"
                        BorderBrush="{DynamicResource DevToolsBrushBorder}"
                        BorderThickness="0,1,0,0"
                        Padding="0,6">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="AddButton" Style="{StaticResource AppBarButtonStyle}" ToolTip="Nova Nota" Click="AddButton_Click">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </Button>
                        <Button x:Name="ExportButton" Style="{StaticResource AppBarButtonStyle}" ToolTip="Exportar Backup (ZIP)" Click="ExportButton_Click" Margin="10,0">
                            <TextBlock Text="&#xE78C;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </Button>
                        <Button x:Name="ImportButton" Style="{StaticResource AppBarButtonStyle}" ToolTip="Importar Backup (ZIP)" Click="ImportButton_Click" Margin="0,0,10,0">
                            <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </Button>

                        <Button x:Name="CloudSyncButton" Style="{StaticResource AppBarButtonStyle}" ToolTip="Sincronizar com Google Drive" Click="CloudSyncButton_Click" Margin="0,0,10,0" Visibility="Collapsed">
                            <TextBlock Text="&#xE83E;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </Button>
                        
                        <Button x:Name="CloseButton" Style="{StaticResource AppBarButtonStyle}" ToolTip="Fechar" Click="CloseButton_Click">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Edit View -->
            <Grid x:Name="EditGrid" Grid.Row="1" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,12,0,10">
                    <TextBox x:Name="NoteTitle"
                             Style="{StaticResource DevToolsTextInput}"
                             Height="Auto"
                             FontSize="18"
                             FontFamily="Segoe UI"
                             FontWeight="SemiBold"
                             Padding="12,10"/>
                    <TextBlock x:Name="EditValidationText"
                               Margin="2,6,2,0"
                               Foreground="{DynamicResource ErrorBrush}"
                               FontSize="{DynamicResource DevToolsFontSize.Status}"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                </StackPanel>

                <TextBox x:Name="NotesContent" Grid.Row="1"
                         Style="{StaticResource DevToolsTextInput}"
                         Height="Auto"
                         FontFamily="Consolas"
                         FontSize="14"
                         Padding="12,10"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="NotesContent_TextChanged"/>

                <!-- AppBar Edit -->
                <Border Grid.Row="2"
                        Background="{DynamicResource DevToolsSurface}"
                        BorderBrush="{DynamicResource DevToolsBrushBorder}"
                        BorderThickness="0,1,0,0"
                        Padding="0,6">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="BackButton" Style="{StaticResource AppBarButtonStyle}" ToolTip="Voltar" Click="BackButton_Click" Margin="0,0,10,0">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </Button>
                        <Button x:Name="SaveButton" Style="{StaticResource AppBarButtonStyle}" ToolTip="Salvar (Ctrl+S)" Click="SaveButton_Click">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </Button>
                        <Button x:Name="CloudUploadNoteButton" Style="{StaticResource AppBarButtonStyle}" ToolTip="Subir esta nota para o Google Drive" Click="CloudUploadNoteButton_Click" Margin="10,0,0,0" Visibility="Collapsed">
                            <TextBlock Text="&#xE83E;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
