<Window x:Class="DevTools.Presentation.Wpf.Views.NotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DevTools - Notes"
        Width="820"
        Height="540"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource DevToolsWindowBackground}">
    <Border BorderBrush="{StaticResource DevToolsBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource DevToolsWindowBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="Header"
                    Grid.Row="0"
                    Background="{StaticResource DevToolsSurface}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel Margin="10,0">
                    <TextBlock Text="Notes"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource DevToolsFontSize.SectionTitle}"
                               Foreground="{StaticResource DevToolsTextPrimary}"/>
                    <Button Content="X"
                            Width="28"
                            Height="24"
                            DockPanel.Dock="Right"
                            Margin="8,8,0,8"
                            Click="CloseButton_Click"
                            Style="{StaticResource DevToolsSecondaryButton}"/>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="16">
                <Grid x:Name="ListGrid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal"
                                Grid.Row="0"
                                Margin="0,0,0,10">
                        <Button Content="Nova nota"
                                Width="110"
                                Margin="0,0,10,0"
                                Click="AddButton_Click"
                                Style="{StaticResource DevToolsPrimaryButton}"/>
                        <Button Content="Exportar"
                                Width="90"
                                Margin="0,0,10,0"
                                Click="ExportButton_Click"
                                Style="{StaticResource DevToolsSecondaryButton}"/>
                        <Button Content="Importar"
                                Width="90"
                                Click="ImportButton_Click"
                                Style="{StaticResource DevToolsSecondaryButton}"/>
                    </StackPanel>

                    <ListBox x:Name="NotesList"
                             Grid.Row="1"
                             Margin="0"
                             MouseDoubleClick="NotesList_MouseDoubleClick"
                             Background="{StaticResource DevToolsSurface}"
                             Foreground="{StaticResource DevToolsTextPrimary}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="6">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="{StaticResource DevToolsFontSize.Label}"
                                               Foreground="{StaticResource DevToolsTextPrimary}"/>
                                    <TextBlock Text="{Binding FileName}"
                                               FontSize="{StaticResource DevToolsFontSize.Status}"
                                               Foreground="{StaticResource DevToolsTextSecondary}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <Grid x:Name="EditGrid" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal"
                                Grid.Row="0"
                                Margin="0,0,0,10">
                        <Button Content="Voltar"
                                Width="90"
                                Margin="0,0,10,0"
                                Click="BackButton_Click"
                                Style="{StaticResource DevToolsSecondaryButton}"/>
                        <Button Content="Salvar"
                                Width="100"
                                Click="SaveButton_Click"
                                Style="{StaticResource DevToolsPrimaryButton}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Margin="0,0,0,10">
                        <TextBlock Text="Título"
                                   FontSize="{StaticResource DevToolsFontSize.Label}"
                                   Foreground="{StaticResource DevToolsTextSecondary}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="NoteTitle"
                                 Style="{StaticResource DevToolsTextInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="Conteúdo"
                                   FontSize="{StaticResource DevToolsFontSize.Label}"
                                   Foreground="{StaticResource DevToolsTextSecondary}"
                                   Margin="0,0,0,4"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="NotesContent"
                                     Style="{StaticResource DevToolsTextInput}"
                                     AcceptsReturn="True"
                                     TextChanged="NotesContent_TextChanged"
                                     VerticalScrollBarVisibility="Hidden"
                                     TextWrapping="Wrap"
                                     MinHeight="260"/>
                        </ScrollViewer>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>

