<Window x:Class="DevTools.Presentation.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="DevTools Hub" Height="900" Width="1440" MinHeight="760" MinWidth="1180"
        Icon="/Assets/application.ico"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen" WindowState="Normal">

    <Window.Resources>
        <ResourceDictionary>
            <!-- Recursos locais para esta janela -->
                                                
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            
            <Style TargetType="Button" x:Key="SidebarButtonStyle">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource DevToolsTextSecondary}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Padding" Value="14,0,0,0"/>
                <Setter Property="FontSize" Value="{DynamicResource DevToolsFontSize.Input}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}">
                                <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DevToolsWindowBackground}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SettingsBackButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                <Setter Property="Content" Value="&#xE72B;"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Width" Value="36"/>
                <Setter Property="Height" Value="36"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0,0,10,0"/>
            </Style>

            <Style x:Key="SettingsCardStyle" TargetType="materialDesign:Card">
                <Setter Property="Padding" Value="20"/>
                <Setter Property="Margin" Value="0,0,0,24"/>
                <Setter Property="Background" Value="{DynamicResource DevToolsWindowBackground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource DevToolsBrushBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="UniformCornerRadius" Value="8"/>
            </Style>

            <Style x:Key="SettingsListBoxStyle" TargetType="ListBox">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
            </Style>

            <Style x:Key="SettingsListBoxItemStyle" TargetType="ListBoxItem">
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
                <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
                <Setter Property="Background" Value="{DynamicResource DevToolsSurface}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{DynamicResource DevToolsBrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DevToolsAccent}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Background" Value="{DynamicResource DevToolsWindowBackground}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <materialDesign:DialogHost x:Name="RootDialog" Identifier="RootDialog" DialogTheme="Dark">
        <materialDesign:DialogHost.DialogContent>
            <Border Padding="20" Background="{DynamicResource DevToolsSurface}" CornerRadius="8" BorderBrush="{DynamicResource DevToolsBrushBorder}" BorderThickness="1">
                <StackPanel MinWidth="500" MaxWidth="640">
                    <TextBlock Text="Fechar DevTools"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource DevToolsTextPrimary}"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="CloseDialogMessageText"
                               Text="Escolha como deseja fechar o DevTools."
                               Foreground="{DynamicResource DevToolsTextSecondary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,18"/>

                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CloseDialogMinimizeToTrayButton"
                                Content="Minimizar para Bandeja"
                                Click="MinimizeToTrayFromDialog_Click"
                                Margin="0,0,10,10"
                                MinWidth="0"
                                Style="{DynamicResource DevToolsSecondaryButton}"
                                Visibility="Collapsed"/>

                        <Button Content="Cancelar"
                                Click="DialogNoButton_Click"
                                Margin="0,0,10,10"
                                MinWidth="0"
                                Style="{DynamicResource DevToolsSecondaryButton}"/>

                        <Button Content="Encerrar e Sair"
                                Click="Shutdown_Click"
                                MinWidth="0"
                                Margin="0,0,0,10"
                                Style="{DynamicResource DevToolsPrimaryButton}"
                                Background="{DynamicResource ErrorBrush}"
                                Foreground="{DynamicResource DevToolsTextPrimary}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </materialDesign:DialogHost.DialogContent>

        <Border Background="{DynamicResource DevToolsWindowBackground}" 
            BorderBrush="{DynamicResource DevToolsBrushBorder}" 
            BorderThickness="1" 
            CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{DynamicResource DevToolsSurface}" CornerRadius="8,0,0,8">
                    <StackPanel Margin="0,20,0,0">
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,30">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource DevToolsAccent}" Margin="0,2,10,0"/>
                            <TextBlock Text="DevTools" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource DevToolsTextPrimary}"/>
                        </StackPanel>

                        <Button Content="Ferramentas" Style="{DynamicResource SidebarButtonStyle}" Tag="Tools" Click="NavButton_Click" Margin="0,0,0,5"/>
                        <Button Content="Execuções (Jobs)" Style="{DynamicResource SidebarButtonStyle}" Tag="Jobs" Click="NavButton_Click" Margin="0,0,0,5"/>
                        <Button Content="Configurações" Style="{DynamicResource SidebarButtonStyle}" Tag="Settings" Click="NavButton_Click" Margin="0,0,0,20"/>
                        <Button Content="Sobre" Style="{DynamicResource SidebarButtonStyle}" Click="OpenAbout_Click" Margin="0,0,0,20"/>

                        <Button Content="Encerrar"
                            Style="{DynamicResource SidebarButtonStyle}"
                            Foreground="{DynamicResource ErrorBrush}"
                            Command="{x:Static materialDesign:DialogHost.OpenDialogCommand}"
                            CommandTarget="{Binding ElementName=RootDialog}"/>
                    </StackPanel>
                </Border>

                <!-- Main Content -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="72"/>
                    </Grid.RowDefinitions>

                    <!-- Window Drag/Close -->
                    <Grid Grid.Row="0" Background="{DynamicResource DevToolsSurface}" MouseLeftButtonDown="Window_MouseLeftButtonDown">
                        <Border BorderBrush="{DynamicResource DevToolsBrushBorder}" BorderThickness="0,0,0,1"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Click="MinimizeButton_Click"
                                Content="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                Width="40" Height="40" Background="Transparent" Foreground="{DynamicResource DevToolsTextSecondary}"
                                BorderThickness="0"
                                Visibility="Collapsed"
                                IsEnabled="False">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource DevToolsWindowBackground}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button x:Name="MaximizeRestoreButton"
                                Click="MaximizeRestoreButton_Click"
                                Content="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                Width="40" Height="40" Background="Transparent" Foreground="{DynamicResource DevToolsTextSecondary}"
                                BorderThickness="0"
                                Visibility="Collapsed"
                                IsEnabled="False">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource DevToolsWindowBackground}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Click="CloseButton_Click"
                                Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                Width="40" Height="40" Background="Transparent" Foreground="{DynamicResource DevToolsTextSecondary}"
                                BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource DevToolsStatusError}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Dynamic Content Area -->
                    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="24,16,24,16" x:Name="MainTabControl">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <!-- Removemos a visibilidade Collapsed aqui para garantir que os cards apareçam se selecionado -->
                            </Style>
                        </TabControl.Resources>

                        <!-- Tab: Tools -->
                        <TabItem x:Name="TabTools">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,15,0">
                                <StackPanel>
                                    <TextBlock Text="Ferramentas Disponíveis" Style="{DynamicResource DevToolsPageTitle}"/>

                                    <WrapPanel Orientation="Horizontal" Margin="0,4,-15,0">
                                        <!-- Cards de Ferramentas -->
                                        <Button Style="{DynamicResource ToolCardStyle}" Content="Notas Rápidas" 
                                            Tag="{DynamicResource Icon.Notes}" ToolTip="Anotações flutuantes always-on-top" Click="OpenTool_Click" CommandParameter="Notes"/>

                                        <Button Style="{DynamicResource ToolCardStyle}" Content="Organizador de Arquivos" 
                                            Tag="{DynamicResource Icon.Organizer}" ToolTip="Move/organiza por extensão/data conforme categorias" Click="OpenTool_Click" CommandParameter="Organizer"/>

                                        <Button Style="{DynamicResource ToolCardStyle}" Content="Renomear Projeto .NET" 
                                            Tag="{DynamicResource Icon.Rename}" ToolTip="Renomeia projeto/solution e namespaces C# com backup" Click="OpenTool_Click" CommandParameter="Rename"/>

                                        <Button Style="{DynamicResource ToolCardStyle}" Content="Snapshot do Projeto" 
                                            Tag="{DynamicResource Icon.Snapshot}" ToolTip="Gera ZIP do projeto com filtros" Click="OpenTool_Click" CommandParameter="Snapshot"/>

                                        <Button Style="{DynamicResource ToolCardStyle}" Content="Dividir Imagens" 
                                            Tag="{DynamicResource Icon.ImageSplitter}" ToolTip="Divide imagens em grade configurável" Click="OpenTool_Click" CommandParameter="ImageSplitter"/>

                                        <Button Style="{DynamicResource ToolCardStyle}" Content="Converter para UTF-8" 
                                            Tag="{DynamicResource Icon.Utf8Convert}" ToolTip="Converte arquivos para UTF-8 preservando conteúdo" Click="OpenTool_Click" CommandParameter="Utf8Convert"/>

                                        <Button Style="{DynamicResource ToolCardStyle}" Content="Buscar Texto em Arquivos" 
                                            Tag="{DynamicResource Icon.SearchText}" ToolTip="Busca rápida com regex e filtros" Click="OpenTool_Click" CommandParameter="SearchText"/>

                                        <Button Style="{DynamicResource ToolCardStyle}" Content="EF Core Migrations" 
                                            Tag="{DynamicResource Icon.Migrations}" ToolTip="Cria/aplica migrations em contextos EF Core" Click="OpenTool_Click" CommandParameter="Migrations"/>

                                        <Button Style="{DynamicResource ToolCardStyle}" Content="Coletor de Arquivos" 
                                            Tag="{DynamicResource Icon.Harvest}" ToolTip="Copia arquivos filtrados para pasta de saída" Click="OpenTool_Click" CommandParameter="Harvest"/>

                                        <Button Style="{DynamicResource ToolCardStyle}" Content="Túnel SSH" 
                                            Tag="{DynamicResource Icon.SSHTunnel}" ToolTip="Gerenciador de túneis SSH" Click="OpenTool_Click" CommandParameter="SSHTunnel"/>

                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- Tab: Jobs -->
                        <TabItem x:Name="TabJobs">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Text="Centro de Execuções" Style="{DynamicResource DevToolsPageTitle}"/>

                                <!-- Detalhes / Logs (Bottom) -->
                                <Expander DockPanel.Dock="Bottom"
                                          Header="Detalhes / Logs"
                                          Foreground="{DynamicResource DevToolsTextPrimary}"
                                          Margin="0,10,0,0"
                                          IsExpanded="True"
                                          BorderBrush="{DynamicResource DevToolsBrushBorder}">
                                    <TextBox Text="{Binding SelectedItem.Logs, ElementName=JobsDataGrid, Mode=OneWay}" 
                                         Height="150" 
                                         Background="{DynamicResource DevToolsWindowBackground}" 
                                         Foreground="{DynamicResource DevToolsTextPrimary}"
                                         FontFamily="Consolas"
                                         IsReadOnly="True"
                                         VerticalScrollBarVisibility="Auto"
                                         BorderThickness="0"
                                         Padding="5"/>
                                </Expander>

                                <!-- Lista de Jobs (Fill) -->
                                <DataGrid x:Name="JobsDataGrid" 
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True" 
                                      Background="Transparent"
                                      BorderThickness="0"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      RowBackground="Transparent"
                                      Foreground="{DynamicResource DevToolsTextSecondary}">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="{DynamicResource DevToolsSurface}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
                                            <Setter Property="Padding" Value="10,5"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource DevToolsBorder}"/>
                                        </Style>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Padding" Value="10"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource DevToolsWindowBackground}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Tarefa" Binding="{Binding Name}" Width="2*"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                        <DataGridTemplateColumn Header="Progresso" Width="1.5*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="4" VerticalAlignment="Center" Background="{DynamicResource DevToolsBrushBorder}" BorderThickness="0" Foreground="{DynamicResource DevToolsAccent}"/>
                                                        <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0}%}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" Foreground="{DynamicResource DevToolsTextPrimary}" Margin="0,-15,0,0"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Mensagem" Binding="{Binding Message}" Width="3*"/>
                                        <DataGridTextColumn Header="Início" Binding="{Binding StartedAt, StringFormat=HH:mm:ss}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </TabItem>

                        <!-- Tab: Embedded Tool Host -->
                        <TabItem x:Name="TabEmbeddedTool">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="{DynamicResource DevToolsSurface}"
                                        BorderBrush="{DynamicResource DevToolsBrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                Content="&#xE72B;"
                                                FontFamily="Segoe MDL2 Assets"
                                                Style="{DynamicResource DevToolsSecondaryButton}"
                                                Width="40"
                                                Height="40"
                                                Click="BackToToolsFromEmbedded_Click"/>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock x:Name="EmbeddedToolTitleText"
                                                       Text="Ferramenta Embutida"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource DevToolsTextPrimary}"/>
                                            <TextBlock x:Name="EmbeddedToolSubtitleText"
                                                       Text="Visualizacao integrada no Shell."
                                                       FontSize="13"
                                                       Foreground="{DynamicResource DevToolsTextSecondary}"/>
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                Content="Voltar para Ferramentas"
                                                Click="BackToToolsFromEmbedded_Click"
                                                Style="{DynamicResource DevToolsSecondaryButton}"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1"
                                        Background="{DynamicResource DevToolsWindowBackground}"
                                        BorderBrush="{DynamicResource DevToolsBrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <ContentControl x:Name="EmbeddedToolContentHost"/>
                                </Border>
                            </Grid>
                        </TabItem>

                        <!-- Tab: Settings -->
                        <TabItem x:Name="TabSettings">
                            <Grid>
                                <!-- Lista de Configurações (Cards) -->
                                <ScrollViewer x:Name="SettingsListPanel" VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="0,0">
                                        <TextBlock Text="Configurações do Projeto" Style="{DynamicResource DevToolsPageTitle}"/>

                                        <!-- Seção: Configurações Gerais -->
                                        <TextBlock Text="Configurações Gerais" Style="{DynamicResource DevToolsSectionTitle}"/>
                                        <WrapPanel Orientation="Horizontal" Margin="0,4,-15,20">
    
                                            <Button Style="{DynamicResource ToolCardStyle}" Tag="{DynamicResource Icon.Migrations}" Content="Armazenamento" 
                                                ToolTip="Selecionar backend de configurações: JSON ou SQLite" Width="200" Click="OpenStorageSettings_Click"/>

                                            <Button Style="{DynamicResource ToolCardStyle}" Tag="{DynamicResource Icon.Harvest}" Content="Harvest" 
                                                ToolTip="Configurar regras de extração e IA" Width="200" Click="OpenHarvestSettings_Click"/>

                                            <Button Style="{DynamicResource ToolCardStyle}" Tag="{DynamicResource Icon.Organizer}" Content="Organizer" 
                                                ToolTip="Categorias e regras de organização" Width="200" Click="OpenOrganizerSettings_Click"/>

                                            <Button Style="{DynamicResource ToolCardStyle}" Tag="{DynamicResource Icon.Migrations}" Content="Migrations" 
                                                ToolTip="Caminhos e contextos do EF Core" Width="200" Click="OpenMigrationsSettings_Click"/>

                                            <Button Style="{DynamicResource ToolCardStyle}" Tag="{DynamicResource Icon.Ngrok}" Content="Ngrok" 
                                                ToolTip="Caminho do executável e token" Width="200" Click="OpenNgrokSettings_Click"/>

                                            <Button Style="{DynamicResource ToolCardStyle}" Tag="{DynamicResource Icon.Notes}" Content="Notas e Nuvem" 
                                                ToolTip="Local de armazenamento e backup no Google Drive" Width="200" Click="OpenNotesCloudSettings_Click"/>
                                        </WrapPanel>

                                        <!-- Seção: Perfis de Ferramentas -->
                                        <TextBlock Text="Perfis de Ferramentas" Style="{DynamicResource DevToolsSectionTitle}" Margin="0,20,0,10"/>
                                        <WrapPanel Orientation="Horizontal" Margin="0,0,-15,0">
                                            <Button Style="{DynamicResource ToolCardStyle}" Tag="{DynamicResource Icon.Rename}" Content="Renomeação" 
                                                ToolTip="Perfis de renomeação de projeto" Width="200" Click="OpenToolProfiles_Click" CommandParameter="Rename"/>

                                            <Button Style="{DynamicResource ToolCardStyle}" Tag="{DynamicResource Icon.Migrations}" Content="EF Migrations" 
                                                ToolTip="Perfis de execução de migrations" Width="200" Click="OpenToolProfiles_Click" CommandParameter="Migrations"/>

                                            <Button Style="{DynamicResource ToolCardStyle}" Tag="{DynamicResource Icon.Harvest}" Content="Harvest" 
                                                ToolTip="Perfis de coleta de arquivos" Width="200" Click="OpenToolProfiles_Click" CommandParameter="Harvest"/>
                                                
                                            <Button Style="{DynamicResource ToolCardStyle}" Tag="{DynamicResource Icon.SearchText}" Content="Busca de Texto" 
                                                ToolTip="Perfis de busca de texto em arquivos" Width="200" Click="OpenToolProfiles_Click" CommandParameter="SearchText"/>

                                            <Button Style="{DynamicResource ToolCardStyle}" Tag="{DynamicResource Icon.Snapshot}" Content="Snapshot" 
                                                ToolTip="Perfis de snapshot de projeto" Width="200" Click="OpenToolProfiles_Click" CommandParameter="Snapshot"/>

                                            <Button Style="{DynamicResource ToolCardStyle}" Tag="{DynamicResource Icon.SSHTunnel}" Content="Túnel SSH" 
                                                ToolTip="Perfis de conexão e túnel SSH" Width="200" Click="OpenToolProfiles_Click" CommandParameter="SSHTunnel"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </ScrollViewer>

                                <!-- Painel: Configuração de Armazenamento -->
                                <Grid x:Name="StorageSettingsPanel" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <Button Style="{DynamicResource SettingsBackButtonStyle}" Click="BackToSettingsList_Click" />
                                        <TextBlock Text="Configuração: Armazenamento" Style="{DynamicResource DevToolsPanelTitle}"/>
                                    </StackPanel>

                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="0,0,20,0">
                                            <materialDesign:Card Style="{DynamicResource SettingsCardStyle}">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                                        <materialDesign:PackIcon Kind="Database" Foreground="{DynamicResource DevToolsAccent}" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20"/>
                                                        <TextBlock Text="Backend de Configurações" Style="{DynamicResource DevToolsCardTitle}"/>
                                                    </StackPanel>

                                                    <TextBlock Text="Selecione onde as configurações e perfis serão persistidos."
                                                               Foreground="{DynamicResource DevToolsTextSecondary}"
                                                               Margin="0,0,0,12"
                                                               TextWrapping="Wrap"/>

                                                    <StackPanel Width="360">
                                                        <TextBlock Text="Modo de Armazenamento" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                        <ComboBox x:Name="StorageBackendCombo"
                                                                  Style="{DynamicResource DevToolsSelectInput}"
                                                                  SelectionChanged="StorageBackendCombo_SelectionChanged">
                                                            <ComboBoxItem Tag="json" Content="Arquivo JSON (appsettings.json)"/>
                                                            <ComboBoxItem Tag="sqlite" Content="Banco SQLite (devtools.db)"/>
                                                        </ComboBox>
                                                    </StackPanel>

                                                    <TextBlock x:Name="StorageBackendHintText"
                                                               Margin="0,12,0,0"
                                                               Foreground="{DynamicResource DevToolsTextSecondary}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </materialDesign:Card>

                                            <materialDesign:Card Style="{DynamicResource SettingsCardStyle}">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                        <materialDesign:PackIcon Kind="InformationOutline" Foreground="{DynamicResource DevToolsAccent}" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20"/>
                                                        <TextBlock Text="Observação" Style="{DynamicResource DevToolsCardTitle}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="A troca de backend exige reiniciar o DevTools para ser aplicada."
                                                               Foreground="{DynamicResource DevToolsTextSecondary}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </materialDesign:Card>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,20">
                                                <Button Content="Cancelar" Click="BackToSettingsList_Click" Style="{DynamicResource DevToolsSecondaryButton}" Width="120" Margin="0,0,10,0"/>
                                                <Button Content="Salvar" Click="SaveStorageSettings_Click" Style="{DynamicResource DevToolsPrimaryButton}" Width="120"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>

                                <!-- Painel: Gestão de Perfis de Ferramenta -->
                                <Grid x:Name="ToolProfilesSettingsPanel" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header com Voltar -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <Button Style="{DynamicResource SettingsBackButtonStyle}" Click="BackToSettingsList_Click" />
                                        <TextBlock x:Name="ToolProfilesTitle" Text="Perfis: [Ferramenta]" Style="{DynamicResource DevToolsPanelTitle}"/>
                                    </StackPanel>

                                    <!-- Conteúdo Gestão de Perfis -->
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="250"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Lista de Perfis -->
                                        <Border BorderBrush="{DynamicResource DevToolsBrushBorder}" BorderThickness="0" Padding="0,0,10,0">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Bottom" Content="+ Novo Perfil" Style="{DynamicResource DevToolsSecondaryButton}" 
                                                    Margin="0,10,0,0" Click="AddToolProfile_Click"/>
                                                <ListBox x:Name="ToolProfilesList"
                                                     Style="{DynamicResource SettingsListBoxStyle}"
                                                     ItemContainerStyle="{DynamicResource SettingsListBoxItemStyle}"
                                                     SelectionChanged="ToolProfile_SelectionChanged">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,2">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1" Text="&#x2605;" Foreground="{DynamicResource DevToolsAccent}" 
                                                                           Visibility="{Binding IsDefault, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                                                           ToolTip="Perfil Padrão" Margin="5,0,0,0"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </DockPanel>
                                        </Border>

                                                <!-- Editor de Perfil -->
                                        <ScrollViewer Grid.Column="1" Margin="20,0,0,0" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                                            <StackPanel x:Name="ToolProfileEditForm" Visibility="Collapsed">
                                                
                                                <materialDesign:Card Style="{DynamicResource SettingsCardStyle}">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                                            <materialDesign:PackIcon Kind="Settings" Foreground="{DynamicResource DevToolsAccent}" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20"/>
                                                            <TextBlock Text="Configurações do Perfil" Style="{DynamicResource DevToolsCardTitle}"/>
                                                        </StackPanel>

                                                        <StackPanel>
                                                            <TextBlock Text="Nome do Perfil" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                            <TextBox x:Name="ToolProfileNameInput" Style="{DynamicResource DevToolsTextInput}"/>
                                                        </StackPanel>

                                                        <!-- Container para campos específicos injetados -->
                                                        <StackPanel x:Name="ToolProfileFieldsContainer" Margin="0,20,0,0"/>

                                                        <CheckBox x:Name="ToolProfileIsDefaultCheck" 
                                                              Content="Usar como perfil padrão" 
                                                              Margin="0,24,0,0"
                                                              Style="{DynamicResource DevToolsCheckBox}"/>
                                                    </StackPanel>
                                                </materialDesign:Card>

                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,20">
                                                    <Button Content="Remover" Click="DeleteToolProfile_Click" 
                                                            Style="{DynamicResource DevToolsDangerButton}" Width="120" Margin="0,0,10,0"/>
                                                    <Button Content="Cancelar" Click="BackToSettingsList_Click" 
                                                            Style="{DynamicResource DevToolsSecondaryButton}" Width="120" Margin="0,0,10,0"/>
                                                    <Button Content="Salvar" Click="SaveToolProfile_Click" 
                                                            Style="{DynamicResource DevToolsPrimaryButton}" Width="120"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>
                                </Grid>



                                <!-- Painel: Configuração Notas e Nuvem -->
                                <Grid x:Name="NotesCloudSettingsPanel" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <Button Style="{DynamicResource SettingsBackButtonStyle}" Click="BackToSettingsList_Click" />
                                        <TextBlock Text="Configuração: Notas e Nuvem" Style="{DynamicResource DevToolsPanelTitle}"/>
                                    </StackPanel>

                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="0,0,20,0">
                                            <!-- Grupo: Armazenamento Local -->
                                            <StackPanel Margin="0,0,0,16">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                                    <materialDesign:PackIcon Kind="Folder" Foreground="{DynamicResource DevToolsAccent}" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20"/>
                                                    <TextBlock Text="Armazenamento Local" Style="{DynamicResource DevToolsCardTitle}"/>
                                                </StackPanel>

                                                <c:PathSelector x:Name="NotesStoragePathSelector" Title="Pasta de Armazenamento" IsFolderPicker="True" Margin="0,0,0,20"/>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="Formato Padrão" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                        <ComboBox x:Name="NotesFormatCombo" Style="{DynamicResource DevToolsSelectInput}">
                                                            <ComboBoxItem Content=".txt"/>
                                                            <ComboBoxItem Content=".md"/>
                                                        </ComboBox>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                                        <CheckBox x:Name="NotesAutoCloudSyncCheck" Content="Backup Automático na Nuvem ao Salvar" Style="{DynamicResource DevToolsCheckBox}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <StackPanel Margin="0,20,0,0" Width="320">
                                                    <TextBlock Text="Exibição Inicial da Lista" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                    <ComboBox x:Name="NotesInitialListDisplayCombo" Style="{DynamicResource DevToolsSelectInput}">
                                                        <ComboBoxItem Content="Auto"/>
                                                        <ComboBoxItem Content="8"/>
                                                        <ComboBoxItem Content="15"/>
                                                        <ComboBoxItem Content="20"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </StackPanel>

                                            <Border Height="1" Background="{DynamicResource DevToolsBrushBorder}" Margin="0,0,0,16"/>

                                            <!-- Grupo: Google Drive (Backup) -->
                                            <StackPanel Margin="0,0,0,8">
                                                <DockPanel LastChildFill="False" Margin="0,0,0,20">
                                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                                        <materialDesign:PackIcon Kind="GoogleDrive" Foreground="{DynamicResource DevToolsAccent}" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20"/>
                                                        <TextBlock Text="Backup Google Drive" Style="{DynamicResource DevToolsCardTitle}"/>
                                                    </StackPanel>
                                                    <Button DockPanel.Dock="Right" Content="Como configurar?" Style="{DynamicResource DevToolsSecondaryButton}" 
                                                        Padding="12,8" MinWidth="140" Click="OpenHelp_Click"/>
                                                </DockPanel>

                                                <CheckBox x:Name="GDriveEnabledCheck" Content="Habilitar Backup no Google Drive" 
                                                          Margin="0,0,0,20" Style="{DynamicResource DevToolsCheckBox}"
                                                          Checked="GDriveEnabledCheck_Changed" Unchecked="GDriveEnabledCheck_Changed"/>

                                                <Grid x:Name="GDriveConfigGrid" IsEnabled="{Binding IsChecked, ElementName=GDriveEnabledCheck}">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                                        <TextBlock Text="Client ID" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="GDriveClientId" Style="{DynamicResource DevToolsTextInput}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                                        <TextBlock Text="Client Secret" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="GDriveClientSecret" Style="{DynamicResource DevToolsTextInput}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,20,0,0">
                                                        <TextBlock Text="Project ID" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="GDriveProjectId" Style="{DynamicResource DevToolsTextInput}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,20,0,0">
                                                        <TextBlock Text="Nome da Pasta no Drive" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="GDriveFolderName" Style="{DynamicResource DevToolsTextInput}"/>
                                                    </StackPanel>

                                                    <Button x:Name="GDriveTestConnectionButton" Grid.Row="2" Grid.Column="0" Content="Testar Conexão" Click="TestConnection_Click" 
                                                        Style="{DynamicResource DevToolsSecondaryButton}" Width="150" HorizontalAlignment="Left" Margin="0,20,0,0"/>
                                                    <TextBlock x:Name="GDriveTestConnectionStatus" Grid.Row="2" Grid.Column="2" Margin="0,24,0,0"
                                                               Foreground="{DynamicResource DevToolsTextSecondary}" FontSize="13"
                                                               TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,20">
                                                <Button Content="Cancelar" Click="BackToSettingsList_Click" Style="{DynamicResource DevToolsSecondaryButton}" Width="120" Margin="0,0,10,0"/>
                                                <Button Content="Salvar" Click="SaveNotesCloudSettings_Click" Style="{DynamicResource DevToolsPrimaryButton}" Width="120"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>

                                <!-- Painel: Configuração Harvest -->
                                <Grid x:Name="HarvestSettingsPanel" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <Button Style="{DynamicResource SettingsBackButtonStyle}" Click="BackToSettingsList_Click" />
                                        <TextBlock Text="Configuração: Harvest" Style="{DynamicResource DevToolsPanelTitle}"/>
                                    </StackPanel>

                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="0,0,20,0">
                                            <!-- Grupo: Regras de Filtragem -->
                                            <StackPanel Margin="0,0,0,16">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                    <materialDesign:PackIcon Kind="FilterVariant" Foreground="{DynamicResource DevToolsAccent}" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20"/>
                                                    <TextBlock Text="Regras de Filtragem" Style="{DynamicResource DevToolsCardTitle}"/>
                                                </StackPanel>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="Extensões Permitidas (ex: .cs, .ts)" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="HarvestExtensions" Style="{DynamicResource DevToolsTextInput}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Pastas Ignoradas (ex: bin, obj)" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="HarvestExcludeDirs" Style="{DynamicResource DevToolsTextInput}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <StackPanel Margin="0,20,0,0" Width="280" HorizontalAlignment="Left">
                                                    <TextBlock Text="Tamanho Máximo de Arquivo (KB)" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                    <TextBox x:Name="HarvestMaxFileSizeInput" Style="{DynamicResource DevToolsTextInput}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <Border Height="1" Background="{DynamicResource DevToolsBrushBorder}" Margin="0,0,0,16"/>

                                            <!-- Grupo: Limites e Top -->
                                            <StackPanel Margin="0,0,0,16">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                    <materialDesign:PackIcon Kind="ChartLine" Foreground="{DynamicResource DevToolsAccent}" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20"/>
                                                    <TextBlock Text="Limites Padrão" Style="{DynamicResource DevToolsCardTitle}"/>
                                                </StackPanel>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="Score Mínimo (0-100)" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="HarvestMinScore" Style="{DynamicResource DevToolsTextInput}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Top Arquivos (Quantidade)" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="HarvestTopDefault" Style="{DynamicResource DevToolsTextInput}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>

                                            <Border Height="1" Background="{DynamicResource DevToolsBrushBorder}" Margin="0,0,0,16"/>

                                            <!-- Grupo: Pesos de IA -->
                                            <StackPanel Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                    <materialDesign:PackIcon Kind="Robot" Foreground="{DynamicResource DevToolsAccent}" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20"/>
                                                    <TextBlock Text="Pesos de Relevância (IA)" Style="{DynamicResource DevToolsCardTitle}"/>
                                                </StackPanel>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="Fan-In (Entradas)" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="HarvestWeightFanIn" Style="{DynamicResource DevToolsTextInput}"/>

                                                        <TextBlock Text="Densidade de Keywords" Style="{DynamicResource DevToolsInputLabel}" Margin="0,16,0,6"/>
                                                        <TextBox x:Name="HarvestWeightDensity" Style="{DynamicResource DevToolsTextInput}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Fan-Out (Saídas)" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                        <TextBox x:Name="HarvestWeightFanOut" Style="{DynamicResource DevToolsTextInput}"/>

                                                        <TextBlock Text="Penalidade Dead Code" Style="{DynamicResource DevToolsInputLabel}" Margin="0,16,0,6"/>
                                                        <TextBox x:Name="HarvestWeightDeadCode" Style="{DynamicResource DevToolsTextInput}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,20">
                                                <Button Content="Cancelar" Click="BackToSettingsList_Click" 
                                                        Style="{StaticResource DevToolsSecondaryButton}" Width="120" Margin="0,0,10,0"/>
                                                <Button Content="Salvar" Click="SaveHarvestSettings_Click" 
                                                        Style="{StaticResource DevToolsPrimaryButton}" Width="120"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>

                                <!-- Painel: Configuração Organizer -->
                                <Grid x:Name="OrganizerSettingsPanel" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <Button Style="{DynamicResource SettingsBackButtonStyle}" Click="BackToSettingsList_Click" />
                                        <TextBlock Text="Configuração: Organizer" Style="{DynamicResource DevToolsPanelTitle}"/>
                                    </StackPanel>

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="250"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Lista de Categorias -->
                                        <Border BorderBrush="{DynamicResource DevToolsBrushBorder}" BorderThickness="0" Padding="0,0,10,0">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Bottom" Content="+ Nova Categoria" Style="{DynamicResource DevToolsSecondaryButton}" 
                                                    Margin="0,10,0,0" Click="AddOrganizerCategory_Click"/>
                                                <ListBox x:Name="OrganizerCategoriesList"
                                                     Style="{DynamicResource SettingsListBoxStyle}"
                                                     ItemContainerStyle="{DynamicResource SettingsListBoxItemStyle}"
                                                     DisplayMemberPath="Name"
                                                     SelectionChanged="OrganizerCategory_SelectionChanged"/>
                                            </DockPanel>
                                        </Border>

                                        <!-- Form Organizer -->
                                        <ScrollViewer Grid.Column="1" Margin="20,0,0,0" VerticalScrollBarVisibility="Auto">
                                            <StackPanel x:Name="OrganizerEditForm" Visibility="Collapsed">
                                                
                                                <!-- Grupo: Detalhes da Categoria -->
                                                <materialDesign:Card Style="{DynamicResource SettingsCardStyle}" Margin="0,0,0,16">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                                            <materialDesign:PackIcon Kind="Category" Foreground="{DynamicResource DevToolsAccent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <TextBlock Text="Detalhes da Categoria" Style="{DynamicResource DevToolsCardTitle}"/>
                                                        </StackPanel>

                                                        <StackPanel>
                                                            <TextBlock Text="Nome da Categoria" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,2"/>
                                                            <TextBox x:Name="OrgCatName" Style="{DynamicResource DevToolsTextInput}"/>
                                                        </StackPanel>

                                                        <StackPanel Margin="0,16,0,0">
                                                            <TextBlock Text="Nome da Pasta Destino" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,2"/>
                                                            <TextBox x:Name="OrgCatFolder" Style="{DynamicResource DevToolsTextInput}"/>
                                                        </StackPanel>

                                                        <StackPanel Margin="0,16,0,0">
                                                            <TextBlock Text="Palavras-Chave (separadas por vírgula)" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,2"/>
                                                            <TextBox x:Name="OrgCatKeywords" Style="{DynamicResource DevToolsTextInput}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </materialDesign:Card>

                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,20">
                                                    <Button Content="Remover" Click="DeleteOrganizerCategory_Click" 
                                                            Style="{DynamicResource DevToolsDangerButton}" Width="120" Margin="0,0,10,0"/>
                                                    <Button Content="Cancelar" Click="BackToSettingsList_Click" 
                                                            Style="{DynamicResource DevToolsSecondaryButton}" Width="120" Margin="0,0,10,0"/>
                                                    <Button Content="Salvar" Click="SaveOrganizerCategory_Click" 
                                                            Style="{DynamicResource DevToolsPrimaryButton}" Width="120"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>
                                </Grid>

                                <!-- Painel: Configuração Migrations -->
                                <Grid x:Name="MigrationsSettingsPanel" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <Button Style="{DynamicResource SettingsBackButtonStyle}" Click="BackToSettingsList_Click" />
                                        <TextBlock Text="Configuração: EF Core Migrations" Style="{DynamicResource DevToolsPanelTitle}"/>
                                    </StackPanel>

                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="0,0,20,0">
                                            
                                            <!-- Grupo: Caminhos do Projeto -->
                                            <materialDesign:Card Style="{DynamicResource SettingsCardStyle}" Margin="0,0,0,16">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                                    <materialDesign:PackIcon Kind="Folder" Foreground="{DynamicResource DevToolsAccent}" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20"/>
                                                    <TextBlock Text="Caminhos do Projeto" Style="{DynamicResource DevToolsCardTitle}"/>
                                                </StackPanel>

                                                <StackPanel Margin="0,0,0,20">
                                                    <c:PathSelector x:Name="MigRootPathSelector" Title="Caminho Raiz do Projeto (Root Path)" IsFolderPicker="True"/>
                                                </StackPanel>

                                                <StackPanel>
                                                    <c:PathSelector x:Name="MigStartupPathSelector" Title="Caminho do Projeto de Startup (Startup Project)" IsFolderPicker="True"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </materialDesign:Card>

                                        <!-- Grupo: Configuração do Contexto -->
                                        <materialDesign:Card Style="{DynamicResource SettingsCardStyle}">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                                    <materialDesign:PackIcon Kind="DatabaseSettings" Foreground="{DynamicResource DevToolsAccent}" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20"/>
                                                    <TextBlock Text="Configuração do Contexto" Style="{DynamicResource DevToolsCardTitle}"/>
                                                </StackPanel>

                                                <StackPanel>
                                                    <TextBlock Text="Nome Completo do DbContext (ex: MyApp.Data.AppDbContext)" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                    <TextBox x:Name="MigContextInput" Style="{DynamicResource DevToolsTextInput}"/>
                                                </StackPanel>

                                                <StackPanel Margin="0,20,0,0">
                                                    <TextBlock Text="Argumentos Adicionais (dotnet ef ...)" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                    <TextBox x:Name="MigArgsInput" Style="{DynamicResource DevToolsTextInput}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </materialDesign:Card>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,20">
                                            <Button Content="Cancelar" Click="BackToSettingsList_Click" Style="{DynamicResource DevToolsSecondaryButton}" Width="120" Margin="0,0,10,0"/>
                                            <Button Content="Salvar" Click="SaveMigrationsSettings_Click" 
                                                Style="{DynamicResource DevToolsPrimaryButton}" Width="120"/>
                                        </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>

                                <!-- Painel: Configuração Ngrok -->
                                <Grid x:Name="NgrokSettingsPanel" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <Button Style="{DynamicResource SettingsBackButtonStyle}" Click="BackToSettingsList_Click" />
                                        <TextBlock Text="Configuração: Ngrok" Style="{DynamicResource DevToolsPanelTitle}"/>
                                    </StackPanel>

                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="0,0,20,0">
                                            <!-- Grupo: Execução Local -->
                                            <StackPanel Margin="0,0,0,16">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                                    <materialDesign:PackIcon Kind="PlayCircle" Foreground="{DynamicResource DevToolsAccent}" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20"/>
                                                    <TextBlock Text="Execução Local" Style="{DynamicResource DevToolsCardTitle}"/>
                                                </StackPanel>

                                                <c:PathSelector x:Name="NgrokExeSelector" Title="Caminho do Executável do Ngrok (ngrok.exe)" IsFolderPicker="False"/>
                                            </StackPanel>

                                            <Border Height="1" Background="{DynamicResource DevToolsBrushBorder}" Margin="0,0,0,16"/>

                                            <!-- Grupo: Autenticação e Argumentos -->
                                            <StackPanel Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                                    <materialDesign:PackIcon Kind="KeyVariant" Foreground="{DynamicResource DevToolsAccent}" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20"/>
                                                    <TextBlock Text="Autenticação e Argumentos" Style="{DynamicResource DevToolsCardTitle}"/>
                                                </StackPanel>

                                                <StackPanel>
                                                    <TextBlock Text="Auth Token (via --authtoken)" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                    <TextBox x:Name="NgrokAuthTokenInput" Style="{DynamicResource DevToolsTextInput}"/>
                                                </StackPanel>

                                                <StackPanel Margin="0,20,0,0">
                                                    <TextBlock Text="Argumentos Adicionais" Style="{DynamicResource DevToolsInputLabel}" Margin="0,0,0,6"/>
                                                    <TextBox x:Name="NgrokArgsInput" Style="{DynamicResource DevToolsTextInput}"/>
                                                </StackPanel>
                                            </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,20">
                                            <Button Content="Cancelar" Click="BackToSettingsList_Click" Style="{DynamicResource DevToolsSecondaryButton}" Width="120" Margin="0,0,10,0"/>
                                            <Button Content="Salvar" Click="SaveNgrokSettings_Click" 
                                                Style="{DynamicResource DevToolsPrimaryButton}" Width="120"/>
                                        </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </TabItem>

                    </TabControl>

                    <Border Grid.Row="2"
                            Background="{DynamicResource DevToolsSurface}"
                            BorderBrush="{DynamicResource DevToolsBrushBorder}"
                            BorderThickness="0,1,0,0"
                            Padding="20,0,0,0">
                        <Grid IsSharedSizeScope="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="MainFooterButton"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="MainStatusText"
                                       Grid.Column="0"
                                       Text="DevTools Hub pronto."
                                       Foreground="{DynamicResource DevToolsTextSecondary}"
                                       FontSize="{DynamicResource DevToolsFontSize.Status}"
                                       VerticalAlignment="Center"/>

                            <Button Grid.Column="1"
                                    Content="Abrir Jobs"
                                    Tag="Jobs"
                                    Click="NavButton_Click"
                                    Style="{DynamicResource DevToolsPrimaryButton}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </materialDesign:DialogHost>
</Window>








