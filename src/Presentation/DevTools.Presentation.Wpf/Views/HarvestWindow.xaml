<Window x:Class="DevTools.Presentation.Wpf.Views.HarvestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        Title="DevTools - Harvest"
        Width="900"
        Height="540"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource DevToolsWindowBackground}">
    <Border BorderBrush="{StaticResource DevToolsBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource DevToolsWindowBackground}">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="Header"
                    Grid.Row="0"
                    Background="{StaticResource DevToolsSurface}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel Margin="10,0">
                    <TextBlock Text="Harvest"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource DevToolsFontSize.SectionTitle}"
                               Foreground="{StaticResource DevToolsTextPrimary}"/>
                    <Button Content="X"
                            Width="28"
                            Height="24"
                            DockPanel.Dock="Right"
                            Margin="8,8,0,8"
                            Click="Cancel_Click"
                            Style="{StaticResource DevToolsSecondaryButton}"/>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="0,12,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <c:ProfileSelector x:Name="ProfileSelector"
                                       ToolName="harvest"
                                       Margin="0,0,0,12"/>

                    <TextBlock Text="Diretório de origem"
                               Foreground="{StaticResource DevToolsTextSecondary}"/>
                    <c:PathSelector x:Name="SourcePathSelector"
                                    Margin="0,4,0,8"/>

                    <TextBlock Text="Diretório de saída"
                               Foreground="{StaticResource DevToolsTextSecondary}"/>
                    <c:PathSelector x:Name="OutputPathSelector"
                                    Margin="0,4,0,8"/>

                    <TextBlock Text="Config JSON (opcional)"
                               Foreground="{StaticResource DevToolsTextSecondary}"/>
                    <c:PathSelector x:Name="ConfigPathSelector"
                                    Margin="0,4,0,8"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Score mínimo"
                                       Foreground="{StaticResource DevToolsTextSecondary}"/>
                            <TextBox x:Name="MinScoreBox"
                                     Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,0,0" VerticalAlignment="Bottom">
                            <CheckBox x:Name="CopyFilesCheck"
                                      Content="Copiar arquivos para saída"
                                      Foreground="{StaticResource DevToolsTextSecondary}"/>
                        </StackPanel>
                    </Grid>

                    <CheckBox x:Name="RememberSettingsCheck"
                              Margin="0,8,0,0"
                              Content="Lembrar configurações desta ferramenta"
                              Foreground="{StaticResource DevToolsTextSecondary}"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{StaticResource DevToolsSurface}"
                        BorderBrush="{StaticResource DevToolsBorder}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8">
                    <c:RunSummaryControl x:Name="RunSummary"/>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Executar Harvest"
                        Width="140"
                        Click="Run_Click"
                        Style="{StaticResource DevToolsPrimaryButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

