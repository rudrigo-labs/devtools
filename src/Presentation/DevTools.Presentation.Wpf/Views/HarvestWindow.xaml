<Window x:Class="DevTools.Presentation.Wpf.Views.HarvestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        mc:Ignorable="d"
        Title="Coletor de Arquivos" Height="640" Width="900" WindowStartupLocation="CenterScreen"
        Style="{StaticResource ModernWindowStyle}">

    <c:DevToolsToolFrame Title="Coletor de Arquivos"
                         HelpText="Copia arquivos filtrados por regras para pasta de saída"
                         PrimaryButtonContent="EXECUTAR HARVEST"
                         SecondaryButtonContent="Cancelar"
                         PrimaryButtonClick="Run_Click"
                         SecondaryButtonClick="Cancel_Click"
                         CloseButtonClick="Cancel_Click">

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
        <StackPanel Margin="0,10,0,0">
            <TextBlock Text="Configuração" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,15"/>
                
                <c:PathSelector x:Name="SourcePathSelector" Title="Diretório de Origem (Projeto para Análise)" 
                                IsFolderPicker="True" Margin="0,0,0,20"/>
                
                <c:PathSelector x:Name="OutputPathSelector" Title="Diretório de Destino (Local de Backup)" 
                                IsFolderPicker="True"/>

                <c:PathSelector x:Name="ConfigPathSelector" Title="Arquivo de Configuração (Opcional)" 
                                IsFolderPicker="False" Margin="0,20,0,0"/>

                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                     <StackPanel Margin="0,0,20,0">
                        <Label Content="Pontuação Mínima"/>
                        <TextBox x:Name="MinScoreBox" Text="0" Width="100" Style="{StaticResource ModernTextBoxStyle}"/>
                     </StackPanel>
                     
                     <CheckBox x:Name="CopyFilesCheck" Content="Copiar Arquivos" IsChecked="True" VerticalAlignment="Bottom" Margin="0,0,20,5"/>
                     <CheckBox x:Name="RememberSettingsCheck" Content="Lembrar configurações" IsChecked="False" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
                </StackPanel>
                                
                <TextBlock Text="Esta ferramenta analisará o diretório de origem em busca de classes auxiliares e utilitários (Helpers, Utils), pontuando-os com base em regras predefinidas, e copiará os arquivos úteis para o diretório de destino." 
                           TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,20,0,0" LineHeight="18"/>
                
                <c:RunSummaryControl x:Name="RunSummary" Margin="0,20,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </c:DevToolsToolFrame>
</Window>
