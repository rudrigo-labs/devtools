<Window x:Class="DevTools.Presentation.Wpf.Views.HarvestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        mc:Ignorable="d"
        Title="Coletor de Arquivos (Harvest)"
        Height="720"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Style="{StaticResource ModernWindowStyle}">

    <c:DevToolsToolFrame Title="Coletor de Arquivos"
                         HelpText="Copia arquivos filtrados por regras para pasta de saida."
                         PrimaryButtonContent="Executar"
                         SecondaryButtonContent="Cancelar"
                         PrimaryButtonClick="Run_Click"
                         SecondaryButtonClick="Cancel_Click"
                         CloseButtonClick="Cancel_Click">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Configuracao"
                           FontSize="{DynamicResource DevToolsFontSize.SectionTitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           Margin="0,0,0,16"/>

                <c:PathSelector x:Name="SourcePathSelector"
                                Title="Diretorio de Origem (Projeto)"
                                IsFolderPicker="True"
                                Margin="0,0,0,16"/>

                <c:PathSelector x:Name="OutputPathSelector"
                                Title="Diretorio de Destino (Backup)"
                                IsFolderPicker="True"
                                Margin="0,0,0,16"/>

                <c:PathSelector x:Name="ConfigPathSelector"
                                Title="Arquivo de Configuracao (Opcional)"
                                IsFolderPicker="False"
                                Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Pontuacao Minima"
                                   Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="MinScoreBox"
                                 Text="0"
                                 Width="120"
                                 Style="{StaticResource DevToolsTextInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                        <CheckBox x:Name="CopyFilesCheck"
                                  Content="Copiar arquivos"
                                  IsChecked="True"
                                  Style="{StaticResource DevToolsCheckBox}"
                                  Margin="0,0,0,8"/>
                        <CheckBox x:Name="RememberSettingsCheck"
                                  Content="Lembrar configuracoes"
                                  IsChecked="False"
                                  Style="{StaticResource DevToolsCheckBox}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Analisa o diretorio de origem, pontua arquivos por regras configuradas e copia os itens relevantes para o diretorio de destino."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="{DynamicResource DevToolsFontSize.Status}"
                           Margin="0,0,0,16"/>

                <c:RunSummaryControl x:Name="RunSummary"/>
            </StackPanel>
        </ScrollViewer>
    </c:DevToolsToolFrame>
</Window>
