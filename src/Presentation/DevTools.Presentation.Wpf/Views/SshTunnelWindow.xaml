<Window x:Class="DevTools.Presentation.Wpf.Views.SshTunnelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        mc:Ignorable="d"
        Title="Tunel SSH"
        Height="780"
        Width="1120"
        MinWidth="1020"
        MinHeight="700"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Style="{StaticResource ModernWindowStyle}">

    <c:DevToolsToolFrame x:Name="MainFrame"
                         Title="Gerenciador de Tuneis SSH"
                         HelpText="Faz port-forward local para um destino remoto via bastion."
                         StatusText="Parado"
                         PrimaryButtonContent="Conectar"
                         SecondaryButtonContent="Fechar"
                         PrimaryButtonClick="ToggleTunnel_Click"
                         SecondaryButtonClick="CloseButton_Click"
                         CloseButtonClick="CloseButton_Click">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Conexao SSH"
                           FontSize="{DynamicResource DevToolsFontSize.SectionTitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Host SSH (Bastion)" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="SshHostInput" Style="{StaticResource DevToolsTextInput}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Porta SSH" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="SshPortInput" Style="{StaticResource DevToolsTextInput}"/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Usuario SSH" Style="{StaticResource DevToolsInputLabel}"/>
                    <TextBox x:Name="SshUserInput" Style="{StaticResource DevToolsTextInput}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Arquivo de Identidade (Chave Privada)" Style="{StaticResource DevToolsInputLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 x:Name="IdentityFileInput"
                                 Style="{StaticResource DevToolsTextInput}"/>

                        <Button Grid.Column="2"
                                Content="Procurar"
                                Click="BrowseKey_Click"
                                Style="{StaticResource DevToolsSecondaryButton}"/>
                    </Grid>
                </StackPanel>

                <Separator Margin="0,0,0,16"/>

                <TextBlock Text="Mapeamento do Tunel"
                           FontSize="{DynamicResource DevToolsFontSize.SectionTitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           Margin="0,0,0,16"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Local (Sua Maquina)"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,12"/>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Host Local (Bind)" Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="LocalBindInput" Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Porta Local" Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="LocalPortInput" Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Remoto (Destino)"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,12"/>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Host Remoto" Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="RemoteHostInput" Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Porta Remota" Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="RemotePortInput" Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </c:DevToolsToolFrame>
</Window>

