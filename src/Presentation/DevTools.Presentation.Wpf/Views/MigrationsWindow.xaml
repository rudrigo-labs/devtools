<Window x:Class="DevTools.Presentation.Wpf.Views.MigrationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        Title="DevTools - Migrations"
        Width="900"
        Height="540"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource DevToolsWindowBackground}">
    <Border BorderBrush="{StaticResource DevToolsBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource DevToolsWindowBackground}">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="Header"
                    Grid.Row="0"
                    Background="{StaticResource DevToolsSurface}"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel Margin="10,0">
                    <TextBlock Text="Migrations"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource DevToolsFontSize.SectionTitle}"
                               Foreground="{StaticResource DevToolsTextPrimary}"/>
                    <Button Content="X"
                            Width="28"
                            Height="24"
                            DockPanel.Dock="Right"
                            Margin="8,8,0,8"
                            Click="Close_Click"
                            Style="{StaticResource DevToolsSecondaryButton}"/>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="0,12,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <c:ProfileSelector x:Name="ProfileSelector"
                                       ToolName="migrations"
                                       Margin="0,0,0,12"/>

                    <TextBlock Text="Projeto raiz (Root)"
                               Foreground="{StaticResource DevToolsTextSecondary}"/>
                    <c:PathSelector x:Name="ProjectSelector"
                                    Margin="0,4,0,8"/>

                    <TextBlock Text="Startup project"
                               Foreground="{StaticResource DevToolsTextSecondary}"/>
                    <c:PathSelector x:Name="StartupSelector"
                                    Margin="0,4,0,8"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Ação"
                                       Foreground="{StaticResource DevToolsTextSecondary}"/>
                            <ComboBox x:Name="ActionCombo"
                                      SelectionChanged="ActionCombo_SelectionChanged"
                                      Style="{StaticResource DevToolsComboBox}">
                                <ComboBoxItem Content="Add Migration" Tag="Add"/>
                                <ComboBoxItem Content="Update Database" Tag="Update"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,0,0">
                            <TextBlock Text="Provider"
                                       Foreground="{StaticResource DevToolsTextSecondary}"/>
                            <ComboBox x:Name="ProviderCombo"
                                      Style="{StaticResource DevToolsComboBox}">
                                <ComboBoxItem Content="SqlServer" Tag="SqlServer"/>
                                <ComboBoxItem Content="Sqlite" Tag="Sqlite"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="MigrationNamePanel" Margin="0,8,0,0">
                        <TextBlock Text="Nome da Migration"
                                   Foreground="{StaticResource DevToolsTextSecondary}"/>
                        <TextBox x:Name="MigrationNameInput"
                                 Style="{StaticResource DevToolsTextInput}"/>
                    </StackPanel>

                    <TextBlock Text="DbContext (Namespace.Classe)"
                               Margin="0,8,0,4"
                               Foreground="{StaticResource DevToolsTextSecondary}"/>
                    <TextBox x:Name="DbContextInput"
                             Style="{StaticResource DevToolsTextInput}"/>

                    <CheckBox x:Name="DryRunCheck"
                              Margin="0,8,0,0"
                              Content="Dry-run (mostra comando sem executar)"
                              Foreground="{StaticResource DevToolsTextSecondary}"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{StaticResource DevToolsSurface}"
                        BorderBrush="{StaticResource DevToolsBorder}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="OutputText"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Hidden"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource DevToolsTextPrimary}"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Executar"
                        Width="120"
                        Click="Execute_Click"
                        Style="{StaticResource DevToolsPrimaryButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

