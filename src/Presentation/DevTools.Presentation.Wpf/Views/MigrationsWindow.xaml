<Window x:Class="DevTools.Presentation.Wpf.Views.MigrationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:components="clr-namespace:DevTools.Presentation.Wpf.Components"
        xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components"
        mc:Ignorable="d"
        Title="EF Core Migrations" Height="640" Width="900" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <c:DevToolsToolFrame x:Name="MainFrame"
                         Title="EF Core Migrations"
                         HelpText="Cria/aplica migrations para contextos EF Core."
                         PrimaryButtonContent="Executar comando"
                         SecondaryButtonContent="Cancelar"
                         PrimaryButtonClick="Execute_Click"
                         SecondaryButtonClick="Close_Click"
                         CloseButtonClick="Close_Click">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                
                <!-- Caminhos -->
                <components:PathSelector x:Name="ProjectSelector" 
                                     Title="Pasta Raiz do Projeto (Onde está o .csproj)"
                                     IsFolderPicker="True"
                                     Margin="0,0,0,15"/>

                <components:PathSelector x:Name="StartupSelector" 
                                     Title="Startup Project (API/Web)"
                                     IsFolderPicker="True"
                                     Margin="0,0,0,15"/>

                <!-- Configuração -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Ação -->
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Ação" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ActionCombo" SelectionChanged="ActionCombo_SelectionChanged" SelectedIndex="0" Style="{StaticResource ModernComboBoxStyle}" Background="{DynamicResource ControlBackgroundBrush}">
                            <ComboBoxItem Content="Add Migration" Tag="Add"/>
                            <ComboBoxItem Content="Update Database" Tag="Update"/>
                        </ComboBox>
                    </StackPanel>
                    
                    <!-- Provider -->
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Provider" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ProviderCombo" SelectedIndex="0" Style="{StaticResource ModernComboBoxStyle}" Background="{DynamicResource ControlBackgroundBrush}">
                            <ComboBoxItem Content="SQL Server" Tag="SqlServer"/>
                            <ComboBoxItem Content="SQLite" Tag="Sqlite"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Campos Específicos -->
                <StackPanel x:Name="MigrationNamePanel" Margin="0,0,0,15">
                    <TextBlock Text="Nome da Migration" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,5"/>
                    <TextBox x:Name="MigrationNameInput" Style="{StaticResource ModernTextBoxStyle}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="DbContext Full Name (Opcional)" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,5"/>
                    <TextBox x:Name="DbContextInput" ToolTip="Ex: MyProject.Data.AppDbContext" Style="{StaticResource ModernTextBoxStyle}"/>
                </StackPanel>

                <CheckBox x:Name="DryRunCheck" Content="Dry Run (Gerar comando sem executar)" Margin="0,5,0,15"/>

                <!-- Output Area -->
                <Expander IsExpanded="True" BorderBrush="{DynamicResource BorderBrush}">
                    <Expander.Header>
                        <TextBlock Text="Log de Saída" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </Expander.Header>
                    <TextBox x:Name="OutputText" 
                             Height="100" 
                             TextWrapping="Wrap" 
                             IsReadOnly="True" 
                             FontFamily="Consolas"
                             FontSize="12"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource ModernTextBoxStyle}"/>
                </Expander>

            </StackPanel>
        </ScrollViewer>
    </c:DevToolsToolFrame>
</Window>
