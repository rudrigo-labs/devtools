<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components">
    <Style TargetType="{x:Type c:DevToolsToolFrame}">
        <Setter Property="Background" Value="{DynamicResource DevToolsWindowBackground}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type c:DevToolsToolFrame}">
                    <Border BorderBrush="{DynamicResource DevToolsBrushBorder}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Background="{TemplateBinding Background}"
                            ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="{DynamicResource DevToolsHeaderHeight}"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="{DynamicResource DevToolsFooterHeight}"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Grid.Row="0"
                                    x:Name="PART_Header"
                                    Background="{DynamicResource DevToolsSurface}"
                                    BorderBrush="{DynamicResource DevToolsBrushBorder}"
                                    BorderThickness="0,0,0,1"
                                    Padding="20,0">
                                <DockPanel>
                                    <Button x:Name="PART_CloseButton"
                                            Content="X"
                                            DockPanel.Dock="Right"
                                            Style="{DynamicResource IconButtonStyle}"
                                            FontSize="14"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="10,0,0,0"
                                            Width="30" Height="30"/>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{TemplateBinding Title}"
                                                   FontSize="{DynamicResource DevToolsFontSize.WindowTitle}"
                                                   Foreground="{DynamicResource DevToolsTextPrimary}"
                                                   FontWeight="SemiBold"/>
                                        
                                        <Border x:Name="StatusBadge" 
                                                Margin="15,0,0,0" 
                                                Padding="8,2" 
                                                CornerRadius="10"
                                                Background="{DynamicResource DevToolsStatusIdle}"
                                                Visibility="Collapsed">
                                            <TextBlock Text="{TemplateBinding StatusText}"
                                                       Foreground="White"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- Content (no forced scroll - content handles scrolling) -->
                            <Grid Grid.Row="1"
                                  Margin="{DynamicResource DevToolsContentMargin}">
                                <ContentPresenter MaxWidth="{DynamicResource DevToolsContentMaxWidth}"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"/>
                            </Grid>

                            <!-- Action Bar -->
                            <Border Grid.Row="2"
                                    Background="{DynamicResource DevToolsSurface}"
                                    BorderBrush="{DynamicResource DevToolsBrushBorder}"
                                    BorderThickness="0,1,0,0"
                                    Padding="20,0,0,0">
                                <Grid IsSharedSizeScope="True">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="ActionButtonWidth"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="ActionButtonWidth"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{TemplateBinding HelpText}"
                                               Foreground="{DynamicResource DevToolsTextSecondary}"
                                               FontSize="{DynamicResource DevToolsFontSize.Label}"
                                               VerticalAlignment="Center"/>

                                    <Button Grid.Column="1"
                                            x:Name="PART_SecondaryButton"
                                            Content="{TemplateBinding SecondaryButtonContent}"
                                            Command="{TemplateBinding SecondaryCommand}"
                                            Style="{DynamicResource DevToolsSecondaryButton}"/>

                                    <Button Grid.Column="3"
                                            x:Name="PART_PrimaryButton"
                                            Content="{TemplateBinding PrimaryButtonContent}"
                                            Command="{TemplateBinding PrimaryCommand}"
                                            Style="{DynamicResource DevToolsPrimaryButton}"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="StatusText" Value="{x:Null}">
                            <Setter TargetName="StatusBadge" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding StatusText, RelativeSource={RelativeSource Self}}" Value="">
                            <Setter TargetName="StatusBadge" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding StatusText, RelativeSource={RelativeSource Self}, Converter={x:Static c:StringVisibilityConverter.Instance}}" Value="Visible">
                            <Setter TargetName="StatusBadge" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

