<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:c="clr-namespace:DevTools.Presentation.Wpf.Components">
    
    <!-- Palette -->
    <Color x:Key="WindowBackgroundColor">#1E1E1E</Color>
    <Color x:Key="ControlBackgroundColor">#2D2D2D</Color>
    <Color x:Key="ControlHighlightColor">#3D3D3D</Color>
    <Color x:Key="PrimaryTextColor">#E0E0E0</Color>
    <Color x:Key="SecondaryTextColor">#A0A0A0</Color>
    <Color x:Key="AccentColor">#007ACC</Color>
    <Color x:Key="AccentHoverColor">#0098FF</Color>
    <Color x:Key="ErrorColor">#FF4444</Color>
    <Color x:Key="BorderColor">#333333</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{StaticResource ControlBackgroundColor}"/>
    <SolidColorBrush x:Key="ControlHighlightBrush" Color="{StaticResource ControlHighlightColor}"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <!-- Modern Button Style (Primary) -->
    <Style x:Key="ModernButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                            CornerRadius="6" 
                            Padding="{TemplateBinding Padding}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.98" ScaleY="0.98" CenterX="0.5" CenterY="0.5"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                            <Setter Property="Cursor" Value="No"/>
                            <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Alias for compatibility -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}"/>

    <!-- Danger Button Style (Red) -->
    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
        <Setter Property="Background" Value="{StaticResource ErrorColor}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                            CornerRadius="6" 
                            Padding="{TemplateBinding Padding}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FF6666"/>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.98" ScaleY="0.98" CenterX="0.5" CenterY="0.5"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                            <Setter Property="Cursor" Value="No"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary Button Style (Outlined) -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ControlHighlightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Padding" Value="15,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                            CornerRadius="6" 
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource ControlHighlightBrush}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource SecondaryTextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Icon Button Style -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource ControlHighlightBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Default Button: Secondary -->
    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}"/>

    
    <!-- Modern TextBox Style -->
    <Style x:Key="ModernTextBoxStyle" TargetType="{x:Type TextBox}">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>

        <!-- conforto + padrão -->
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="CaretBrush" Value="White"/>

        <!-- se tiver scroll, já usa o estilo bonito -->
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.65"/>
            </Trigger>
            <Trigger Property="IsReadOnly" Value="True">
                <Setter Property="Opacity" Value="0.9"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ScrollBar moderno (evita o "IE scrollbar") -->
    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Width" Value="10"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0" IsHitTestVisible="False"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Height="40">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border CornerRadius="5"
                                                    Background="{StaticResource ControlHighlightBrush}"
                                                    Opacity="0.75"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0" IsHitTestVisible="False"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Track" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ScrollViewer padrão -->
    <Style TargetType="{x:Type ScrollViewer}">
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <!-- Dark dropdown for ComboBox -->
    <SolidColorBrush x:Key="DropdownBackgroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="DropdownForegroundBrush" Color="#E0E0E0"/>

    <!-- Modern ComboBox Style -->
    <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>

        <!-- Padrão visual igual ao TextBox -->
        <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>

                        <!-- Caixa principal -->
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">

                            <Grid>

                                <!-- Texto selecionado -->
                                <ContentPresenter x:Name="ContentSite"
                                                  Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>

                                <!-- Editable -->
                                <TextBox x:Name="PART_EditableTextBox"
                                         Visibility="Hidden"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{TemplateBinding Foreground}"
                                         FontSize="{TemplateBinding FontSize}"
                                         Padding="0"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"/>

                                <!-- Arrow -->
                                <Path Width="10"
                                      Height="6"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,14,0"
                                      Fill="{TemplateBinding Foreground}"
                                      Data="M 0 0 L 5 5 L 10 0 Z"/>
                            </Grid>
                        </Border>

                        <!-- Área clicável -->
                        <ToggleButton Background="Transparent"
                                      BorderThickness="0"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      Focusable="False"/>

                        <!-- Popup -->
                        <Popup x:Name="Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade">

                            <Border Margin="0,6,0,0"
                                    Background="{StaticResource ControlBackgroundBrush}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">

                                <ScrollViewer MaxHeight="250">
                                    <ItemsPresenter/>
                                </ScrollViewer>

                            </Border>
                        </Popup>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border" Property="Opacity" Value="0.55"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource DropdownForegroundBrush}"/>
        <Setter Property="Padding" Value="10,6"/>
    </Style>

    <!-- Alias for compatibility -->
    <Style x:Key="InputStyle" TargetType="TextBox" BasedOn="{StaticResource ModernTextBoxStyle}"/>

    <!-- Default TextBox -->
    <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBoxStyle}"/>

    <!-- Default Label -->
    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
        <Setter Property="Margin" Value="0,0,0,5"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- Default CheckBox -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- Tool Card Style used in Dashboard/Settings/Tools tabs -->
    <Style x:Key="ToolCardStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource DevToolsTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DevToolsBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="0,0,15,15"/>
        <Setter Property="Height" Value="140"/>
        <Setter Property="Width" Value="200"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <StackPanel Margin="15">
                            <Path Data="{TemplateBinding Tag}"
                                  Style="{DynamicResource IconPathStyle}"
                                  HorizontalAlignment="Left"
                                  Margin="0,0,0,15"/>
                            
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontSize="{StaticResource DevToolsFontSize.SectionTitle}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,5"/>
                            
                            <TextBlock Text="{Binding ToolTip, RelativeSource={RelativeSource TemplatedParent}}" 
                                       FontSize="12"
                                       Foreground="{StaticResource DevToolsTextSecondary}"
                                       TextWrapping="Wrap"
                                       MaxHeight="40"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource DevToolsSurface}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource DevToolsAccent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Window Style (Transparent/Floating) -->
    <Style x:Key="ModernWindowStyle" TargetType="Window">
        <Setter Property="WindowStyle" Value="None"/>
        <Setter Property="AllowsTransparency" Value="True"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="ResizeMode" Value="NoResize"/>
    </Style>

    <!-- Context Menu Style -->
    <Style x:Key="DarkContextMenuStyle" TargetType="{x:Type ContextMenu}">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Grid.IsSharedSizeScope" Value="true" />
        <Setter Property="HasDropShadow" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border x:Name="Border" Background="#1E1E1E" BorderThickness="1" BorderBrush="#333333" Padding="2">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.4" Color="Black"/>
                        </Border.Effect>
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasDropShadow" Value="true">
                            <Setter TargetName="Border" Property="Padding" Value="0,3,0,3" />
                            <Setter TargetName="Border" Property="CornerRadius" Value="4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Menu Item Style -->
    <Style x:Key="DarkMenuItemStyle" TargetType="{x:Type MenuItem}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Header" Value="{Binding Path=Header}" />
        <Setter Property="Command" Value="{Binding Path=Command}" />
        <Setter Property="Foreground" Value="#E0E0E0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Border x:Name="Border" Padding="10,5,10,5" BorderThickness="0" Background="Transparent" SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Icon" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut" />
                                <ColumnDefinition Width="13" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="Icon" Margin="6,0,6,0" VerticalAlignment="Center" ContentSource="Icon" />
                            <ContentPresenter x:Name="HeaderHost" Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            <TextBlock x:Name="InputGestureText" Grid.Column="2" Text="{TemplateBinding InputGestureText}" Margin="5,2,2,2" DockPanel.Dock="Right" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="true">
                            <Setter Property="Background" TargetName="Border" Value="#3D3D3D"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter Property="Foreground" Value="#888888"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DarkSeparatorStyle" TargetType="{x:Type Separator}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border Height="1" Background="#333333" Margin="0,4,0,4"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================= -->
    <!-- COMPATIBILIDADE LEGADA (DevTools UI Foundation) -->
    <!-- Trazido para suportar componentes como DevToolsToolFrame e Cards -->
    <!-- ================================================================= -->

    <Color x:Key="DevToolsWindowBackgroundColor">#1E1E1E</Color>
    <Color x:Key="DevToolsSurfaceColor">#2D2D2D</Color>
    <Color x:Key="DevToolsBorderColor">#333333</Color>
    <Color x:Key="DevToolsAccentColor">#007ACC</Color>
    <Color x:Key="DevToolsAccentHoverColor">#0098FF</Color>
    <Color x:Key="DevToolsPrimaryTextColor">#E0E0E0</Color>
    <Color x:Key="DevToolsSecondaryTextColor">#A0A0A0</Color>
    <Color x:Key="DevToolsStatusIdleColor">#2D2D2D</Color>
    <Color x:Key="DevToolsStatusOkColor">#1B5E20</Color>
    <Color x:Key="DevToolsStatusErrorColor">#B71C1C</Color>

    <SolidColorBrush x:Key="DevToolsWindowBackground" Color="{StaticResource DevToolsWindowBackgroundColor}"/>
    <SolidColorBrush x:Key="DevToolsSurface" Color="{StaticResource DevToolsSurfaceColor}"/>
    <SolidColorBrush x:Key="DevToolsBorder" Color="{StaticResource DevToolsBorderColor}"/>
    <SolidColorBrush x:Key="DevToolsAccent" Color="{StaticResource DevToolsAccentColor}"/>
    <SolidColorBrush x:Key="DevToolsAccentHover" Color="{StaticResource DevToolsAccentHoverColor}"/>
    <SolidColorBrush x:Key="DevToolsTextPrimary" Color="{StaticResource DevToolsPrimaryTextColor}"/>
    <SolidColorBrush x:Key="DevToolsTextSecondary" Color="{StaticResource DevToolsSecondaryTextColor}"/>
    <SolidColorBrush x:Key="DevToolsStatusIdle" Color="{StaticResource DevToolsStatusIdleColor}"/>
    <SolidColorBrush x:Key="DevToolsStatusOk" Color="{StaticResource DevToolsStatusOkColor}"/>
    <SolidColorBrush x:Key="DevToolsStatusError" Color="{StaticResource DevToolsStatusErrorColor}"/>

    <sys:Double x:Key="DevToolsFontSize.WindowTitle">20</sys:Double>
    <sys:Double x:Key="DevToolsFontSize.SectionTitle">16</sys:Double>
    <sys:Double x:Key="DevToolsFontSize.Label">16</sys:Double>
    <sys:Double x:Key="DevToolsFontSize.Input">16</sys:Double>
    <sys:Double x:Key="DevToolsFontSize.Button">16</sys:Double>
    <sys:Double x:Key="DevToolsFontSize.Status">12</sys:Double>

    <sys:Double x:Key="DevToolsSpacing.LabelToField">8</sys:Double>
    <sys:Double x:Key="DevToolsSpacing.FieldGroup">16</sys:Double>
    <sys:Double x:Key="DevToolsFormMaxWidth">700</sys:Double>
    <sys:Double x:Key="DevToolsActionButtonWidth">180</sys:Double>

    <!-- DevTools Text Input -->
    <Style x:Key="DevToolsTextInput" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource DevToolsWindowBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource DevToolsTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DevToolsBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontSize" Value="{StaticResource DevToolsFontSize.Input}"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DevTools Select Input -->
    <Style x:Key="DevToolsSelectInput" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource DevToolsWindowBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource DevToolsTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DevToolsBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="FontSize" Value="{StaticResource DevToolsFontSize.Input}"/>
        <Setter Property="MinHeight" Value="36"/>
    </Style>

    <!-- DevTools CheckBox -->
    <Style x:Key="DevToolsCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource DevToolsTextPrimary}"/>
        <Setter Property="FontSize" Value="{StaticResource DevToolsFontSize.Input}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- DevTools Primary Button -->
    <Style x:Key="DevToolsPrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource DevToolsAccent}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="FontSize" Value="{StaticResource DevToolsFontSize.Button}"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="MinWidth" Value="{StaticResource DevToolsActionButtonWidth}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource DevToolsAccentHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DevTools Secondary Button -->
    <Style x:Key="DevToolsSecondaryButton" TargetType="Button">
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource DevToolsTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DevToolsBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="18,9"/>
        <Setter Property="FontSize" Value="{StaticResource DevToolsFontSize.Button}"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="MinWidth" Value="{StaticResource DevToolsActionButtonWidth}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource DevToolsSurface}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DevTools Card Button (Dashboard) -->
    <Style x:Key="DevToolsCardButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource DevToolsTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DevToolsBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="10"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource DevToolsSurface}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource DevToolsAccent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DevToolsToolFrame Control Template -->
    <Style TargetType="{x:Type c:DevToolsToolFrame}">
        <Setter Property="Background" Value="{StaticResource DevToolsWindowBackground}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type c:DevToolsToolFrame}">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0"
                                x:Name="PART_Header"
                                Background="{StaticResource DevToolsSurface}"
                                BorderBrush="{StaticResource DevToolsBorder}"
                                BorderThickness="0,0,0,1"
                                Padding="20,14">
                            <DockPanel>
                                <Button x:Name="PART_CloseButton"
                                        Content="✕"
                                        DockPanel.Dock="Right"
                                        Style="{StaticResource IconButtonStyle}"
                                        FontSize="14"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="10,-5,-5,-5"
                                        Width="30" Height="30"/>

                                <TextBlock Text="{TemplateBinding Title}"
                                           FontSize="{StaticResource DevToolsFontSize.WindowTitle}"
                                           Foreground="{StaticResource DevToolsTextPrimary}"
                                           FontWeight="SemiBold"
                                           DockPanel.Dock="Left"/>
                            </DockPanel>
                        </Border>

                        <!-- Content (no forced scroll - content handles scrolling) -->
                        <ContentPresenter Grid.Row="1" Margin="30,20"/>

                        <!-- Action Bar -->
                        <Border Grid.Row="2"
                                Background="{StaticResource DevToolsSurface}"
                                BorderBrush="{StaticResource DevToolsBorder}"
                                BorderThickness="0,1,0,0"
                                Padding="20,10">
                            <Grid IsSharedSizeScope="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="ActionButtonWidth"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="ActionButtonWidth"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{TemplateBinding HelpText}"
                                           Foreground="{StaticResource DevToolsTextSecondary}"
                                           FontSize="{StaticResource DevToolsFontSize.Label}"
                                           VerticalAlignment="Center"/>

                                <Button Grid.Column="1"
                                        x:Name="PART_SecondaryButton"
                                        Content="{TemplateBinding SecondaryButtonContent}"
                                        Command="{TemplateBinding SecondaryCommand}"
                                        Style="{StaticResource DevToolsSecondaryButton}"/>

                                <Button Grid.Column="3"
                                        x:Name="PART_PrimaryButton"
                                        Content="{TemplateBinding PrimaryButtonContent}"
                                        Command="{TemplateBinding PrimaryCommand}"
                                        Style="{StaticResource DevToolsPrimaryButton}"/>
                            </Grid>
                        </Border>

                        <!-- Status Strip -->
                        <Border Grid.Row="3"
                                Background="{StaticResource DevToolsStatusIdle}">
                            <TextBlock Text="{TemplateBinding StatusText}"
                                       Foreground="{StaticResource DevToolsTextPrimary}"
                                       FontSize="{StaticResource DevToolsFontSize.Status}"
                                       VerticalAlignment="Center"
                                       Margin="10,0"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
