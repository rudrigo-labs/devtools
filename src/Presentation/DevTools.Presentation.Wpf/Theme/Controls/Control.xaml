<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style TargetType="Control">
        <Setter Property="BorderBrush" Value="{DynamicResource DevToolsBrushBorder}"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
        <Setter Property="Margin" Value="{DynamicResource DevToolsSpacing.LabelMargin}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="DevToolsInputLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Margin" Value="{DynamicResource DevToolsSpacing.LabelMargin}"/>
    </Style>

    <Style x:Key="DevToolsPageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Light"/>
        <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
        <Setter Property="Margin" Value="0,10,0,20"/>
    </Style>

    <Style x:Key="DevToolsSectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource DevToolsAccent}"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <Style x:Key="DevToolsPanelTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="DevToolsCardTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource DevToolsFontSize.SectionTitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
    </Style>

    <Style TargetType="Expander">
        <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
        <Setter Property="Background" Value="{DynamicResource DevToolsSurface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DevToolsBrushBorder}"/>
    </Style>
</ResourceDictionary>
