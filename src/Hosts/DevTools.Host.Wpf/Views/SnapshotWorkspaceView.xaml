<UserControl x:Class="DevTools.Host.Wpf.Views.SnapshotWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:DevTools.Host.Wpf.Components">

    <c:DevToolsToolFrame x:Name="MainFrame"
                         Title="Snapshot"
                         HelpText="Configurar e executar snapshot no novo padrao."
                         StatusText=""
                         PrimaryButtonContent="Executar"
                         SecondaryButtonContent="Cancelar"
                         PrimaryButtonClick="ExecuteButton_Click"
                         SecondaryButtonClick="CancelButton_Click">
        <Grid Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <c:ActionBarControl Grid.Row="0"
                                x:Name="Actions"
                                ShowNew="True"
                                ShowSave="True"
                                ShowDelete="True"
                                ShowCancel="True"
                                ActionNew="ActionNew_Click"
                                ActionSave="ActionSave_Click"
                                ActionDelete="ActionDelete_Click"
                                ActionCancel="ActionCancel_Click"/>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,4,0,0">
                    <TextBlock Text="Configuracoes salvas"
                               Style="{StaticResource DevToolsCardTitle}"/>
                    <ComboBox x:Name="ConfigurationsCombo"
                              Margin="0,8,0,16"
                              Style="{StaticResource DevToolsSelectInput}"
                              SelectionChanged="ConfigurationsCombo_SelectionChanged"
                              DisplayMemberPath="Name"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nome"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="NameInput"
                                     Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Descricao"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="DescriptionInput"
                                     Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>
                    </Grid>

                    <c:PathSelector x:Name="RootPathSelector"
                                    Title="Pasta do projeto"
                                    IsFolderPicker="True"
                                    Margin="0,0,0,12"/>

                    <c:PathSelector x:Name="OutputBasePathSelector"
                                    Title="Pasta de saida (opcional)"
                                    IsFolderPicker="True"
                                    Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Diretorios ignorados (separados por virgula)"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="IgnoredDirectoriesInput"
                                     Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Tamanho maximo por arquivo (KB)"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="MaxFileSizeKbInput"
                                     Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Formatos de saida"
                               Style="{StaticResource DevToolsCardTitle}"
                               Margin="0,4,0,10"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <CheckBox x:Name="TextCheck"
                                      Content="Texto (.txt)"
                                      Style="{StaticResource DevToolsCheckBox}"
                                      IsChecked="True"
                                      Margin="0,0,0,8"/>
                            <CheckBox x:Name="HtmlCheck"
                                      Content="HTML (.html)"
                                      Style="{StaticResource DevToolsCheckBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <CheckBox x:Name="JsonNestedCheck"
                                      Content="JSON Aninhado"
                                      Style="{StaticResource DevToolsCheckBox}"
                                      Margin="0,0,0,8"/>
                            <CheckBox x:Name="JsonRecursiveCheck"
                                      Content="JSON Recursivo"
                                      Style="{StaticResource DevToolsCheckBox}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <TextBlock x:Name="ExecutionStatusText"
                       Grid.Row="2"
                       Margin="0,10,0,0"
                       Foreground="{DynamicResource DevToolsTextSecondary}"/>
        </Grid>
    </c:DevToolsToolFrame>
</UserControl>
