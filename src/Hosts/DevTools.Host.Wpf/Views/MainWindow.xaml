<Window x:Class="DevTools.Host.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DevTools.Host.Wpf.Views"
        Title="DevTools"
        Width="1320"
        Height="820"
        MinWidth="1080"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource DevToolsWindowBackground}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource DevToolsSurface}"
                BorderBrush="{DynamicResource DevToolsBrushBorder}"
                BorderThickness="0,0,1,0"
                Padding="18">
            <StackPanel>
                <TextBlock Text="DevTools"
                           Style="{StaticResource DevToolsSectionTitle}"/>
                <TextBlock Text="Workspace"
                           Foreground="{DynamicResource DevToolsTextSecondary}"
                           Margin="0,0,0,20"/>

                <Button x:Name="SnapshotNavButton"
                        Content="Snapshot"
                        Height="40"
                        HorizontalContentAlignment="Left"
                        Padding="12,0"
                        Style="{StaticResource DevToolsSecondaryButton}"
                        Click="SnapshotNavButton_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18,18,18,18">
            <views:SnapshotWorkspaceView x:Name="SnapshotWorkspace"/>
        </Grid>
    </Grid>
</Window>
