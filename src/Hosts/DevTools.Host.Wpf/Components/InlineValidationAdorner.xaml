<UserControl x:Class="DevTools.Host.Wpf.Components.InlineValidationAdorner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             IsHitTestVisible="False">
    <Grid>
        <Popup AllowsTransparency="True"
               Placement="Right"
               PlacementTarget="{Binding Target, ElementName=Root}"
               HorizontalOffset="-10"
               VerticalOffset="-8"
               StaysOpen="True"
               IsOpen="{Binding IsAsteriskVisible, ElementName=Root}">
            <Border Style="{StaticResource DevToolsValidationAsteriskBorder}">
                <TextBlock Text="*"
                           Style="{StaticResource DevToolsValidationAsteriskText}" />
            </Border>
        </Popup>

        <Popup AllowsTransparency="True"
               Placement="Bottom"
               PlacementTarget="{Binding Target, ElementName=Root}"
               HorizontalOffset="2"
               VerticalOffset="2"
               StaysOpen="True"
               IsOpen="{Binding IsMessageVisible, ElementName=Root}">
            <Border Style="{StaticResource DevToolsValidationMessageBorder}">
                <TextBlock Text="{Binding Message, ElementName=Root}"
                           Style="{StaticResource DevToolsValidationMessageText}" />
            </Border>
        </Popup>
    </Grid>
</UserControl>


