<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="ActionBarButton" TargetType="Button">
        <Setter Property="Width" Value="100"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="Background" Value="{DynamicResource DevToolsSurface}"/>
        <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DevToolsBrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>
