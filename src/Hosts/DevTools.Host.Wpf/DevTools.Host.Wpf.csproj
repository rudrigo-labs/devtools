    <PackageReference Include="H.NotifyIcon.Wpf" Version="2.1.2" />
    <PackageReference Include="MaterialDesignColors" Version="5.3.0" />
    <PackageReference Include="MaterialDesignThemes" Version="5.3.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Core\DevTools.Core\DevTools.Core.csproj" />
    <ProjectReference Include="..\..\Infrastructure\DevTools.Infrastructure\DevTools.Infrastructure.csproj" />
    <ProjectReference Include="..\..\Tools\DevTools.Organizer\DevTools.Organizer.csproj" />
    <ProjectReference Include="..\..\Tools\DevTools.Harvest\DevTools.Harvest.csproj" />
    <ProjectReference Include="..\..\Tools\DevTools.Notes\DevTools.Notes.csproj" />
    <ProjectReference Include="..\..\Tools\DevTools.Image\DevTools.Image.csproj" />
    <ProjectReference Include="..\..\Tools\DevTools.Rename\DevTools.Rename.csproj" />
    <ProjectReference Include="..\..\Tools\DevTools.Snapshot\DevTools.Snapshot.csproj" />
    <ProjectReference Include="..\..\Tools\DevTools.Utf8Convert\DevTools.Utf8Convert.csproj" />
    <ProjectReference Include="..\..\Tools\DevTools.SSHTunnel\DevTools.SSHTunnel.csproj" />
    <ProjectReference Include="..\..\Tools\DevTools.Ngrok\DevTools.Ngrok.csproj" />
    <ProjectReference Include="..\..\Tools\DevTools.SearchText\DevTools.SearchText.csproj" />
    <ProjectReference Include="..\..\Tools\DevTools.Migrations\DevTools.Migrations.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="app.ico">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
