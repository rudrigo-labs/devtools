<UserControl x:Class="DevTools.Host.Wpf.Views.SnapshotWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:DevTools.Host.Wpf.Components">

    <Grid x:Name="WorkspaceRoot" Margin="0">
        <Grid HorizontalAlignment="Stretch"
              VerticalAlignment="Top"
              Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ==================== TOOL HEADER ==================== -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Snapshot"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DevToolsTextPrimary}"/>
                <TextBlock Text="Gera um snapshot textual completo do projeto para uso com assistentes de IA."
                           Foreground="{DynamicResource DevToolsTextSecondary}"
                           FontSize="12"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
                <Border Height="1"
                        Background="{DynamicResource DevToolsBrushBorder}"
                        Margin="0,10,0,0"/>
            </StackPanel>

            <!-- ==================== ACTION BAR ==================== -->
            <c:ActionBarControl Grid.Row="1"
                                x:Name="Actions"
                                ShowNew="True"
                                ShowSave="True"
                                ShowDelete="True"
                                ShowCancel="True"
                                ActionNew="ActionNew_Click"
                                ActionSave="ActionSave_Click"
                                ActionDelete="ActionDelete_Click"
                                ActionCancel="ActionCancel_Click"/>

            <!-- ==================== TOOL BODY ==================== -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,4,0,0">

                    <!-- Seletor de configuração (condicional) -->
                    <StackPanel x:Name="ConfigurationsLabel"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Configurações salvas"
                                   Style="{StaticResource DevToolsCardTitle}"/>
                        <Border Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Width="16" Height="16"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource DevToolsTextSecondary}"
                                ToolTipService.InitialShowDelay="200"
                                ToolTipService.ShowDuration="30000">
                            <Border.ToolTip>
                                <ToolTip Placement="Right" MaxWidth="360">
                                    <TextBlock TextWrapping="Wrap"
                                               Text="Escolha uma configuração salva ou selecione 'Configurar manualmente' para preencher os campos e executar sem usar configuração salva."/>
                                </ToolTip>
                            </Border.ToolTip>
                            <TextBlock Text="?"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource DevToolsTextSecondary}"/>
                        </Border>
                    </StackPanel>
                    <ComboBox x:Name="ConfigurationsCombo"
                              Margin="0,8,0,16"
                              Style="{StaticResource DevToolsSelectInput}"
                              SelectionChanged="ConfigurationsCombo_SelectionChanged"
                              DisplayMemberPath="Name"/>

                    <!-- ===== Caminhos ===== -->
                    <c:PathSelector x:Name="RootPathSelector"
                                    Title="Pasta do projeto *"
                                    IsFolderPicker="True"
                                    Margin="0,0,0,12"/>

                    <c:PathSelector x:Name="OutputBasePathSelector"
                                    Title="Pasta de saída *"
                                    IsFolderPicker="True"
                                    Margin="0,0,0,12"/>

                    <!-- ===== Filtros de arquivo ===== -->
                    <TextBlock Text="Filtros de arquivo"
                               Style="{StaticResource DevToolsCardTitle}"
                               Margin="0,4,0,10"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Diretórios ignorados (separados por vírgula)"
                                   Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="IgnoredDirectoriesInput"
                                 Style="{StaticResource DevToolsTextInput}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Extensões ignoradas (separadas por vírgula)"
                                   Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="IgnoredExtensionsInput"
                                 Style="{StaticResource DevToolsTextInput}"
                                 ToolTip=".dll, .exe, .png, .jpg ..."/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Extensões permitidas (separadas por vírgula)"
                                   Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="IncludedExtensionsInput"
                                 Style="{StaticResource DevToolsTextInput}"
                                 ToolTip="Deixe vazio para processar todas as não ignoradas. Ex: .cs, .json, .md"/>
                    </StackPanel>

                    <!-- ===== Validação ===== -->
                    <TextBlock Text="Validação"
                               Style="{StaticResource DevToolsCardTitle}"
                               Margin="0,4,0,10"/>

                    <CheckBox x:Name="ValidateDotNetCheck"
                              Content="Validar projeto .NET (exige .csproj, .sln ou .slnx na pasta raiz)"
                              Style="{StaticResource DevToolsCheckBox}"
                              IsChecked="True"
                              Margin="0,0,0,12"
                              ToolTip="Antes de executar, verifica se existe um arquivo .csproj, .sln ou .slnx na pasta raiz. Desmarque para executar em qualquer diretório."/>

                    <!-- ===== Campos de configuração (modo Configuração) ===== -->
                    <Grid x:Name="ConfigurationMetadataSection"
                          Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nome"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="NameInput"
                                     Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Descrição"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="DescriptionInput"
                                     Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>
                    </Grid>

                    <!-- ===== Formatos de saída ===== -->
                    <TextBlock Text="Formatos de saída"
                               Style="{StaticResource DevToolsCardTitle}"
                               Margin="0,4,0,10"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <CheckBox x:Name="TextCheck"
                                      Content="Texto (.txt)"
                                      Style="{StaticResource DevToolsCheckBox}"
                                      IsChecked="True"
                                      Margin="0,0,0,8"/>
                            <CheckBox x:Name="HtmlCheck"
                                      Content="HTML (.html)"
                                      Style="{StaticResource DevToolsCheckBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <CheckBox x:Name="JsonNestedCheck"
                                      Content="JSON Aninhado"
                                      Style="{StaticResource DevToolsCheckBox}"
                                      Margin="0,0,0,8"/>
                            <CheckBox x:Name="JsonRecursiveCheck"
                                      Content="JSON Recursivo"
                                      Style="{StaticResource DevToolsCheckBox}"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- ==================== STATUS ==================== -->
            <TextBlock x:Name="ExecutionStatusText"
                       Grid.Row="3"
                       Margin="0,10,0,0"
                       Foreground="{DynamicResource DevToolsTextSecondary}"/>
        </Grid>
    </Grid>
</UserControl>
