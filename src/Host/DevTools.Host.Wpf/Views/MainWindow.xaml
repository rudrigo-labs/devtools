<Window x:Class="DevTools.Host.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DevTools"
        Width="1320"
        Height="820"
        MinWidth="1080"
        MinHeight="700"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <!-- Botão da caption bar -->
        <Style x:Key="ShellCaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource DevToolsTextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DevToolsWindowBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShellCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource ShellCaptionButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DevToolsStatusError}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Botão de navegação lateral (tool) -->
        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource DevToolsTextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0,0,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent">
                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DevToolsWindowBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão de navegação lateral ATIVO -->
        <Style x:Key="SidebarNavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{DynamicResource DevToolsWindowBackground}"
                                BorderThickness="3,0,0,0"
                                BorderBrush="{DynamicResource DevToolsAccent}">
                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão Encerrar — vermelho no hover -->
        <Style x:Key="SidebarNavButtonExitStyle" TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FF4444"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Margin="10"
            Background="{DynamicResource DevToolsWindowBackground}"
            BorderBrush="{DynamicResource DevToolsBrushBorder}"
            BorderThickness="1"
            CornerRadius="8"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- ======================== SIDEBAR ======================== -->
            <Border Grid.Column="0"
                    Grid.RowSpan="3"
                    Background="{DynamicResource DevToolsSurface}"
                    BorderBrush="{DynamicResource DevToolsBrushBorder}"
                    BorderThickness="0,0,1,0"
                    CornerRadius="8,0,0,8">
                <DockPanel>
                    <!-- Logo -->
                    <StackPanel DockPanel.Dock="Top" Margin="16,16,16,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80F;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       Foreground="{DynamicResource DevToolsAccent}"
                                       Margin="0,1,8,0"/>
                            <TextBlock Text="DevTools"
                                       Style="{StaticResource DevToolsSectionTitle}"/>
                        </StackPanel>
                        <TextBlock Text="Ferramentas"
                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                   FontSize="11"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Separador -->
                    <Border DockPanel.Dock="Top"
                            Height="1"
                            Background="{DynamicResource DevToolsBrushBorder}"
                            Margin="0,0,0,8"/>

                    <!-- Itens de navegação -->
                    <StackPanel DockPanel.Dock="Top">
                        <Button x:Name="NavSnapshot"
                                Content="Snapshot"
                                Tag="Snapshot"
                                Style="{StaticResource SidebarNavButtonActiveStyle}"
                                Click="NavButton_Click"/>
                        <Button x:Name="NavRename"
                                Content="Rename"
                                Tag="Rename"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="NavButton_Click"/>
                        <Button x:Name="NavHarvest"
                                Content="Harvest"
                                Tag="Harvest"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="NavButton_Click"/>
                        <Button x:Name="NavImageSplit"
                                Content="Image Split"
                                Tag="ImageSplit"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="NavButton_Click"/>
                        <Button x:Name="NavSearchText"
                                Content="Search Text"
                                Tag="SearchText"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="NavButton_Click"/>
                        <Button x:Name="NavOrganizer"
                                Content="Organizer"
                                Tag="Organizer"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="NavButton_Click"/>
                        <Button x:Name="NavUtf8Convert"
                                Content="UTF-8 Convert"
                                Tag="Utf8Convert"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="NavButton_Click"/>
                        <Button x:Name="NavMigrations"
                                Content="Migrations"
                                Tag="Migrations"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="NavButton_Click"/>
                        <Button x:Name="NavSshTunnel"
                                Content="SSH Tunnel"
                                Tag="SshTunnel"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="NavButton_Click"/>
                        <Button x:Name="NavNgrok"
                                Content="Ngrok"
                                Tag="Ngrok"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="NavButton_Click"/>
                        <Button x:Name="NavNotes"
                                Content="Notes"
                                Tag="Notes"
                                Style="{StaticResource SidebarNavButtonStyle}"
                                Click="NavButton_Click"/>
                    </StackPanel>

                    <!-- Encerrar (fixado na base da sidebar) -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,8">
                        <Border Height="1"
                                Background="{DynamicResource DevToolsBrushBorder}"
                                Margin="0,0,0,8"/>
                        <Button Content="Encerrar"
                                Style="{StaticResource SidebarNavButtonExitStyle}"
                                Click="ExitButton_Click"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ======================== TITLEBAR ======================== -->
            <Grid Grid.Column="1"
                  Grid.Row="0"
                  Background="{DynamicResource DevToolsSurface}"
                  MouseLeftButtonDown="WindowDragArea_MouseLeftButtonDown">
                <Border BorderBrush="{DynamicResource DevToolsBrushBorder}"
                        BorderThickness="0,0,0,1"/>
                <TextBlock x:Name="ActiveToolLabel"
                           Text="Snapshot"
                           Foreground="{DynamicResource DevToolsTextSecondary}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="MinimizeButton"
                            Click="MinimizeButton_Click"
                            Content="&#xE921;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="12"
                            Style="{StaticResource ShellCaptionButtonStyle}"/>
                    <Button x:Name="MaximizeButton"
                            Click="MaximizeButton_Click"
                            Content="&#xE922;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="12"
                            Style="{StaticResource ShellCaptionButtonStyle}"/>
                    <Button x:Name="CloseButton"
                            Click="CloseButton_Click"
                            Content="&#xE8BB;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="12"
                            Style="{StaticResource ShellCloseButtonStyle}"/>
                </StackPanel>
            </Grid>

            <!-- ======================== WORKSPACE ======================== -->
            <Grid Grid.Column="1" Grid.Row="1">
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#141619" Offset="0"/>
                            <GradientStop Color="#0F1113" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <ContentControl x:Name="WorkspaceHost" Margin="20,12,20,12"/>
            </Grid>

            <!-- ======================== FOOTER / STATUS ======================== -->
            <Border Grid.Column="1"
                    Grid.Row="2"
                    Background="{DynamicResource DevToolsSurface}"
                    BorderBrush="{DynamicResource DevToolsBrushBorder}"
                    BorderThickness="0,1,0,0">
                <TextBlock x:Name="MainStatusText"
                           Text="DevTools pronto."
                           Foreground="{DynamicResource DevToolsTextSecondary}"
                           FontSize="{DynamicResource DevToolsFontSize.Status}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,20,0"
                           TextAlignment="Right"/>
            </Border>
        </Grid>
    </Border>
</Window>
