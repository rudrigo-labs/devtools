<Window x:Class="DevTools.Host.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:DevTools.Host.Wpf.Components"
        Title="DevTools"
        Width="1320"
        Height="820"
        MinWidth="1080"
        MinHeight="700"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/app.ico"
        Background="Transparent"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <!-- Botão da caption bar -->
        <Style x:Key="ShellCaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource DevToolsTextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource DevToolsWindowBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShellCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource ShellCaptionButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DevToolsStatusError}"/>
                    <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Botão de navegação lateral (tool) -->
        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource DevToolsTextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0,0,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent">
                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DevToolsWindowBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarSubNavButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="30,0,0,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Botão de navegação lateral ATIVO -->
        <Style x:Key="SidebarNavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{DynamicResource DevToolsWindowBackground}"
                                BorderThickness="3,0,0,0"
                                BorderBrush="{DynamicResource DevToolsAccent}">
                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão Encerrar — vermelho no hover -->
        <Style x:Key="SidebarNavButtonExitStyle" TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FF4444"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Margin="10"
            Background="{DynamicResource DevToolsWindowBackground}"
            BorderBrush="{DynamicResource DevToolsBrushBorder}"
            BorderThickness="1"
            CornerRadius="8"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <!-- ======================== SIDEBAR ======================== -->
            <Border Grid.Column="0"
                    Grid.RowSpan="3"
                    Background="{DynamicResource DevToolsSurface}"
                    BorderBrush="{DynamicResource DevToolsBrushBorder}"
                    BorderThickness="0,0,1,0"
                    CornerRadius="8,0,0,8">
                <DockPanel>
                    <!-- Logo -->
                    <Grid DockPanel.Dock="Top"
                          Height="52"
                          Margin="12,0,12,0">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Image Width="40"
                                   Height="40"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Source="pack://application:,,,/Assets/devtoolslogo-simbolo-ct.png"/>
                            <Image Width="112"
                                   Height="22"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Stretch="Uniform"
                                   SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Source="pack://application:,,,/Assets/devtoolslogo-texto-ct.png"/>
                        </StackPanel>
                    </Grid>

                    <!-- Separador -->
                    <Border DockPanel.Dock="Top"
                            Height="1"
                            Background="{DynamicResource DevToolsBrushBorder}"
                            Margin="0,0,0,8"/>

                    <!-- Itens de navegação -->
                    <StackPanel DockPanel.Dock="Top">
                        <c:SectionExpander x:Name="FerramentasSection" IsExpanded="True">
                            <c:SectionExpander.Header>
                                <TextBlock Text="FERRAMENTAS"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource DevToolsTextSecondary}"/>
                            </c:SectionExpander.Header>
                            <StackPanel>
                                <c:SidebarNavItem x:Name="NavFerramentas"
                                                  Content="Home Ferramentas"
                                                  IconGlyph="&#xE7C3;"
                                                  ToolTip="Abre o painel principal de execução das ferramentas."
                                                  Tag="Ferramentas"
                                                  Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavExecSnapshot" IsSubItem="True" Content="Snapshot" IconGlyph="&#xE7C3;" ToolTip="Gera snapshot do projeto." Tag="Exec:Snapshot" Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavExecRename" IsSubItem="True" Content="Rename" IconGlyph="&#xE8AC;" ToolTip="Renomeia identificadores em lote." Tag="Exec:Rename" Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavExecHarvest" IsSubItem="True" Content="Harvest" IconGlyph="&#xE9D2;" ToolTip="Extrai componentes reutilizáveis do código." Tag="Exec:Harvest" Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavExecImageSplit" IsSubItem="True" Content="Image Split" IconGlyph="&#xE91B;" ToolTip="Recorta componentes de imagem automaticamente." Tag="Exec:ImageSplit" Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavExecSearchText" IsSubItem="True" Content="Search Text" IconGlyph="&#xE721;" ToolTip="Busca texto em arquivos com filtros e regex." Tag="Exec:SearchText" Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavExecOrganizer" IsSubItem="True" Content="Organizer" IconGlyph="&#xE8A1;" ToolTip="Organiza arquivos por categorias." Tag="Exec:Organizer" Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavExecUtf8Convert" IsSubItem="True" Content="UTF8 Convert" IconGlyph="&#xE8D2;" ToolTip="Converte arquivos para UTF-8." Tag="Exec:Utf8Convert" Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavExecMigrations" IsSubItem="True" Content="Migrations" IconGlyph="&#xE895;" ToolTip="Executa comandos de migration." Tag="Exec:Migrations" Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavExecSshTunnel" IsSubItem="True" Content="SSH Tunnel" IconGlyph="&#xE7E8;" ToolTip="Inicia e gerencia túneis SSH." Tag="Exec:SshTunnel" Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavExecNgrok" IsSubItem="True" Content="Ngrok" IconGlyph="&#xE8A5;" ToolTip="Inicia túneis Ngrok." Tag="Exec:Ngrok" Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavExecNotes" IsSubItem="True" Content="Notes" IconGlyph="&#xE70B;" ToolTip="Abre o editor de notas." Tag="Exec:Notes" Click="NavButton_Click"/>
                            </StackPanel>
                        </c:SectionExpander>

                        <c:SectionExpander x:Name="ConfiguracoesSection" IsExpanded="True">
                            <c:SectionExpander.Header>
                                <TextBlock Text="CONFIGURACOES"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource DevToolsTextSecondary}"/>
                            </c:SectionExpander.Header>
                            <StackPanel>
                                <c:SidebarNavItem x:Name="NavConfiguracoes"
                                                  Content="Home Configurações"
                                                  IconGlyph="&#xE895;"
                                                  ToolTip="Abre o painel de configurações persistentes."
                                                  Tag="Configurações"
                                                  Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavCfgSnapshot" IsSubItem="True" Content="Snapshot" IconGlyph="&#xE7C3;" ToolTip="Configura perfis de snapshot." Tag="Cfg:Snapshot" Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavCfgHarvest" IsSubItem="True" Content="Harvest" IconGlyph="&#xE9D2;" ToolTip="Configura perfis de mineração de código." Tag="Cfg:Harvest" Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavCfgOrganizer" IsSubItem="True" Content="Organizer" IconGlyph="&#xE8A1;" ToolTip="Configura categorias e regras do Organizer." Tag="Cfg:Organizer" Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavCfgMigrations" IsSubItem="True" Content="Migrations" IconGlyph="&#xE895;" ToolTip="Configura projetos de migrations." Tag="Cfg:Migrations" Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavCfgSshTunnel" IsSubItem="True" Content="SSH Tunnel" IconGlyph="&#xE7E8;" ToolTip="Configura conexões e túneis SSH." Tag="Cfg:SshTunnel" Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavCfgNgrok" IsSubItem="True" Content="Ngrok" IconGlyph="&#xE8A5;" ToolTip="Configura token e parâmetros do Ngrok." Tag="Cfg:Ngrok" Click="NavButton_Click"/>
                                <c:SidebarNavItem x:Name="NavCfgNotes" IsSubItem="True" Content="Notes" IconGlyph="&#xE70B;" ToolTip="Configura pasta padrão e Google Drive do Notes." Tag="Cfg:Notes" Click="NavButton_Click"/>
                            </StackPanel>
                        </c:SectionExpander>

                        <c:SidebarNavItem Content="Encerrar"
                                          IconGlyph="&#xE8BB;"
                                          ToolTip="Encerra o DevTools."
                                          Click="ExitButton_Click"/>
                    </StackPanel>

                    <!-- Espaçador -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,8"/>
                </DockPanel>
            </Border>

            <!-- ======================== TITLEBAR ======================== -->
            <Grid Grid.Column="1"
                  Grid.Row="0"
                  Background="{DynamicResource DevToolsSurface}"
                  MouseLeftButtonDown="WindowDragArea_MouseLeftButtonDown">
                <Border BorderBrush="{DynamicResource DevToolsBrushBorder}"
                        BorderThickness="0,0,0,1"/>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="36,1,0,0">
                    <TextBlock x:Name="ActiveToolLabel"
                               Text="Ferramentas"
                               FontSize="17"
                               FontWeight="Bold"
                               Foreground="{DynamicResource DevToolsTextPrimary}"
                               Margin="0,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,1,0,0">
                    <Button x:Name="MinimizeButton"
                            Click="MinimizeButton_Click"
                            Content="&#xE921;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="12"
                            Style="{StaticResource ShellCaptionButtonStyle}"/>
                    <Button x:Name="MaximizeButton"
                            Click="MaximizeButton_Click"
                            Content="&#xE922;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="12"
                            Style="{StaticResource ShellCaptionButtonStyle}"/>
                    <Button x:Name="CloseButton"
                            Click="CloseButton_Click"
                            Content="&#xE8BB;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="12"
                            Style="{StaticResource ShellCloseButtonStyle}"/>
                </StackPanel>
            </Grid>

            <!-- ======================== WORKSPACE ======================== -->
            <Grid Grid.Column="1" Grid.Row="1">
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#141619" Offset="0"/>
                            <GradientStop Color="#0F1113" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <ContentControl x:Name="WorkspaceHost" Margin="20,16,20,12"/>
            </Grid>

            <!-- ======================== FOOTER / STATUS ======================== -->
            <Border Grid.Column="1"
                    Grid.Row="2"
                    Background="{DynamicResource DevToolsSurface}"
                    BorderBrush="{DynamicResource DevToolsBrushBorder}"
                    BorderThickness="0,1,0,0">
                <TextBlock x:Name="MainStatusText"
                           Text="DevTools pronto."
                           Foreground="{DynamicResource DevToolsTextSecondary}"
                           FontSize="{DynamicResource DevToolsFontSize.Status}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,20,0"
                           TextAlignment="Right"/>
            </Border>
        </Grid>
    </Border>
</Window>
