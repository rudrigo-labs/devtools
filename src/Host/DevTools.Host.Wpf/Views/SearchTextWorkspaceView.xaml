<UserControl x:Class="DevTools.Host.Wpf.Views.SearchTextWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:DevTools.Host.Wpf.Components">

    <Grid Margin="0,4,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Search Text"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource DevToolsTextPrimary}"/>
            <TextBlock Text="Busca texto em arquivos de uma pasta, com suporte a regex, filtros por glob e detecção de encoding."
                       Foreground="{DynamicResource DevToolsTextSecondary}"
                       FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
            <Border Height="1" Background="{DynamicResource DevToolsBrushBorder}" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- ACTION BAR -->
        <c:ActionBarControl Grid.Row="1" x:Name="Actions"
                            ShowNew="False" ShowSave="True" ShowDelete="False" ShowCancel="True"
                            SaveText="Buscar"
                            ShowHelp="True"
                            HelpText="Preencha pasta e padrao. Ative Regex apenas se souber expressoes regulares. Use globs para filtrar arquivos."
                            ActionSave="ActionExecute_Click"
                            ActionCancel="ActionCancel_Click"/>

        <!-- BODY -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,0,0">

                <Border BorderThickness="1" CornerRadius="4"
                        BorderBrush="{DynamicResource DevToolsBrushBorder}"
                        Background="{DynamicResource DevToolsSurface}"
                        Padding="10,8" Margin="0,0,0,12">
                    <TextBlock Foreground="{DynamicResource DevToolsTextSecondary}" TextWrapping="Wrap">
                        Como usar: informe a pasta raiz e o texto a procurar. Regex aceita padroes avancados.
                        Case sensitive diferencia maiusculas/minusculas. Palavra inteira evita partes de palavra.
                        Globs sao filtros como **/*.cs e **/bin/**.
                    </TextBlock>
                </Border>

                <c:PathSelector x:Name="RootPathSelector" Title="Pasta raiz *" IsFolderPicker="True" Margin="0,0,0,12"/>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Padrão de busca *" Style="{StaticResource DevToolsInputLabel}"/>
                    <TextBox x:Name="PatternInput" Style="{StaticResource DevToolsTextInput}"
                             ToolTip="Texto ou expressão regular para buscar."/>
                </StackPanel>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="UseRegexCheck" Grid.Column="0"
                              Content="Usar Regex" Style="{StaticResource DevToolsCheckBox}"/>
                    <CheckBox x:Name="CaseSensitiveCheck" Grid.Column="2"
                              Content="Case sensitive" Style="{StaticResource DevToolsCheckBox}"/>
                    <CheckBox x:Name="WholeWordCheck" Grid.Column="4"
                              Content="Palavra inteira" Style="{StaticResource DevToolsCheckBox}"/>
                </Grid>

                <TextBlock Text="Globs: um padrao por linha. Inclusao: **/*.cs  |  Exclusao: **/obj/**"
                           Foreground="{DynamicResource DevToolsTextSecondary}"
                           FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Incluir globs (um por linha)" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="IncludeGlobsInput" Style="{StaticResource DevToolsTextInput}"
                                 Height="60" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 ToolTip="Ex: **/*.cs&#10;**/*.ts"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Excluir globs (um por linha)" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="ExcludeGlobsInput" Style="{StaticResource DevToolsTextInput}"
                                 Height="60" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 ToolTip="Ex: **/bin/**&#10;**/obj/**"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tamanho máx. de arquivo (KB)" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="MaxFileSizeInput" Style="{StaticResource DevToolsTextInput}"
                                 ToolTip="Deixe vazio para sem limite."/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Máx. de ocorrências por arquivo" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="MaxMatchesInput" Style="{StaticResource DevToolsTextInput}"
                                 Text="0" ToolTip="0 = sem limite."/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="SkipBinaryCheck" Content="Ignorar arquivos binários"
                          Style="{StaticResource DevToolsCheckBox}" IsChecked="True" Margin="0,0,0,12"/>

                <Button Content="Buscar Agora"
                        Style="{StaticResource DevToolsPrimaryButton}"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,12"
                        Click="ActionExecute_Click"/>

                <!-- Resultados -->
                <TextBlock x:Name="ResultSummaryText"
                           Foreground="{DynamicResource DevToolsTextSecondary}"
                           FontSize="12" Margin="0,0,0,6"
                           Visibility="Collapsed"/>

                <ListBox x:Name="ResultsList"
                         Visibility="Collapsed"
                         MaxHeight="280"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,3,0,3">
                                <TextBlock Text="{Binding RelativePath}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource DevToolsTextPrimary}"
                                           FontSize="12"/>
                                <TextBlock FontSize="11"
                                           Foreground="{DynamicResource DevToolsTextSecondary}">
                                    <Run Text="{Binding Occurrences}"/>
                                    <Run Text=" ocorrência(s)"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </StackPanel>
        </ScrollViewer>

        <!-- STATUS -->
        <TextBlock x:Name="ExecutionStatusText" Grid.Row="3"
                   Margin="0,10,0,0"
                   Foreground="{DynamicResource DevToolsTextSecondary}"/>
    </Grid>
</UserControl>
