<UserControl x:Class="DevTools.Host.Wpf.Views.ImageSplitWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:DevTools.Host.Wpf.Components">

    <Grid x:Name="WorkspaceRoot" Margin="0">
        <Grid HorizontalAlignment="Stretch"
              VerticalAlignment="Top"
              Margin="0,4,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ==================== TOOL HEADER ==================== -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Image Split"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DevToolsTextPrimary}"/>
                <TextBlock Text="Detecta e recorta automaticamente os componentes visuais de uma imagem com fundo transparente."
                           Foreground="{DynamicResource DevToolsTextSecondary}"
                           FontSize="12"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
                <Border Height="1"
                        Background="{DynamicResource DevToolsBrushBorder}"
                        Margin="0,10,0,0"/>
            </StackPanel>

            <!-- ==================== ACTION BAR ==================== -->
            <c:ActionBarControl Grid.Row="1"
                                x:Name="Actions" ShowHistory="True" ActionHistory="HistoryButton_Click"
                                ShowNew="False"
                                ShowSave="True"
                                ShowDelete="False"
                                ShowCancel="False"
                                ShowBack="True"
                                SaveText="Executar"
                                ShowHelp="True"
                                HelpText="Selecione a imagem, pasta de saida e ajustes de deteccao. Use Executar para recortar os componentes automaticamente."
                                ActionSave="ActionExecute_Click"
                                ActionBack="ActionBack_Click"/>

            <!-- ==================== TOOL BODY ==================== -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,0,0">

                    <!-- ===== Arquivo de entrada ===== -->
                    <c:PathSelector x:Name="InputPathSelector"
                                    Title="Arquivo de imagem *"
                                    IsFolderPicker="False"
                                    Margin="0,0,0,12"/>

                    <!-- ===== Saida ===== -->
                    <c:PathSelector x:Name="OutputDirectorySelector"
                                    Title="Pasta de saida *"
                                    IsFolderPicker="True"
                                    Margin="0,0,0,12"/>

                    <!-- ===== Opcoes de nomenclatura ===== -->
                    <TextBlock Text="Nomenclatura dos arquivos gerados"
                               Style="{StaticResource DevToolsCardTitle}"
                               Margin="0,4,0,10"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nome base dos arquivos"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="OutputBaseNameInput"
                                     Style="{StaticResource DevToolsTextInput}"
                                     ToolTip="Prefixo dos arquivos gerados. Padrao: nome do arquivo de entrada."/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Extensao de saida"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="OutputExtensionInput"
                                     Style="{StaticResource DevToolsTextInput}"
                                     ToolTip="Ex: .png, .webp. Padrao: mesma extensao do arquivo de entrada."/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Indice inicial dos arquivos"
                                   Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="StartIndexInput"
                                 Style="{StaticResource DevToolsTextInput}"
                                 Text="1"
                                 ToolTip="O primeiro arquivo gerado recebera este indice no nome. Ex: sprite_1.png, sprite_2.png..."/>
                    </StackPanel>

                    <!-- ===== Opcoes de deteccao ===== -->
                    <TextBlock Text="Deteccao de componentes"
                               Style="{StaticResource DevToolsCardTitle}"
                               Margin="0,4,0,10"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Limite de transparencia (0-255)"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="AlphaThresholdInput"
                                     Style="{StaticResource DevToolsTextInput}"
                                     Text="10"
                                     ToolTip="Pixels com alpha abaixo deste valor sao tratados como fundo transparente. Padrao: 10."/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Tamanho minimo (largura x altura px)"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="MinWidthInput"
                                         Grid.Column="0"
                                         Style="{StaticResource DevToolsTextInput}"
                                         Text="3"
                                         ToolTip="Largura minima em pixels para incluir um componente."/>
                                <TextBlock Grid.Column="1"
                                           Text="x"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource DevToolsTextSecondary}"/>
                                <TextBox x:Name="MinHeightInput"
                                         Grid.Column="2"
                                         Style="{StaticResource DevToolsTextInput}"
                                         Text="3"
                                         ToolTip="Altura minima em pixels para incluir um componente."/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- ===== Opcoes extras ===== -->
                    <CheckBox x:Name="OverwriteCheck"
                              Content="Sobrescrever arquivos existentes"
                              Style="{StaticResource DevToolsCheckBox}"
                              Margin="0,0,0,12"
                              ToolTip="Quando marcado, sobrescreve arquivos ja existentes na pasta de saida."/>

                </StackPanel>
            </ScrollViewer>

            <!-- ==================== STATUS ==================== -->
            <TextBlock x:Name="ExecutionStatusText"
                       Grid.Row="3"
                       Margin="0,10,0,0"
                       Foreground="{DynamicResource DevToolsTextSecondary}"/>
        </Grid>
    </Grid>
</UserControl>
