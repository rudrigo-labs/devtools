<UserControl x:Class="DevTools.Host.Wpf.Views.HomeLauncherView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="ToolCardButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="300"/>
            <Setter Property="Margin" Value="0,0,18,18"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform Y="0"/>
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#32000000"
                                      BlurRadius="20"
                                      ShadowDepth="2"
                                      Direction="270"
                                      Opacity="0.55"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Card"
                                CornerRadius="16"
                                Padding="16"
                                BorderThickness="1"
                                BorderBrush="#33404C"
                                Background="{DynamicResource DevToolsSurface}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="1.015" ScaleY="1.015"/>
                                            <TranslateTransform Y="-4"/>
                                        </TransformGroup>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource DevToolsAccent}"/>
                                <Setter TargetName="Card" Property="Background" Value="#202631"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#66000000"
                                                          BlurRadius="28"
                                                          ShadowDepth="3"
                                                          Direction="270"
                                                          Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="0.995" ScaleY="0.995"/>
                                            <TranslateTransform Y="0"/>
                                        </TransformGroup>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardIconBadgeStyle" TargetType="Border">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="CornerRadius" Value="23"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A5A7A" Offset="0"/>
                        <GradientStop Color="#22334A" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#4D82AF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,10,0,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
        </Style>

        <Style x:Key="CardDescriptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DevToolsTextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="18"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,14,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Ferramentas"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource DevToolsTextPrimary}"/>
            <TextBlock Text="Clique em um card para abrir a ferramenta em modo de execução."
                       Foreground="{DynamicResource DevToolsTextSecondary}"
                       FontSize="12"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap"/>
            <Border Height="1"
                    Background="{DynamicResource DevToolsBrushBorder}"
                    Margin="0,12,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      Margin="0,8,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <WrapPanel Orientation="Horizontal" Margin="16,10,10,10">
                <Button Style="{StaticResource ToolCardButtonStyle}" Tag="Snapshot" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource CardIconBadgeStyle}">
                            <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#D5ECFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Snapshot" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Gera um panorama do projeto para revisão rápida." Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ToolCardButtonStyle}" Tag="Rename" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource CardIconBadgeStyle}">
                            <TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#D5ECFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Rename" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Renomeia lotes de arquivos e pastas com seguranca." Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ToolCardButtonStyle}" Tag="Harvest" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource CardIconBadgeStyle}">
                            <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#D5ECFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Harvest" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Coleta e processa dados do workspace automaticamente." Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ToolCardButtonStyle}" Tag="ImageSplit" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource CardIconBadgeStyle}">
                            <TextBlock Text="&#xE91B;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#D5ECFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Image Split" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Recorta imagens em blocos seguindo regras de detecção." Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ToolCardButtonStyle}" Tag="SearchText" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource CardIconBadgeStyle}">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#D5ECFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Search Text" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Busca texto com regex e filtros por globs." Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ToolCardButtonStyle}" Tag="Organizer" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource CardIconBadgeStyle}">
                            <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#D5ECFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Organizer" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Classifica e organiza arquivos por regras de categoria." Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ToolCardButtonStyle}" Tag="Utf8Convert" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource CardIconBadgeStyle}">
                            <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#D5ECFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="UTF-8 Convert" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Converte arquivos de texto para UTF-8 com seguranca." Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ToolCardButtonStyle}" Tag="Migrations" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource CardIconBadgeStyle}">
                            <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#D5ECFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Migrations" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Executa e acompanha migrações de banco de dados." Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ToolCardButtonStyle}" Tag="SshTunnel" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource CardIconBadgeStyle}">
                            <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#D5ECFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="SSH Tunnel" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Abre túneis SSH para conectar servicos remotos." Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ToolCardButtonStyle}" Tag="Ngrok" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource CardIconBadgeStyle}">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#D5ECFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Ngrok" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Publica portas locais com URL externa segura." Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ToolCardButtonStyle}" Tag="Notes" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource CardIconBadgeStyle}">
                            <TextBlock Text="&#xE70B;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#D5ECFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Notes" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Cria e edita notas com suporte a sincronização." Style="{StaticResource CardDescriptionStyle}"/>
                    </StackPanel>
                </Button>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
