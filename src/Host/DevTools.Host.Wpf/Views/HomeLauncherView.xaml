<UserControl x:Class="DevTools.Host.Wpf.Views.HomeLauncherView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="0,4,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Home"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource DevToolsTextPrimary}"/>
            <TextBlock Text="Selecione uma ferramenta para abrir a tela de configuracao."
                       Foreground="{DynamicResource DevToolsTextSecondary}"
                       FontSize="12"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"/>
            <Border Height="1"
                    Background="{DynamicResource DevToolsBrushBorder}"
                    Margin="0,10,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <WrapPanel Margin="0,0,0,0" Orientation="Horizontal">

                <Border Width="280"
                        Margin="0,0,12,12"
                        Padding="12"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource DevToolsBrushBorder}"
                        BorderThickness="1"
                        Background="{DynamicResource DevToolsSurface}">
                    <StackPanel>
                        <TextBlock Text="&#xE9A0;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{DynamicResource DevToolsAccent}"/>
                        <TextBlock Text="Snapshot"
                                   Margin="0,8,0,4"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DevToolsTextPrimary}"/>
                        <TextBlock Text="Gera snapshot textual do projeto."
                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                        <Button Content="Abrir configuracao"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Left"
                                Style="{StaticResource DevToolsPrimaryButton}"
                                Tag="Snapshot"
                                Click="OpenTool_Click"/>
                    </StackPanel>
                </Border>

                <Border Width="280"
                        Margin="0,0,12,12"
                        Padding="12"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource DevToolsBrushBorder}"
                        BorderThickness="1"
                        Background="{DynamicResource DevToolsSurface}">
                    <StackPanel>
                        <TextBlock Text="&#xE895;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{DynamicResource DevToolsAccent}"/>
                        <TextBlock Text="Migrations"
                                   Margin="0,8,0,4"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DevToolsTextPrimary}"/>
                        <TextBlock Text="Configura e executa comandos dotnet ef."
                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                        <Button Content="Abrir configuracao"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Left"
                                Style="{StaticResource DevToolsPrimaryButton}"
                                Tag="Migrations"
                                Click="OpenTool_Click"/>
                    </StackPanel>
                </Border>

                <Border Width="280"
                        Margin="0,0,12,12"
                        Padding="12"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource DevToolsBrushBorder}"
                        BorderThickness="1"
                        Background="{DynamicResource DevToolsSurface}">
                    <StackPanel>
                        <TextBlock Text="&#xE8A5;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{DynamicResource DevToolsAccent}"/>
                        <TextBlock Text="UTF-8 Convert"
                                   Margin="0,8,0,4"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DevToolsTextPrimary}"/>
                        <TextBlock Text="Prepara conversao de arquivos para UTF-8."
                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                        <Button Content="Abrir configuracao"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Left"
                                Style="{StaticResource DevToolsPrimaryButton}"
                                Tag="Utf8Convert"
                                Click="OpenTool_Click"/>
                    </StackPanel>
                </Border>

                <Border Width="280"
                        Margin="0,0,12,12"
                        Padding="12"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource DevToolsBrushBorder}"
                        BorderThickness="1"
                        Background="{DynamicResource DevToolsSurface}">
                    <StackPanel>
                        <TextBlock Text="&#xE70B;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{DynamicResource DevToolsAccent}"/>
                        <TextBlock Text="Notes"
                                   Margin="0,8,0,4"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DevToolsTextPrimary}"/>
                        <TextBlock Text="Configura e gerencia notas locais e Drive."
                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                        <Button Content="Abrir configuracao"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Left"
                                Style="{StaticResource DevToolsPrimaryButton}"
                                Tag="Notes"
                                Click="OpenTool_Click"/>
                    </StackPanel>
                </Border>

            </WrapPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
