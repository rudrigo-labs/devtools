<UserControl x:Class="DevTools.Host.Wpf.Views.Utf8ConvertWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:DevTools.Host.Wpf.Components">

    <Grid Margin="0,4,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="UTF-8 Convert"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource DevToolsTextPrimary}"/>
            <TextBlock Text="Converte arquivos de texto para UTF-8 (com ou sem BOM), detectando o encoding original automaticamente."
                       Foreground="{DynamicResource DevToolsTextSecondary}"
                       FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
            <Border Height="1" Background="{DynamicResource DevToolsBrushBorder}" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- ACTION BAR -->
        <c:ActionBarControl Grid.Row="1" x:Name="Actions"
                            ShowNew="False" ShowSave="True" ShowDelete="False" ShowCancel="True"
                            SaveText="Executar"
                            ShowHelp="True"
                            HelpText="Converte arquivos de texto para UTF-8. Use Dry Run para simular antes. Globs definem quais arquivos entram ou saem."
                            ActionSave="ActionExecute_Click"
                            ActionCancel="ActionCancel_Click"/>

        <!-- BODY -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,0,0">

                <Border BorderThickness="1" CornerRadius="4"
                        BorderBrush="{DynamicResource DevToolsBrushBorder}"
                        Background="{DynamicResource DevToolsSurface}"
                        Padding="10,8" Margin="0,0,0,12">
                    <TextBlock Foreground="{DynamicResource DevToolsTextSecondary}" TextWrapping="Wrap">
                        Como usar: selecione a pasta raiz e, se quiser, filtre com globs.
                        Recursive inclui subpastas. Incluir BOM define o formato final UTF-8.
                        Dry Run mostra o que seria convertido sem alterar arquivo.
                    </TextBlock>
                </Border>

                <c:PathSelector x:Name="RootPathSelector" Title="Pasta raiz *" IsFolderPicker="True" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Incluir globs (um por linha)" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="IncludeGlobsInput" Style="{StaticResource DevToolsTextInput}"
                                 Height="60" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 ToolTip="Ex: **/*.cs&#10;**/*.ts"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Excluir globs (um por linha)" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="ExcludeGlobsInput" Style="{StaticResource DevToolsTextInput}"
                                 Height="60" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 ToolTip="Ex: **/bin/**&#10;**/obj/**"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="RecursiveCheck" Grid.Column="0"
                              Content="Subpastas" IsChecked="True"
                              Style="{StaticResource DevToolsCheckBox}"/>
                    <CheckBox x:Name="OutputBomCheck" Grid.Column="2"
                              Content="Incluir BOM" IsChecked="True"
                              Style="{StaticResource DevToolsCheckBox}"
                              ToolTip="Grava BOM (byte order mark) no início do arquivo UTF-8."/>
                    <CheckBox x:Name="CreateBackupCheck" Grid.Column="4"
                              Content="Criar backup (.bak)" IsChecked="True"
                              Style="{StaticResource DevToolsCheckBox}"/>
                </Grid>

                <CheckBox x:Name="DryRunCheck"
                          Content="Simulação (não modifica arquivos)"
                          Style="{StaticResource DevToolsCheckBox}"
                          Margin="0,0,0,12"/>

                <Button Content="Converter Agora"
                        Style="{StaticResource DevToolsPrimaryButton}"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,12"
                        Click="ActionExecute_Click"/>

                <!-- Resumo -->
                <Border x:Name="ResultPanel" Visibility="Collapsed"
                        BorderThickness="1" CornerRadius="4"
                        BorderBrush="{DynamicResource DevToolsBrushBorder}"
                        Padding="10,8" Margin="0,0,0,8">
                    <TextBlock x:Name="ResultSummaryText"
                               Foreground="{DynamicResource DevToolsTextPrimary}"
                               FontSize="12" TextWrapping="Wrap"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- STATUS -->
        <TextBlock x:Name="ExecutionStatusText" Grid.Row="3"
                   Margin="0,10,0,0"
                   Foreground="{DynamicResource DevToolsTextSecondary}"/>
    </Grid>
</UserControl>
