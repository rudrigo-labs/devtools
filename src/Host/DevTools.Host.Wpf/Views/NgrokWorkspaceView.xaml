<UserControl x:Class="DevTools.Host.Wpf.Views.NgrokWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:DevTools.Host.Wpf.Components">

    <UserControl.Resources>
        <Style x:Key="ConfigurationGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DevToolsBrushBorder}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DevToolsSurface}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource DevToolsAccent}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="WorkspaceRoot" Margin="0">
        <Grid HorizontalAlignment="Stretch"
              VerticalAlignment="Top"
              Margin="0,4,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock x:Name="WorkspaceTitleText"
                           Text="Ngrok"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DevToolsTextPrimary}"/>
                <TextBlock x:Name="WorkspaceSubtitleText"
                           Text="Gerencia túneis HTTP/HTTPS via ngrok."
                           Foreground="{DynamicResource DevToolsTextSecondary}"
                           FontSize="12"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
                <Border Height="1"
                        Background="{DynamicResource DevToolsBrushBorder}"
                        Margin="0,10,0,0"/>
            </StackPanel>

            <c:ActionBarControl Grid.Row="1"
                                x:Name="Actions"
                                ShowHistory="True"
                                ShowNew="True"
                                ShowSave="True"
                                ShowDelete="True"
                                ShowCancel="False"
                                ShowHelp="True"
                                ActionHistory="HistoryButton_Click"
                                ActionNew="ActionNew_Click"
                                ActionSave="ActionSave_Click"
                                ActionDelete="ActionDelete_Click"
                                ActionCancel="ActionCancel_Click"
                                ActionGoToTool="ActionGoToTool_Click"
                                ActionBack="ActionBack_Click"/>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,0,0">

                    <StackPanel x:Name="ConfigurationListSection"
                                Margin="0,0,0,12">
                        <TextBlock Text="Configurações salvas"
                                   Style="{StaticResource DevToolsCardTitle}"/>
                        <Border Margin="0,8,0,0"
                                BorderThickness="1"
                                CornerRadius="6"
                                BorderBrush="{DynamicResource DevToolsBrushBorder}"
                                Background="{DynamicResource DevToolsWindowBackground}">
                            <DataGrid x:Name="ConfigurationsGrid"
                                      Height="210"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      RowStyle="{StaticResource ConfigurationGridRowStyle}"
                                      SelectionChanged="ConfigurationsGrid_SelectionChanged"
                                      MouseDoubleClick="ConfigurationsGrid_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Nome"
                                                        Binding="{Binding Name}"
                                                        Width="220"/>
                                    <DataGridTextColumn Header="Descrição"
                                                        Binding="{Binding Description}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="Criado em"
                                                        Binding="{Binding CreatedAtUtc, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                                        Width="150"/>
                                    <DataGridTextColumn Header="Atualizado em"
                                                        Binding="{Binding UpdatedAtUtc, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                                        Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                        <TextBlock x:Name="GridHintText"
                                   Text="Clique para selecionar. Duplo clique para iniciar edição."
                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                   Margin="0,8,0,0"
                                   FontSize="11"/>
                    </StackPanel>

                    <Border x:Name="ConfigurationModeHint"
                            Visibility="Collapsed"
                            BorderThickness="1"
                            CornerRadius="4"
                            BorderBrush="{DynamicResource DevToolsBrushBorder}"
                            Background="{DynamicResource DevToolsSurface}"
                            Padding="10,8"
                            Margin="0,0,0,12">
                        <TextBlock Text=""
                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <StackPanel x:Name="ConfigurationFormSection">
                        <Grid x:Name="ConfigurationMetadataSection"
                              Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Nome"
                                           Style="{StaticResource DevToolsInputLabel}"/>
                                <TextBox x:Name="NameInput"
                                         Style="{StaticResource DevToolsTextInput}"
                                         TextChanged="ConfigurationField_Changed"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Descrição"
                                           Style="{StaticResource DevToolsInputLabel}"/>
                                <TextBox x:Name="DescriptionInput"
                                         Style="{StaticResource DevToolsTextInput}"
                                         TextChanged="ConfigurationField_Changed"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Configuração"
                                   Style="{StaticResource DevToolsCardTitle}"
                                   Margin="0,4,0,10"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Auth token do ngrok *"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="AuthTokenInput"
                                     Style="{StaticResource DevToolsTextInput}"
                                     TextChanged="ConfigurationField_Changed"
                                     ToolTip="Token de autenticação do ngrok. Usado em: ngrok config add-authtoken"/>
                        </StackPanel>

                        <c:PathSelector x:Name="ExecutablePathSelector"
                                        Title="Executável ngrok (opcional)"
                                        IsFolderPicker="False"
                                        Margin="0,0,0,12"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Argumentos adicionais (opcional)"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="AdditionalArgsInput"
                                     Style="{StaticResource DevToolsTextInput}"
                                     TextChanged="ConfigurationField_Changed"
                                     ToolTip="Exemplo: --log stdout --log-format json"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="URL da API local do ngrok"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="BaseUrlInput"
                                     Style="{StaticResource DevToolsTextInput}"
                                     Text="http://127.0.0.1:4040/"
                                     TextChanged="ConfigurationField_Changed"
                                     ToolTip="Endereço local da API ngrok. Padrão: http://127.0.0.1:4040/"/>
                        </StackPanel>

                        <CheckBox x:Name="IsDefaultCheck"
                                  Content="Marcar como configuração padrão"
                                  Style="{StaticResource DevToolsCheckBox}"
                                  Checked="ConfigurationField_Changed"
                                  Unchecked="ConfigurationField_Changed"
                                  Margin="0,0,0,12"/>
                    </StackPanel>

                    <StackPanel x:Name="ExecutionSection">
                        <TextBlock Text="Execução"
                                   Style="{StaticResource DevToolsCardTitle}"
                                   Margin="0,4,0,10"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="Protocolo"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBlock Grid.Row="0"
                                       Grid.Column="2"
                                       Text="Porta *"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <ComboBox x:Name="ProtocolCombo"
                                      Grid.Row="1"
                                      Grid.Column="0"
                                      Style="{StaticResource DevToolsSelectInput}"/>
                            <TextBox x:Name="StartPortInput"
                                     Grid.Row="1"
                                     Grid.Column="2"
                                     Height="{Binding ElementName=ProtocolCombo, Path=ActualHeight}"
                                     Style="{StaticResource DevToolsTextInput}"
                                     ToolTip="Ex: 5000"/>
                        </Grid>

                        <Border x:Name="TunnelListPanel"
                                Visibility="Collapsed"
                                BorderThickness="1"
                                CornerRadius="4"
                                BorderBrush="{DynamicResource DevToolsBrushBorder}"
                                Padding="10,8"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock x:Name="TunnelListHeader"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Foreground="{DynamicResource DevToolsTextPrimary}"
                                           Margin="0,0,0,8"/>
                                <ListBox x:Name="TunnelList"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource DevToolsWindowBackground}"
                                                    BorderBrush="{DynamicResource DevToolsBrushBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Margin="0,0,0,6"
                                                    Padding="10,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding PublicUrl}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource DevToolsTextPrimary}"/>
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                                                   FontSize="11"
                                                                   Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Content="Copiar URL"
                                                            Style="{StaticResource DevToolsSecondaryButton}"
                                                            Tag="{Binding PublicUrl}"
                                                            Click="CopyUrl_Click"
                                                            Margin="8,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock x:Name="EmptyStateText"
                                           Text="Nenhum túnel ativo no momento."
                                           Foreground="{DynamicResource DevToolsTextSecondary}"
                                           Margin="0,8,0,0"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <TextBlock x:Name="ExecutionStatusText"
                       Grid.Row="3"
                       Margin="0,10,0,0"
                       Foreground="{DynamicResource DevToolsTextSecondary}"/>
        </Grid>
    </Grid>
</UserControl>
