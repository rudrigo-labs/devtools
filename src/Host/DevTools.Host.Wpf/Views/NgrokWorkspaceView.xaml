<UserControl x:Class="DevTools.Host.Wpf.Views.NgrokWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:DevTools.Host.Wpf.Components">

    <Grid x:Name="WorkspaceRoot" Margin="0">
        <Grid HorizontalAlignment="Stretch"
              VerticalAlignment="Top"
              Margin="0,4,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ==================== TOOL HEADER ==================== -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock x:Name="WorkspaceTitleText"
                           Text="Ngrok"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DevToolsTextPrimary}"/>
                <TextBlock x:Name="WorkspaceSubtitleText"
                           Text="Gerencia túneis HTTP/HTTPS via ngrok. Inicia, lista, encerra e monitora processos ngrok."
                           Foreground="{DynamicResource DevToolsTextSecondary}"
                           FontSize="12"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
                <Border Height="1"
                        Background="{DynamicResource DevToolsBrushBorder}"
                        Margin="0,10,0,0"/>
            </StackPanel>

            <!-- ==================== ACTION BAR ==================== -->
            <c:ActionBarControl Grid.Row="1"
                                x:Name="Actions" ShowHistory="True" ActionHistory="HistoryButton_Click"
                                ShowNew="True"
                                ShowSave="True"
                                ShowDelete="True"
                                ShowCancel="False"
                                ShowHelp="True"
                                ActionNew="ActionNew_Click"
                                ActionSave="ActionSave_Click"
                                ActionDelete="ActionDelete_Click"
                                ActionCancel="ActionCancel_Click"
                                ActionGoToTool="ActionGoToTool_Click"
                                ActionBack="ActionBack_Click"/>

            <!-- ==================== TOOL BODY ==================== -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,0,0">

                    <!-- Seletor de configuração (condicional) -->
                    <StackPanel x:Name="ConfigurationsLabel"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Configurações salvas"
                                   Style="{StaticResource DevToolsCardTitle}"/>
                        <Border Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Width="16" Height="16"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource DevToolsTextSecondary}"
                                ToolTipService.InitialShowDelay="200"
                                ToolTipService.ShowDuration="30000">
                            <Border.ToolTip>
                                <ToolTip Placement="Right" MaxWidth="360">
                                    <TextBlock TextWrapping="Wrap"
                                               Text="Escolha uma configuração salva ou selecione 'Configurar manualmente' para preencher os campos sem usar configuração salva."/>
                                </ToolTip>
                            </Border.ToolTip>
                            <TextBlock Text="?"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource DevToolsTextSecondary}"/>
                        </Border>
                    </StackPanel>
                    <ComboBox x:Name="ConfigurationsCombo"
                              Margin="0,8,0,16"
                              Style="{StaticResource DevToolsSelectInput}"
                              SelectionChanged="ConfigurationsCombo_SelectionChanged"
                              DisplayMemberPath="Label"/>

                    <Border x:Name="ConfigurationModeHint"
                            Visibility="Collapsed"
                            BorderThickness="1"
                            CornerRadius="4"
                            BorderBrush="{DynamicResource DevToolsBrushBorder}"
                            Background="{DynamicResource DevToolsSurface}"
                            Padding="10,8"
                            Margin="0,0,0,12">
                        <TextBlock Text="Modo configuração: preencha os campos abaixo para salvar uma configuração reutilizável."
                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- ===== Campos de configuração (modo Configuração) ===== -->
                    <Grid x:Name="ConfigurationMetadataSection"
                          Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nome"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="NameInput"
                                     Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Descrição"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="DescriptionInput"
                                     Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>
                    </Grid>

                    <!-- ===== Configuração ===== -->
                    <TextBlock Text="Configuração"
                               Style="{StaticResource DevToolsCardTitle}"
                               Margin="0,4,0,10"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Auth token do ngrok *"
                                   Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="AuthTokenInput"
                                 Style="{StaticResource DevToolsTextInput}"
                                 ToolTip="Token de autenticacao do ngrok. Usado em: ngrok config add-authtoken"/>
                    </StackPanel>

                    <c:PathSelector x:Name="ExecutablePathSelector"
                                    Title="Executável ngrok (opcional)"
                                    IsFolderPicker="False"
                                    Margin="0,0,0,12"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Argumentos adicionais (opcional)"
                                   Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="AdditionalArgsInput"
                                 Style="{StaticResource DevToolsTextInput}"
                                 ToolTip="Exemplo: --log stdout --log-format json"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="URL da API local do ngrok"
                                   Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="BaseUrlInput"
                                 Style="{StaticResource DevToolsTextInput}"
                                 Text="http://127.0.0.1:4040/"
                                 ToolTip="Endereco local da API ngrok. Padrão: http://127.0.0.1:4040/"/>
                    </StackPanel>

                    <CheckBox x:Name="IsDefaultCheck"
                              Content="Marcar como configuração padrão"
                              Style="{StaticResource DevToolsCheckBox}"
                              Margin="0,0,0,12"/>

                    <!-- ===== Execução ===== -->
                    <TextBlock Text="Execução"
                               Style="{StaticResource DevToolsCardTitle}"
                               Margin="0,4,0,10"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Protocolo"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <ComboBox x:Name="ProtocolCombo"
                                      Style="{StaticResource DevToolsSelectInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Porta *"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="StartPortInput"
                                     Style="{StaticResource DevToolsTextInput}"
                                     ToolTip="Ex: 5000"/>
                        </StackPanel>
                        <Button Grid.Column="4"
                                Content="Iniciar túnel"
                                Style="{StaticResource DevToolsPrimaryButton}"
                                VerticalAlignment="Bottom"
                                Click="StartHttp_Click"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Listar túneis"
                                Style="{StaticResource DevToolsSecondaryButton}"
                                Margin="0,0,8,0"
                                Click="ListTunnels_Click"/>
                        <Button Content="Status"
                                Style="{StaticResource DevToolsSecondaryButton}"
                                Margin="0,0,8,0"
                                Click="Status_Click"/>
                        <Button Content="Encerrar tudo"
                                Style="{StaticResource DevToolsSecondaryButton}"
                                Click="KillAll_Click"/>
                    </StackPanel>

                    <!-- ===== Túneis ativos ===== -->
                    <Border x:Name="TunnelListPanel"
                            Visibility="Collapsed"
                            BorderThickness="1" CornerRadius="4"
                            BorderBrush="{DynamicResource DevToolsBrushBorder}"
                            Padding="10,8" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock x:Name="TunnelListHeader"
                                       FontWeight="SemiBold" FontSize="12"
                                       Foreground="{DynamicResource DevToolsTextPrimary}"
                                       Margin="0,0,0,8"/>
                            <ListBox x:Name="TunnelList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource DevToolsWindowBackground}"
                                                BorderBrush="{DynamicResource DevToolsBrushBorder}"
                                                BorderThickness="1" CornerRadius="4"
                                                Margin="0,0,0,6" Padding="10,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding PublicUrl}"
                                                               FontWeight="SemiBold" FontSize="12"
                                                               Foreground="{DynamicResource DevToolsTextPrimary}"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{DynamicResource DevToolsTextSecondary}"
                                                               FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="Copiar URL"
                                                        Style="{StaticResource DevToolsSecondaryButton}"
                                                        Tag="{Binding PublicUrl}"
                                                        Click="CopyUrl_Click"
                                                        Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock x:Name="EmptyStateText"
                                       Text="Nenhum túnel ativo no momento."
                                       Foreground="{DynamicResource DevToolsTextSecondary}"
                                       Margin="0,8,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ==================== STATUS ==================== -->
            <TextBlock x:Name="ExecutionStatusText"
                       Grid.Row="3"
                       Margin="0,10,0,0"
                       Foreground="{DynamicResource DevToolsTextSecondary}"/>
        </Grid>
    </Grid>
</UserControl>

