<UserControl x:Class="DevTools.Host.Wpf.Views.SshTunnelWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:DevTools.Host.Wpf.Components">

    <Grid x:Name="WorkspaceRoot" Margin="0">
        <Grid HorizontalAlignment="Stretch"
              VerticalAlignment="Top"
              Margin="0,4,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ==================== TOOL HEADER ==================== -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock x:Name="WorkspaceTitleText"
                           Text="SSH Tunnel"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DevToolsTextPrimary}"/>
                <TextBlock x:Name="WorkspaceSubtitleText"
                           Text="Cria e gerencia tuneis SSH para redirecionamento de portas, com configuracoes nomeadas."
                           Foreground="{DynamicResource DevToolsTextSecondary}"
                           FontSize="12"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
                <Border Height="1"
                        Background="{DynamicResource DevToolsBrushBorder}"
                        Margin="0,10,0,0"/>
            </StackPanel>

            <!-- ==================== ACTION BAR ==================== -->
            <c:ActionBarControl Grid.Row="1"
                                x:Name="Actions"
                                ShowNew="True"
                                ShowSave="True"
                                ShowDelete="True"
                                ShowCancel="True"
                                ShowHelp="True"
                                HelpText="Use Configurar para salvar host, usuario e mapeamento. Use Iniciar para abrir o tunel SSH."
                                ActionNew="ActionNew_Click"
                                ActionSave="ActionSave_Click"
                                ActionDelete="ActionDelete_Click"
                                ActionCancel="ActionCancel_Click"/>

            <!-- ==================== TOOL BODY ==================== -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,0,0">

                    <!-- Seletor de configuração (condicional) -->
                    <StackPanel x:Name="ConfigurationsLabel"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Configurações salvas"
                                   Style="{StaticResource DevToolsCardTitle}"/>
                        <Border Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Width="16" Height="16"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource DevToolsTextSecondary}"
                                ToolTipService.InitialShowDelay="200"
                                ToolTipService.ShowDuration="30000">
                            <Border.ToolTip>
                                <ToolTip Placement="Right" MaxWidth="360">
                                    <TextBlock TextWrapping="Wrap"
                                               Text="Escolha uma configuração salva ou selecione 'Configurar manualmente' para preencher os campos sem usar configuração salva."/>
                                </ToolTip>
                            </Border.ToolTip>
                            <TextBlock Text="?"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource DevToolsTextSecondary}"/>
                        </Border>
                    </StackPanel>
                    <ComboBox x:Name="ConfigurationsCombo"
                              Margin="0,8,0,16"
                              Style="{StaticResource DevToolsSelectInput}"
                              SelectionChanged="ConfigurationsCombo_SelectionChanged"
                              DisplayMemberPath="Label"/>

                    <Border x:Name="ConfigurationModeHint"
                            Visibility="Collapsed"
                            BorderThickness="1"
                            CornerRadius="4"
                            BorderBrush="{DynamicResource DevToolsBrushBorder}"
                            Background="{DynamicResource DevToolsSurface}"
                            Padding="10,8"
                            Margin="0,0,0,12">
                        <TextBlock Text="Modo configuracao: preencha os campos abaixo para salvar uma configuracao reutilizavel."
                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- ===== Campos de configuracao (modo Configuracao) ===== -->
                    <Grid x:Name="ConfigurationMetadataSection"
                          Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nome"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="NameInput"
                                     Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Descricao"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="DescriptionInput"
                                     Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>
                    </Grid>

                    <!-- ===== Conexão SSH ===== -->
                    <TextBlock Text="Conexão SSH"
                               Style="{StaticResource DevToolsCardTitle}"
                               Margin="0,4,0,10"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Host SSH (Bastion) *"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="SshHostInput"
                                     Style="{StaticResource DevToolsTextInput}"
                                     ToolTip="Ex: servidor.empresa.com"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Porta SSH"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="SshPortInput"
                                     Style="{StaticResource DevToolsTextInput}"
                                     Text="22"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Usuario SSH *"
                                   Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="SshUserInput"
                                 Style="{StaticResource DevToolsTextInput}"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="StrictHostKeyChecking"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <ComboBox x:Name="StrictHostKeyCheckingCombo"
                                      Style="{StaticResource DevToolsSelectInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Timeout de conexao (s)"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="ConnectTimeoutInput"
                                     Style="{StaticResource DevToolsTextInput}"
                                     ToolTip="Deixe vazio para padrao."/>
                        </StackPanel>
                    </Grid>

                    <c:PathSelector x:Name="IdentityFileSelector"
                                    Title="Arquivo de Identidade (Chave Privada)"
                                    IsFolderPicker="False"
                                    Margin="0,0,0,12"/>

                    <!-- ===== Mapeamento do Tunel ===== -->
                    <TextBlock Text="Mapeamento do Tunel"
                               Style="{StaticResource DevToolsCardTitle}"
                               Margin="0,4,0,10"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Bind local"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="LocalBindHostInput"
                                     Style="{StaticResource DevToolsTextInput}"
                                     Text="127.0.0.1"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Porta local"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="LocalPortInput"
                                     Style="{StaticResource DevToolsTextInput}"
                                     Text="14331"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Host remoto"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="RemoteHostInput"
                                     Style="{StaticResource DevToolsTextInput}"
                                     Text="127.0.0.1"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Porta remota"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="RemotePortInput"
                                     Style="{StaticResource DevToolsTextInput}"
                                     Text="1433"/>
                        </StackPanel>
                    </Grid>

                    <CheckBox x:Name="IsDefaultCheck"
                              Content="Marcar como configuracao padrao"
                              Style="{StaticResource DevToolsCheckBox}"
                              Margin="0,0,0,12"/>

                    <!-- ===== Status do tunel ===== -->
                    <TextBlock Text="Status do Tunel"
                               Style="{StaticResource DevToolsCardTitle}"
                               Margin="0,4,0,10"/>

                    <Border Background="{DynamicResource DevToolsSurface}"
                            BorderBrush="{DynamicResource DevToolsBrushBorder}"
                            BorderThickness="1" CornerRadius="4"
                            Padding="10,8" Margin="0,0,0,12">
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left"
                                       Text="Estado atual"
                                       Foreground="{DynamicResource DevToolsTextSecondary}"
                                       FontSize="12" VerticalAlignment="Center"/>
                            <Border x:Name="SshStatusBadge"
                                    DockPanel.Dock="Right"
                                    CornerRadius="10" Padding="10,3">
                                <TextBlock x:Name="SshStatusText"
                                           Text="Parado"
                                           Foreground="White"
                                           FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </DockPanel>
                    </Border>

                    <Border x:Name="ConfigSummaryPanel"
                            Visibility="Collapsed"
                            BorderThickness="1" CornerRadius="4"
                            BorderBrush="{DynamicResource DevToolsBrushBorder}"
                            Padding="10,8" Margin="0,0,0,12">
                        <TextBlock x:Name="ConfigSummaryText"
                                   FontFamily="Consolas,Courier New" FontSize="11"
                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="StartButton"
                                Content="Iniciar tunel"
                                Style="{StaticResource DevToolsPrimaryButton}"
                                Margin="0,0,8,0"
                                Click="Start_Click"/>
                        <Button x:Name="StopButton"
                                Content="Parar tunel"
                                Style="{StaticResource DevToolsSecondaryButton}"
                                Click="Stop_Click"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- ==================== STATUS ==================== -->
            <TextBlock x:Name="ExecutionStatusText"
                       Grid.Row="3"
                       Margin="0,10,0,0"
                       Foreground="{DynamicResource DevToolsTextSecondary}"/>
        </Grid>
    </Grid>
</UserControl>
