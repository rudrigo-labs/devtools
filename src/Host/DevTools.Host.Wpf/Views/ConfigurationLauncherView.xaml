<UserControl x:Class="DevTools.Host.Wpf.Views.ConfigurationLauncherView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="ConfigCardButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="300"/>
            <Setter Property="Margin" Value="0,0,18,18"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform Y="0"/>
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#32000000"
                                      BlurRadius="20"
                                      ShadowDepth="2"
                                      Direction="270"
                                      Opacity="0.55"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Card"
                                CornerRadius="16"
                                Padding="16"
                                BorderThickness="1"
                                BorderBrush="#375043"
                                Background="{DynamicResource DevToolsSurface}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="1.015" ScaleY="1.015"/>
                                            <TranslateTransform Y="-4"/>
                                        </TransformGroup>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource DevToolsAccent}"/>
                                <Setter TargetName="Card" Property="Background" Value="#1E2A25"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#66000000"
                                                          BlurRadius="28"
                                                          ShadowDepth="3"
                                                          Direction="270"
                                                          Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConfigCardIconBadgeStyle" TargetType="Border">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="CornerRadius" Value="23"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E6A52" Offset="0"/>
                        <GradientStop Color="#214033" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#52A986"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ConfigCardTitleStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,10,0,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{DynamicResource DevToolsTextPrimary}"/>
        </Style>

        <Style x:Key="ConfigCardDescriptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DevToolsTextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="18"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,14,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Configurações"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource DevToolsTextPrimary}"/>
            <TextBlock Text="Escolha um card para editar configurações persistentes das ferramentas."
                       Foreground="{DynamicResource DevToolsTextSecondary}"
                       FontSize="12"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap"/>
            <Border Height="1"
                    Background="{DynamicResource DevToolsBrushBorder}"
                    Margin="0,12,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      Margin="0,8,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <WrapPanel Orientation="Horizontal" Margin="16,10,10,10">
                <Button Style="{StaticResource ConfigCardButtonStyle}" Tag="Snapshot" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource ConfigCardIconBadgeStyle}">
                            <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#DAFFE9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Snapshot" Style="{StaticResource ConfigCardTitleStyle}"/>
                        <TextBlock Text="Perfis de snapshot com caminhos, filtros e formatos de saída." Style="{StaticResource ConfigCardDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ConfigCardButtonStyle}" Tag="Harvest" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource ConfigCardIconBadgeStyle}">
                            <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#DAFFE9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Harvest" Style="{StaticResource ConfigCardTitleStyle}"/>
                        <TextBlock Text="Perfis de mineração com origem, destino e regras de extração." Style="{StaticResource ConfigCardDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ConfigCardButtonStyle}" Tag="Organizer" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource ConfigCardIconBadgeStyle}">
                            <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#DAFFE9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Organizer" Style="{StaticResource ConfigCardTitleStyle}"/>
                        <TextBlock Text="Perfis de organização com categorias, pesos e deduplicação." Style="{StaticResource ConfigCardDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ConfigCardButtonStyle}" Tag="Migrations" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource ConfigCardIconBadgeStyle}">
                            <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#DAFFE9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Migrations" Style="{StaticResource ConfigCardTitleStyle}"/>
                        <TextBlock Text="Perfis de migração, contexto e parâmetros de banco." Style="{StaticResource ConfigCardDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ConfigCardButtonStyle}" Tag="SshTunnel" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource ConfigCardIconBadgeStyle}">
                            <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#DAFFE9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="SSH Tunnel" Style="{StaticResource ConfigCardTitleStyle}"/>
                        <TextBlock Text="Conexões SSH nomeadas para acesso remoto rápido." Style="{StaticResource ConfigCardDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ConfigCardButtonStyle}" Tag="Ngrok" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource ConfigCardIconBadgeStyle}">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#DAFFE9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Ngrok" Style="{StaticResource ConfigCardTitleStyle}"/>
                        <TextBlock Text="Token, executável e presets de túnel público." Style="{StaticResource ConfigCardDescriptionStyle}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ConfigCardButtonStyle}" Tag="Notes" Click="OpenTool_Click">
                    <StackPanel>
                        <Border Style="{StaticResource ConfigCardIconBadgeStyle}">
                            <TextBlock Text="&#xE70B;" FontFamily="Segoe MDL2 Assets" FontSize="21" Foreground="#DAFFE9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Notes" Style="{StaticResource ConfigCardTitleStyle}"/>
                        <TextBlock Text="Configuração única da pasta de notas e Google Drive." Style="{StaticResource ConfigCardDescriptionStyle}"/>
                    </StackPanel>
                </Button>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
