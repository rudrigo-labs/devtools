<UserControl x:Class="DevTools.Host.Wpf.Views.MigrationsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:DevTools.Host.Wpf.Components">

    <Grid Margin="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Migrations"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource DevToolsTextPrimary}"/>
            <TextBlock Text="Executa dotnet ef migrations add e database update com configurações nomeadas por provedor."
                       Foreground="{DynamicResource DevToolsTextSecondary}"
                       FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
            <Border Height="1" Background="{DynamicResource DevToolsBrushBorder}" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- ACTION BAR -->
        <c:ActionBarControl Grid.Row="1" x:Name="Actions"
                            ShowNew="True" ShowSave="True" ShowDelete="True" ShowCancel="True"
                            ActionNew="ActionNew_Click"
                            ActionSave="ActionSave_Click"
                            ActionDelete="ActionDelete_Click"
                            ActionCancel="ActionCancel_Click"/>

        <!-- SELETOR DE CONFIGURAÇÃO -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="ConfigurationsCombo"
                      Grid.Column="0"
                      Style="{StaticResource DevToolsSelectInput}"
                      DisplayMemberPath="Label"
                      SelectionChanged="ConfigurationsCombo_SelectionChanged"/>
            <Button Grid.Column="2" Content="Execução"
                    Style="{StaticResource DevToolsSecondaryButton}"
                    Click="SwitchToExecution_Click"/>
            <Button Grid.Column="4" Content="Configuração"
                    Style="{StaticResource DevToolsSecondaryButton}"
                    Click="SwitchToConfiguration_Click"/>
        </Grid>

        <!-- BODY -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,4,0,0">

                <!-- MODO EXECUÇÃO -->
                <StackPanel x:Name="ExecutionPanel">
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ação *" Style="{StaticResource DevToolsInputLabel}"/>
                            <ComboBox x:Name="ActionCombo" Style="{StaticResource DevToolsSelectInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Provedor *" Style="{StaticResource DevToolsInputLabel}"/>
                            <ComboBox x:Name="ProviderCombo" Style="{StaticResource DevToolsSelectInput}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="MigrationNamePanel" Margin="0,0,0,12">
                        <TextBlock Text="Nome da migration *" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="MigrationNameInput" Style="{StaticResource DevToolsTextInput}"
                                 ToolTip="Só para AddMigration. Ex: AddUserTable"/>
                    </StackPanel>

                    <CheckBox x:Name="DryRunCheck" Content="Dry run (apenas mostrar o comando, sem executar)"
                              Style="{StaticResource DevToolsCheckBox}" Margin="0,0,0,12"/>

                    <!-- Resultado -->
                    <Border x:Name="ResultPanel" Visibility="Collapsed"
                            BorderThickness="1" CornerRadius="4"
                            BorderBrush="{DynamicResource DevToolsBrushBorder}"
                            Padding="10,8" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock x:Name="ResultCommandText"
                                       FontFamily="Consolas,Courier New"
                                       FontSize="11"
                                       Foreground="{DynamicResource DevToolsTextSecondary}"
                                       TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBox x:Name="ResultOutputText"
                                     Style="{StaticResource DevToolsTextInput}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas,Courier New"
                                     FontSize="11"
                                     Height="120"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- MODO CONFIGURAÇÃO -->
                <StackPanel x:Name="ConfigurationPanel" Visibility="Collapsed">
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Nome da configuração *" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="NameInput" Style="{StaticResource DevToolsTextInput}"/>
                    </StackPanel>

                    <c:PathSelector x:Name="RootPathSelector" Title="Pasta raiz do projeto *"
                                    IsFolderPicker="True" Margin="0,0,0,12"/>

                    <c:PathSelector x:Name="StartupProjectSelector" Title="Startup project (.csproj) *"
                                    IsFolderPicker="False" Margin="0,0,0,12"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="DbContext (nome completo com namespace) *"
                                   Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="DbContextInput" Style="{StaticResource DevToolsTextInput}"
                                 ToolTip="Ex: MyApp.Infrastructure.Data.AppDbContext"/>
                    </StackPanel>

                    <Border Margin="0,0,0,12" Padding="10,8" CornerRadius="4"
                            BorderThickness="1" BorderBrush="{DynamicResource DevToolsBrushBorder}">
                        <StackPanel>
                            <TextBlock Text="Projetos de migração por provedor"
                                       FontWeight="SemiBold" FontSize="12"
                                       Foreground="{DynamicResource DevToolsTextPrimary}"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="SQL Server (.csproj)"
                                           Style="{StaticResource DevToolsInputLabel}"/>
                                <TextBox x:Name="SqlServerProjectInput" Grid.Column="2"
                                         Style="{StaticResource DevToolsTextInput}"
                                         ToolTip="Caminho do .csproj de migrations para SQL Server. Deixe vazio se não usar."/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="SQLite (.csproj)"
                                           Style="{StaticResource DevToolsInputLabel}"/>
                                <TextBox x:Name="SqliteProjectInput" Grid.Column="2"
                                         Style="{StaticResource DevToolsTextInput}"
                                         ToolTip="Caminho do .csproj de migrations para SQLite. Deixe vazio se não usar."/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Argumentos adicionais" Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="AdditionalArgsInput" Style="{StaticResource DevToolsTextInput}"
                                 ToolTip="Ex: --no-build"/>
                    </StackPanel>

                    <CheckBox x:Name="IsDefaultCheck" Content="Marcar como configuração padrão"
                              Style="{StaticResource DevToolsCheckBox}" Margin="0,0,0,12"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- STATUS -->
        <TextBlock x:Name="ExecutionStatusText" Grid.Row="4"
                   Margin="0,10,0,0"
                   Foreground="{DynamicResource DevToolsTextSecondary}"/>
    </Grid>
</UserControl>
