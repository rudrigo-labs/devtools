<UserControl x:Class="DevTools.Host.Wpf.Views.MigrationsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:DevTools.Host.Wpf.Components">

    <Grid x:Name="WorkspaceRoot" Margin="0">
        <Grid HorizontalAlignment="Stretch"
              VerticalAlignment="Top"
              Margin="0,4,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ==================== TOOL HEADER ==================== -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock x:Name="WorkspaceTitleText"
                           Text="Migrations"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DevToolsTextPrimary}"/>
                <TextBlock x:Name="WorkspaceSubtitleText"
                           Text="Executa dotnet ef migrations add e database update com configurações nomeadas por provedor."
                           Foreground="{DynamicResource DevToolsTextSecondary}"
                           FontSize="12"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
                <Border Height="1"
                        Background="{DynamicResource DevToolsBrushBorder}"
                        Margin="0,10,0,0"/>
            </StackPanel>

            <!-- ==================== ACTION BAR ==================== -->
            <c:ActionBarControl Grid.Row="1"
                                x:Name="Actions" ShowHistory="True" ActionHistory="HistoryButton_Click"
                                ShowNew="True"
                                ShowSave="True"
                                ShowDelete="True"
                                ShowCancel="True"
                                ShowHelp="True"
                                HelpText="Use Configurar para salvar caminhos e DbContext. Use Executar para rodar dotnet ef."
                                ActionNew="ActionNew_Click"
                                ActionSave="ActionSave_Click"
                                ActionDelete="ActionDelete_Click"
                                ActionCancel="ActionCancel_Click"
                                ActionGoToTool="ActionGoToTool_Click"
                                ActionBack="ActionBack_Click"/>

            <!-- ==================== TOOL BODY ==================== -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,0,0">

                    <!-- Seletor de configuração (condicional) -->
                    <StackPanel x:Name="ConfigurationsLabel"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Configurações salvas"
                                   Style="{StaticResource DevToolsCardTitle}"/>
                        <Border Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Width="16" Height="16"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource DevToolsTextSecondary}"
                                ToolTipService.InitialShowDelay="200"
                                ToolTipService.ShowDuration="30000">
                            <Border.ToolTip>
                                <ToolTip Placement="Right" MaxWidth="360">
                                    <TextBlock TextWrapping="Wrap"
                                               Text="Escolha uma configuração salva ou selecione 'Configurar manualmente' para preencher os campos sem usar configuração salva."/>
                                </ToolTip>
                            </Border.ToolTip>
                            <TextBlock Text="?"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource DevToolsTextSecondary}"/>
                        </Border>
                    </StackPanel>
                    <ComboBox x:Name="ConfigurationsCombo"
                              Margin="0,8,0,16"
                              Style="{StaticResource DevToolsSelectInput}"
                              SelectionChanged="ConfigurationsCombo_SelectionChanged"
                              DisplayMemberPath="Label"/>

                    <Border x:Name="ConfigurationModeHint"
                            Visibility="Collapsed"
                            BorderThickness="1"
                            CornerRadius="4"
                            BorderBrush="{DynamicResource DevToolsBrushBorder}"
                            Background="{DynamicResource DevToolsSurface}"
                            Padding="10,8"
                            Margin="0,0,0,12">
                        <TextBlock Text="Modo configuração: preencha os campos abaixo para salvar uma configuração reutilizável."
                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- ===== Campos de configuração (modo Configuração) ===== -->
                    <Grid x:Name="ConfigurationMetadataSection"
                          Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nome"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="NameInput"
                                     Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Descrição"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <TextBox x:Name="DescriptionInput"
                                     Style="{StaticResource DevToolsTextInput}"/>
                        </StackPanel>
                    </Grid>

                    <!-- ===== Caminhos ===== -->
                    <c:PathSelector x:Name="RootPathSelector"
                                    Title="Pasta raiz do projeto *"
                                    IsFolderPicker="True"
                                    Margin="0,0,0,12"/>

                    <c:PathSelector x:Name="StartupProjectSelector"
                                    Title="Startup project (.csproj) *"
                                    IsFolderPicker="False"
                                    Margin="0,0,0,12"/>

                    <!-- ===== DbContext ===== -->
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="DbContext (nome completo com namespace) *"
                                   Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="DbContextInput"
                                 Style="{StaticResource DevToolsTextInput}"
                                 ToolTip="Ex: MyApp.Infrastructure.Data.AppDbContext"/>
                    </StackPanel>

                    <!-- ===== Projetos por provedor ===== -->
                    <TextBlock Text="Projetos de migração por provedor"
                               Style="{StaticResource DevToolsCardTitle}"
                               Margin="0,4,0,10"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="SQL Server (.csproj)"
                                   Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="SqlServerProjectInput"
                                 Grid.Column="2"
                                 Style="{StaticResource DevToolsTextInput}"
                                 ToolTip="Caminho do .csproj de migrations para SQL Server. Deixe vazio se não usar."/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="SQLite (.csproj)"
                                   Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="SqliteProjectInput"
                                 Grid.Column="2"
                                 Style="{StaticResource DevToolsTextInput}"
                                 ToolTip="Caminho do .csproj de migrations para SQLite. Deixe vazio se não usar."/>
                    </Grid>

                    <!-- ===== Execução ===== -->
                    <TextBlock Text="Execução"
                               Style="{StaticResource DevToolsCardTitle}"
                               Margin="0,4,0,10"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ação *"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <ComboBox x:Name="ActionCombo"
                                      Style="{StaticResource DevToolsSelectInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Provedor *"
                                       Style="{StaticResource DevToolsInputLabel}"/>
                            <ComboBox x:Name="ProviderCombo"
                                      Style="{StaticResource DevToolsSelectInput}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="MigrationNamePanel" Margin="0,0,0,12">
                        <TextBlock Text="Nome da migration *"
                                   Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="MigrationNameInput"
                                 Style="{StaticResource DevToolsTextInput}"
                                 ToolTip="So para AddMigration. Ex: AddUserTable"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Argumentos adicionais"
                                   Style="{StaticResource DevToolsInputLabel}"/>
                        <TextBox x:Name="AdditionalArgsInput"
                                 Style="{StaticResource DevToolsTextInput}"
                                 ToolTip="Ex: --no-build"/>
                    </StackPanel>

                    <CheckBox x:Name="IsDefaultCheck"
                              Content="Marcar como configuração padrão"
                              Style="{StaticResource DevToolsCheckBox}"
                              Margin="0,0,0,8"/>

                    <CheckBox x:Name="DryRunCheck"
                              Content="Dry run (apenas mostrar o comando, sem executar)"
                              Style="{StaticResource DevToolsCheckBox}"
                              Margin="0,0,0,12"/>

                    <!-- Resultado -->
                    <Border x:Name="ResultPanel"
                            Visibility="Collapsed"
                            BorderThickness="1" CornerRadius="4"
                            BorderBrush="{DynamicResource DevToolsBrushBorder}"
                            Padding="10,8" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock x:Name="ResultCommandText"
                                       FontFamily="Consolas,Courier New"
                                       FontSize="11"
                                       Foreground="{DynamicResource DevToolsTextSecondary}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="ResultOutputText"
                                     Style="{StaticResource DevToolsTextInput}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas,Courier New"
                                     FontSize="11"
                                     Height="120"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ==================== STATUS ==================== -->
            <TextBlock x:Name="ExecutionStatusText"
                       Grid.Row="3"
                       Margin="0,10,0,0"
                       Foreground="{DynamicResource DevToolsTextSecondary}"/>
        </Grid>
    </Grid>
</UserControl>
