<Window x:Class="DevTools.Host.Wpf.Components.DevToolsMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MinWidth="360"
        MaxWidth="520">

    <Border Background="{DynamicResource DevToolsSurface}"
            BorderBrush="{DynamicResource DevToolsBrushBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="28,24,28,24"
            SnapsToDevicePixels="True">
        <StackPanel>

            <!-- Ícone + Título -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <TextBlock x:Name="IconText"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="20"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <TextBlock x:Name="TitleText"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DevToolsTextPrimary}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Separador -->
            <Border Height="1"
                    Background="{DynamicResource DevToolsBrushBorder}"
                    Margin="0,0,0,18"/>

            <!-- Mensagem -->
            <TextBlock x:Name="MessageText"
                       Foreground="{DynamicResource DevToolsTextPrimary}"
                       FontSize="13"
                       TextWrapping="Wrap"
                       LineHeight="20"
                       Margin="0,0,0,24"/>

            <!-- Botões -->
            <StackPanel x:Name="ButtonPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"/>

        </StackPanel>
    </Border>
</Window>
