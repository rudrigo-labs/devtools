<UserControl x:Class="DevTools.Host.Wpf.Components.ActionBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             x:Name="Root">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,0,0,6">

        <Button Style="{StaticResource ActionBarCancelButton}"
                IsEnabled="{Binding CanHelp, ElementName=Root}"
                ToolTip="{Binding HelpText, ElementName=Root}"
                Visibility="{Binding ShowHelp, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="HelpCircleOutline" Width="16" Height="16" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding HelpTextLabel, ElementName=Root}"/>
            </StackPanel>
        </Button>

        <Button Style="{StaticResource ActionBarNewButton}"
                Click="ActionNew_Click"
                IsEnabled="{Binding CanNew, ElementName=Root}"
                Visibility="{Binding ShowNew, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding NewText, ElementName=Root}"/>
            </StackPanel>
        </Button>

        <Button Style="{StaticResource ActionBarSaveButton}"
                Click="ActionSave_Click"
                IsEnabled="{Binding CanSave, ElementName=Root}"
                Visibility="{Binding ShowSave, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding SaveText, ElementName=Root}"/>
            </StackPanel>
        </Button>

        <Button Style="{StaticResource ActionBarDeleteButton}"
                Click="ActionDelete_Click"
                IsEnabled="{Binding CanDelete, ElementName=Root}"
                Visibility="{Binding ShowDelete, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding DeleteText, ElementName=Root}"/>
            </StackPanel>
        </Button>

        <Button Style="{StaticResource ActionBarCancelButton}"
                Click="ActionCancel_Click"
                IsEnabled="{Binding CanCancel, ElementName=Root}"
                Visibility="{Binding ShowCancel, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Close" Width="16" Height="16" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding CancelText, ElementName=Root}"/>
            </StackPanel>
        </Button>

    </StackPanel>
</UserControl>


