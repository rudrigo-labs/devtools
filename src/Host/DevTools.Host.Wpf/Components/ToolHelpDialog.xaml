<Window x:Class="DevTools.Host.Wpf.Components.ToolHelpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajuda"
        Width="760"
        Height="560"
        MinWidth="760"
        MinHeight="560"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="Transparent">

    <Border Margin="10"
            Background="{DynamicResource DevToolsWindowBackground}"
            BorderBrush="{DynamicResource DevToolsBrushBorder}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="DialogTitleText"
                       Grid.Row="0"
                       Style="{StaticResource DevToolsPageTitle}"
                       Margin="0,0,0,10"/>

            <TabControl Grid.Row="1">
                <TabItem Header="Objetivo">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="10">
                        <TextBlock x:Name="ObjetivoText"
                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                   TextWrapping="Wrap"
                                   xml:space="preserve"/>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Como usar">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="10">
                        <TextBlock x:Name="ComoUsarText"
                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                   TextWrapping="Wrap"
                                   xml:space="preserve"/>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Exemplo">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="10">
                        <TextBlock x:Name="ExemploText"
                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                   TextWrapping="Wrap"
                                   xml:space="preserve"/>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Observa&#231;&#245;es">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="10">
                        <TextBlock x:Name="ObservacoesText"
                                   Foreground="{DynamicResource DevToolsTextSecondary}"
                                   TextWrapping="Wrap"
                                   xml:space="preserve"/>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,14,0,0">
                <Button Content="Fechar"
                        MinWidth="110"
                        Style="{StaticResource DevToolsSecondaryButton}"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
